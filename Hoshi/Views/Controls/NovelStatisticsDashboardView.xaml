<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="Hoshi.Views.Controls.NovelStatisticsDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Hoshi.Views.Controls"
             xmlns:converters="using:Hoshi.Helpers.UI.Converters"
             xmlns:novel="using:Hoshi.Models.Novel">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="DashboardCardStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <DataTemplate x:Key="MetricTemplate"
                      x:DataType="novel:NovelStatisticsMetricDisplay">
            <StackPanel MinWidth="170"
                        Padding="0,6"
                        Spacing="4">
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind Label}" />
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="{x:Bind Value}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="WeekDayTemplate"
                      x:DataType="novel:NovelStatisticsWeekDayDisplay">
            <Border MinWidth="44"
                    MinHeight="58"
                    Margin="3"
                    Padding="8"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="8"
                    AutomationProperties.Name="{x:Bind Weekday}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <TextBlock HorizontalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="{x:Bind Weekday}" />
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind PercentText}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CalendarDayTemplate"
                      x:DataType="novel:NovelStatisticsCalendarDayDisplay">
            <Grid Width="18"
                  Height="18"
                  Margin="2"
                  AutomationProperties.Name="{x:Bind AccessibleText}">
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="3"
                        Opacity="{x:Bind HeatOpacity}" />
                <Border BorderBrush="{ThemeResource AccentStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Visibility="{x:Bind IsInSelectedRange, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="BookRankingTemplate"
                      x:DataType="novel:NovelStatisticsBookRankingDisplayRow">
            <StackPanel Padding="0,7"
                        Spacing="6">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <TextBlock FontWeight="SemiBold"
                               Text="{x:Bind Title}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ValueText}" />
                </Grid>
                <ProgressBar Maximum="1"
                             Value="{x:Bind NormalizedValue}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ShelfComparisonTemplate"
                      x:DataType="novel:NovelStatisticsShelfComparisonDisplayRow">
            <StackPanel Padding="0,8"
                        Spacing="6">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold"
                                   Text="{x:Bind Name}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="{x:Bind DetailText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="{x:Bind SpeedText}" />
                </Grid>
                <ProgressBar Maximum="1"
                             Value="{x:Bind NormalizedVolume}" />
                <ProgressBar Height="3"
                             Maximum="1"
                             Opacity="0.55"
                             Value="{x:Bind RecordedProgress}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Padding="20,0,36,24">
        <ScrollViewer AutomationProperties.AutomationId="NovelStatisticsDashboardScrollViewer"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled"
                      Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel MaxWidth="1440"
                        HorizontalAlignment="Stretch"
                        Spacing="18">
                <StackPanel Margin="0,8,0,6"
                            Spacing="4">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}"
                               Text="Statistics" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="Your reading activity, goals, trends, and library comparisons." />
                </StackPanel>

                <InfoBar AutomationProperties.AutomationId="NovelStatisticsCorruptWarning"
                         IsClosable="False"
                         IsOpen="{Binding HasCorruptBooks}"
                         Message="{Binding CorruptWarningText}"
                         Severity="Warning" />

                <Border AutomationProperties.AutomationId="NovelStatisticsTrendCard"
                        Style="{StaticResource DashboardCardStyle}">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="3">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                           Text="Range &amp; Trend" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{Binding RangeTitle}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Bottom"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{Binding RangeText}" />
                        </Grid>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      HorizontalScrollMode="Enabled"
                                      VerticalScrollBarVisibility="Disabled"
                                      VerticalScrollMode="Disabled">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Range" />
                                    <ComboBox MinWidth="110"
                                              AutomationProperties.AutomationId="NovelStatisticsRangeMode"
                                              ItemsSource="{Binding RangeModes}"
                                              SelectedItem="{Binding SelectedRangeMode, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Anchor" />
                                    <CalendarDatePicker Width="158"
                                                        AutomationProperties.AutomationId="NovelStatisticsAnchorDate"
                                                        Date="{Binding AnchorDate, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Time Grain" />
                                    <ComboBox MinWidth="105"
                                              AutomationProperties.AutomationId="NovelStatisticsTrendGrain"
                                              ItemsSource="{Binding TrendGrains}"
                                              SelectedItem="{Binding SelectedTrendGrain, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Metric" />
                                    <ComboBox MinWidth="116"
                                              AutomationProperties.AutomationId="NovelStatisticsTrendMetric"
                                              ItemsSource="{Binding TrendMetrics}"
                                              SelectedItem="{Binding SelectedTrendMetric, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Style" />
                                    <ComboBox MinWidth="96"
                                              AutomationProperties.AutomationId="NovelStatisticsTrendStyle"
                                              ItemsSource="{Binding TrendStyles}"
                                              SelectedItem="{Binding SelectedTrendStyle, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="Range filters all dashboard cards. Time Grain changes only the trend chart." />
                        <controls:NovelStatisticsTrendChart ItemsSource="{Binding TrendPoints}"
                                                            ChartStyle="{Binding SelectedTrendStyle}" />
                    </StackPanel>
                </Border>

                <Grid x:Name="DashboardCardsGrid"
                      ColumnSpacing="14"
                      RowSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="DashboardPrimaryColumn" Width="*" />
                        <ColumnDefinition x:Name="DashboardSecondaryColumn" Width="*" />
                        <ColumnDefinition x:Name="DashboardTertiaryColumn" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="DashboardLayoutStates">
                            <VisualState x:Name="NarrowDashboardState">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="0" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="DashboardSecondaryColumn.Width" Value="0" />
                                    <Setter Target="DashboardTertiaryColumn.Width" Value="0" />
                                    <Setter Target="TodayCard.(Grid.Row)" Value="0" />
                                    <Setter Target="TodayCard.(Grid.Column)" Value="0" />
                                    <Setter Target="GoalCard.(Grid.Row)" Value="1" />
                                    <Setter Target="GoalCard.(Grid.Column)" Value="0" />
                                    <Setter Target="WeekCard.(Grid.Row)" Value="2" />
                                    <Setter Target="WeekCard.(Grid.Column)" Value="0" />
                                    <Setter Target="WeekCard.(Grid.ColumnSpan)" Value="1" />
                                    <Setter Target="SelectedRangeCard.(Grid.Row)" Value="4" />
                                    <Setter Target="SelectedRangeCard.(Grid.Column)" Value="0" />
                                    <Setter Target="SpeedCard.(Grid.Row)" Value="5" />
                                    <Setter Target="SpeedCard.(Grid.Column)" Value="0" />
                                    <Setter Target="CalendarCard.(Grid.Row)" Value="3" />
                                    <Setter Target="CalendarCard.(Grid.Column)" Value="0" />
                                    <Setter Target="CalendarCard.(Grid.ColumnSpan)" Value="1" />
                                    <Setter Target="RankingCard.(Grid.Row)" Value="6" />
                                    <Setter Target="RankingCard.(Grid.Column)" Value="0" />
                                    <Setter Target="RankingCard.(Grid.ColumnSpan)" Value="1" />
                                    <Setter Target="ShelfCard.(Grid.Row)" Value="7" />
                                    <Setter Target="ShelfCard.(Grid.Column)" Value="0" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="MediumDashboardState">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="840" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="DashboardSecondaryColumn.Width" Value="*" />
                                    <Setter Target="DashboardTertiaryColumn.Width" Value="0" />
                                    <Setter Target="TodayCard.(Grid.Row)" Value="0" />
                                    <Setter Target="TodayCard.(Grid.Column)" Value="0" />
                                    <Setter Target="GoalCard.(Grid.Row)" Value="1" />
                                    <Setter Target="GoalCard.(Grid.Column)" Value="0" />
                                    <Setter Target="WeekCard.(Grid.Row)" Value="2" />
                                    <Setter Target="WeekCard.(Grid.Column)" Value="0" />
                                    <Setter Target="WeekCard.(Grid.ColumnSpan)" Value="1" />
                                    <Setter Target="SelectedRangeCard.(Grid.Row)" Value="0" />
                                    <Setter Target="SelectedRangeCard.(Grid.Column)" Value="1" />
                                    <Setter Target="SpeedCard.(Grid.Row)" Value="1" />
                                    <Setter Target="SpeedCard.(Grid.Column)" Value="1" />
                                    <Setter Target="CalendarCard.(Grid.Row)" Value="3" />
                                    <Setter Target="CalendarCard.(Grid.Column)" Value="0" />
                                    <Setter Target="CalendarCard.(Grid.ColumnSpan)" Value="1" />
                                    <Setter Target="RankingCard.(Grid.Row)" Value="2" />
                                    <Setter Target="RankingCard.(Grid.Column)" Value="1" />
                                    <Setter Target="RankingCard.(Grid.ColumnSpan)" Value="1" />
                                    <Setter Target="ShelfCard.(Grid.Row)" Value="4" />
                                    <Setter Target="ShelfCard.(Grid.Column)" Value="0" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="WideDashboardState">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="1260" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="DashboardSecondaryColumn.Width" Value="*" />
                                    <Setter Target="DashboardTertiaryColumn.Width" Value="*" />
                                    <Setter Target="TodayCard.(Grid.Row)" Value="0" />
                                    <Setter Target="TodayCard.(Grid.Column)" Value="0" />
                                    <Setter Target="GoalCard.(Grid.Row)" Value="1" />
                                    <Setter Target="GoalCard.(Grid.Column)" Value="0" />
                                    <Setter Target="WeekCard.(Grid.Row)" Value="2" />
                                    <Setter Target="WeekCard.(Grid.Column)" Value="0" />
                                    <Setter Target="WeekCard.(Grid.ColumnSpan)" Value="1" />
                                    <Setter Target="SelectedRangeCard.(Grid.Row)" Value="0" />
                                    <Setter Target="SelectedRangeCard.(Grid.Column)" Value="2" />
                                    <Setter Target="SpeedCard.(Grid.Row)" Value="1" />
                                    <Setter Target="SpeedCard.(Grid.Column)" Value="2" />
                                    <Setter Target="CalendarCard.(Grid.Row)" Value="0" />
                                    <Setter Target="CalendarCard.(Grid.Column)" Value="1" />
                                    <Setter Target="CalendarCard.(Grid.ColumnSpan)" Value="1" />
                                    <Setter Target="RankingCard.(Grid.Row)" Value="2" />
                                    <Setter Target="RankingCard.(Grid.Column)" Value="1" />
                                    <Setter Target="RankingCard.(Grid.ColumnSpan)" Value="2" />
                                    <Setter Target="ShelfCard.(Grid.Row)" Value="1" />
                                    <Setter Target="ShelfCard.(Grid.Column)" Value="1" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>

                    <Border x:Name="TodayCard"
                            Grid.Row="0"
                            Grid.Column="0"
                            AutomationProperties.AutomationId="NovelStatisticsTodayCard"
                            Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Spacing="14">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="3">
                                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                               Text="Today" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="{Binding TodayText}" />
                                </StackPanel>
                                <Grid Grid.Column="1"
                                      Width="88"
                                      Height="88">
                                    <ProgressRing IsActive="True"
                                                  IsIndeterminate="False"
                                                  Maximum="100"
                                                  Value="{Binding Today.TargetPercent}" />
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Text="{Binding TodayGoalPercentText}" />
                                </Grid>
                            </Grid>
                            <ItemsControl ItemTemplate="{StaticResource MetricTemplate}"
                                          ItemsSource="{Binding TodayMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid ItemWidth="160"
                                                       MaximumRowsOrColumns="2"
                                                       Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="GoalCard"
                            Grid.Row="0"
                            Grid.Column="1"
                            AutomationProperties.AutomationId="NovelStatisticsGoalCard"
                            Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                       Text="Goal" />
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <TextBlock VerticalAlignment="Center"
                                           Text="Goal Type" />
                                <ComboBox Grid.Column="1"
                                          MinWidth="130"
                                          AutomationProperties.AutomationId="NovelStatisticsGoalType"
                                          ItemsSource="{Binding DailyTargetTypes}"
                                          SelectedItem="{Binding SelectedDailyTargetType, Mode=TwoWay}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <TextBlock VerticalAlignment="Center"
                                           Text="Character Target" />
                                <NumberBox Grid.Column="1"
                                           Width="126"
                                           AutomationProperties.AutomationId="NovelStatisticsCharacterTarget"
                                           Minimum="500"
                                           Maximum="20000"
                                           SmallChange="500"
                                           Value="{Binding DailyCharacterTargetValue, Mode=TwoWay}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <TextBlock VerticalAlignment="Center"
                                           Text="Duration Target" />
                                <NumberBox Grid.Column="1"
                                           Width="126"
                                           AutomationProperties.AutomationId="NovelStatisticsDurationTarget"
                                           Minimum="5"
                                           Maximum="240"
                                           SmallChange="5"
                                           Value="{Binding DailyDurationTargetMinutesValue, Mode=TwoWay}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <TextBlock VerticalAlignment="Center"
                                           Text="Weekly Target Days" />
                                <NumberBox Grid.Column="1"
                                           Width="126"
                                           AutomationProperties.AutomationId="NovelStatisticsWeeklyTarget"
                                           Minimum="1"
                                           Maximum="7"
                                           SmallChange="1"
                                           Value="{Binding WeeklyTargetDaysValue, Mode=TwoWay}" />
                            </Grid>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Goals recalculate historical progress and streaks."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="WeekCard"
                            Grid.Row="0"
                            Grid.Column="2"
                            AutomationProperties.AutomationId="NovelStatisticsWeekCard"
                            Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                           Text="This Week" />
                                <TextBlock Grid.Column="1"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{Binding WeekText}" />
                            </Grid>
                            <ItemsControl ItemTemplate="{StaticResource MetricTemplate}"
                                          ItemsSource="{Binding WeekMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid ItemWidth="160"
                                                       MaximumRowsOrColumns="2"
                                                       Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <ItemsControl AutomationProperties.AutomationId="NovelStatisticsWeekDays"
                                          ItemTemplate="{StaticResource WeekDayTemplate}"
                                          ItemsSource="{Binding WeekDays}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel HorizontalAlignment="Stretch"
                                                    Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="SelectedRangeCard"
                            Grid.Row="1"
                            Grid.Column="0"
                            AutomationProperties.AutomationId="NovelStatisticsSelectedRangeCard"
                            Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                       Text="Selected Range" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{Binding RangeTitle}" />
                            <ItemsControl ItemTemplate="{StaticResource MetricTemplate}"
                                          ItemsSource="{Binding RangeMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid ItemWidth="160"
                                                       MaximumRowsOrColumns="2"
                                                       Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <ProgressBar Maximum="100"
                                         Value="{Binding SelectedRange.TargetProgressPercent}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="SpeedCard"
                            Grid.Row="1"
                            Grid.Column="1"
                            AutomationProperties.AutomationId="NovelStatisticsSpeedCard"
                            Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                           Text="Speed Summary" />
                                <TextBlock Grid.Column="1"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{Binding SpeedText}" />
                            </Grid>
                            <ItemsControl ItemTemplate="{StaticResource MetricTemplate}"
                                          ItemsSource="{Binding SpeedMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid ItemWidth="190"
                                                       MaximumRowsOrColumns="3"
                                                       Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Speed ignores reading samples under 1 minute." />
                        </StackPanel>
                    </Border>

                    <Border x:Name="CalendarCard"
                            Grid.Row="1"
                            Grid.Column="2"
                            AutomationProperties.AutomationId="NovelStatisticsCalendarCard"
                            Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="3">
                                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                               Text="Reading Calendar" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="Recent year" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Bottom"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{Binding RangeTitle}" />
                            </Grid>
                            <ListView MaxHeight="190"
                                      AutomationProperties.AutomationId="NovelStatisticsCalendar"
                                      ItemTemplate="{StaticResource CalendarDayTemplate}"
                                      ItemsSource="{Binding CalendarDays}"
                                      SelectedItem="{Binding SelectedCalendarDay, Mode=TwoWay}"
                                      SelectionMode="Single"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollMode="Enabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollMode="Disabled">
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid MaximumRowsOrColumns="7"
                                                       Orientation="Vertical" />
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                            </ListView>
                            <Border Padding="12"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="8">
                                <TextBlock AutomationProperties.AutomationId="NovelStatisticsCalendarDetail"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{Binding CalendarDetail.Text}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="RankingCard"
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            AutomationProperties.AutomationId="NovelStatisticsBookRankingCard"
                            Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <StackPanel Spacing="3">
                                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                               Text="Book Ranking" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="{Binding RangeTitle}" />
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          MinWidth="120"
                                          AutomationProperties.AutomationId="NovelStatisticsRankingMetric"
                                          ItemsSource="{Binding RankingMetrics}"
                                          SelectedItem="{Binding SelectedRankingMetric, Mode=TwoWay}" />
                            </Grid>
                            <ItemsControl AutomationProperties.AutomationId="NovelStatisticsBookRanking"
                                          ItemTemplate="{StaticResource BookRankingTemplate}"
                                          ItemsSource="{Binding BookRankingRows}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="ShelfCard"
                            Grid.Row="2"
                            Grid.Column="2"
                            AutomationProperties.AutomationId="NovelStatisticsShelfComparisonCard"
                            Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="3">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                           Text="Shelf Comparison" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{Binding RangeTitle}" />
                            </StackPanel>
                            <ItemsControl AutomationProperties.AutomationId="NovelStatisticsShelfComparison"
                                          ItemTemplate="{StaticResource ShelfComparisonTemplate}"
                                          ItemsSource="{Binding ShelfComparisonRows}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    AutomationProperties.AutomationId="NovelStatisticsLoadingStatus"
                    Spacing="12"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressRing Width="48"
                          Height="48"
                          IsActive="{Binding IsLoading}" />
            <TextBlock Text="Loading statistics…" />
        </StackPanel>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    AutomationProperties.AutomationId="NovelStatisticsEmptyState"
                    Spacing="8"
                    Visibility="{Binding HasNoData, Converter={StaticResource BooleanToVisibilityConverter}}">
            <FontIcon FontSize="36"
                      Glyph="&#xE9D9;"
                      Opacity="0.5" />
            <TextBlock Style="{StaticResource BodyLargeStrongTextBlockStyle}"
                       Text="No reading statistics yet" />
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Read a novel to start building your dashboard." />
        </StackPanel>
    </Grid>
</UserControl>
