<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="Hoshi.Views.Controls.ReaderChapterListContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dialogs="using:Hoshi.Views.Dialogs"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid RowDefinitions="Auto,*" RowSpacing="12">
        <StackPanel Spacing="8">
            <TextBlock x:Name="CharacterJumpStatusText"
                       x:Uid="NovelReaderCharacterJumpStatus"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Text="Current character position" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <NumberBox x:Name="CharacterJumpNumberBox"
                           x:Uid="NovelReaderCharacterJumpNumberBox"
                           AutomationProperties.AutomationId="NovelReaderCharacterJumpNumberBox"
                           Minimum="0"
                           SmallChange="100"
                           LargeChange="1000"
                           SpinButtonPlacementMode="Compact" />
                <Button Grid.Column="1"
                        x:Uid="NovelReaderCharacterJumpButton"
                        AutomationProperties.AutomationId="NovelReaderCharacterJumpButton"
                        Click="CharacterJumpButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="12" Glyph="&#xE8AD;" />
                        <TextBlock x:Uid="NovelReaderCharacterJumpButtonText" Text="Go" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>

        <ListView x:Name="ChapterListView"
                  Grid.Row="1"
                  AutomationProperties.AutomationId="NovelReaderChapterList"
                  IsItemClickEnabled="True"
                  ItemClick="ChapterListView_ItemClick"
                  SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="dialogs:ChapterDisplayItem">
                    <Grid Padding="4,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock FontWeight="SemiBold"
                                       Text="{x:Bind DisplayTitle}" />
                            <TextBlock FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind Subtitle}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Text="{x:Bind CharacterCountText}"
                                   Visibility="{x:Bind CharacterCountVisibility, Mode=OneWay}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
