<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Hoshi.Views.Pages.NavigationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:Hoshi.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      NavigationCacheMode="Required"
      mc:Ignorable="d">

    <Grid>
        <Grid x:Name="AppTitleBar"
              Height="48"
              Padding="0"
              VerticalAlignment="Top"
              AutomationProperties.AutomationId="AppTitleBar"
              ColumnDefinitions="Auto, Auto, *, 144">
            <Image Width="19"
                   Height="19"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Source="/Assets/Square44x44Logo.altform-unplated_targetsize-48.png" />
            <TextBlock Grid.Column="1"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Text="Hoshi" />
            <AutoSuggestBox Grid.Column="2"
                            MaxWidth="300"
                            Margin="8,0,8,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            IsEnabled="{x:Bind ViewModel.IsSearchEnabled, Mode=OneWay}"
                            PlaceholderText="Search"
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                            TextChanged="AutoSuggestBox_TextChanged" />
        </Grid>

        <NavigationView x:Name="NavigationViewControl"
                        BackRequested="NavigationViewControl_BackRequested"
                        DisplayModeChanged="NavigationViewControl_DisplayModeChanged"
                        IsBackEnabled="{x:Bind ViewModel.IsBackEnabled, Mode=OneWay}"
                        IsSettingsVisible="False"
                        ItemInvoked="NavigationViewControl_ItemInvoked"
                        OpenPaneLength="200"
                        PaneDisplayMode="Auto">
            <NavigationView.Resources>
                <Thickness x:Key="NavigationViewContentMargin">0,48,0,0</Thickness>
                <Thickness x:Key="NavigationViewMinimalContentMargin">0,48,0,0</Thickness>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">1,1,0,0</Thickness>
                <Thickness x:Key="NavigationViewHeaderMargin">36,30,36,0</Thickness>
                <!--  This is the rounded corner on the Top left of the L Pattern  -->
                <CornerRadius x:Key="NavigationViewContentGridCornerRadius">8,0,0,0</CornerRadius>
            </NavigationView.Resources>

            <NavigationView.MenuItems>
                <NavigationViewItem AutomationProperties.AutomationId="NovelNavItem"
                                    Content="Novels"
                                    Icon="Library"
                                    IsSelected="True"
                                    Tag="Hoshi.Views.Pages.NovelLibraryPage" />

            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem AutomationProperties.AutomationId="SettingsNavItem"
                                    Content="设置"
                                    Icon="Setting"
                                    Tag="Hoshi.Views.Pages.SettingsPage" />
                <NavigationViewItem AutomationProperties.AutomationId="NormalLogsNavItem"
                                    Content="普通日志"
                                    Icon="Document"
                                    Tag="Hoshi.Views.Pages.NormalLogsPage" />
                <NavigationViewItem AutomationProperties.AutomationId="ErrorLogsNavItem"
                                    Content="错误日志"
                                    Icon="ReportHacked"
                                    Tag="Hoshi.Views.Pages.ErrorLogsPage" />
                <NavigationViewItem Content="Help"
                                    Icon="Help"
                                    IsEnabled="False"
                                    Tag="Hoshi.Views.Pages.HelpPage" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Padding="16,16,0,0" Navigated="ContentFrame_Navigated">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Page>
