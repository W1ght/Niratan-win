<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Hoshi.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      mc:Ignorable="d">

    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <Grid x:Name="SettingsRoot" RowDefinitions="Auto,*">
        <StackPanel MaxWidth="1016"
                    Padding="20,14,36,16"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
            <FontIcon FontSize="24" Glyph="&#xE713;" />
            <TextBlock x:Uid="SettingsPageTitle"
                       VerticalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="Settings" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="0,0,16,16">
                <StackPanel MaxWidth="1000"
                            HorizontalAlignment="Stretch"
                            Spacing="{StaticResource SettingsCardSpacing}">
                    <StackPanel.ChildrenTransitions>
                        <EntranceThemeTransition FromVerticalOffset="50" />
                        <RepositionThemeTransition IsStaggeringEnabled="False" />
                    </StackPanel.ChildrenTransitions>

                    <toolkit:SettingsCard x:Uid="SettingsDictionariesCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}">
                        <Button AutomationProperties.AutomationId="DictionarySettingsButton"
                                AutomationProperties.Name="Open Dictionary Settings"
                                x:Uid="DictionarySettingsButton"
                                Click="DictionarySettings_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Uid="SettingsOpenDictionaryText" Text="Open" />
                                <FontIcon Glyph="&#xE76C;" FontSize="14" />
                            </StackPanel>
                        </Button>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="SettingsAnkiCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE71B;}">
                        <Button AutomationProperties.AutomationId="AnkiSettingsButton"
                                AutomationProperties.Name="Open AnkiConnect Settings"
                                x:Uid="AnkiSettingsButton"
                                Click="AnkiSettings_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Uid="SettingsOpenAnkiText" Text="Open" />
                                <FontIcon Glyph="&#xE76C;" FontSize="14" />
                            </StackPanel>
                        </Button>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="SettingsAppearanceCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                        <Button AutomationProperties.AutomationId="ReaderAppearanceSettingsButton"
                                AutomationProperties.Name="Open Reader Appearance Settings"
                                x:Uid="ReaderAppearanceSettingsButton"
                                Click="ReaderAppearanceSettings_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Uid="SettingsOpenAppearanceText" Text="Open" />
                                <FontIcon Glyph="&#xE76C;" FontSize="14" />
                            </StackPanel>
                        </Button>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="SettingsAdvancedCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE713;}">
                        <Button AutomationProperties.AutomationId="AdvancedSettingsButton"
                                x:Uid="AdvancedSettingsButton"
                                Click="AdvancedSettings_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Uid="SettingsOpenAdvancedText" Text="Open" />
                                <FontIcon Glyph="&#xE76C;" FontSize="14" />
                            </StackPanel>
                        </Button>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="SettingsSupportSectionHeader"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                               Text="Support" />

                    <toolkit:SettingsCard x:Uid="SettingsReportIssueCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE90A;}">
                        <HyperlinkButton x:Uid="SettingsReportIssueLink"
                                         Content="Report an Issue"
                                         NavigateUri="https://github.com/W1ght/Hoshi/issues" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsExpander x:Uid="SettingsAboutExpander"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch"
                                              Description="© 2026 TXG0Fk3. All rights reserved."
                                              Header="Hoshi"
                                              HeaderIcon="{ui:BitmapIcon Source=ms-appx:///Assets/Square44x44Logo.altform-lightunplated_targetsize-32.png}">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsTextSelectionEnabled="True">
                            <Run x:Uid="SettingsAboutVersionRun" Text="Version" />
                            <Run Text="{x:Bind ViewModel.HoshiVersion, Mode=OneTime}" />
                        </TextBlock>
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                                <StackPanel Margin="-12,0,0,0" Orientation="Vertical">
                                    <HyperlinkButton x:Uid="SettingsProjectRepositoryLink"
                                                     Content="Project Repository"
                                                     NavigateUri="https://github.com/W1ght/Hoshi" />
                                    <HyperlinkButton x:Uid="SettingsSendFeedbackLink"
                                                     Content="Send Feedback"
                                                     NavigateUri="https://github.com/W1ght/Hoshi/issues" />
                                </StackPanel>
                            </toolkit:SettingsCard>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
