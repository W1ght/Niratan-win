<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Hoshi.Views.Pages.DictionarySettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:helpers="using:Hoshi.Helpers.UI.Converters"
      xmlns:dictModels="using:Hoshi.Models.Dictionary"
      mc:Ignorable="d">

    <Page.Resources>
        <helpers:BooleanNegationConverter x:Key="BoolNegationConverter" />
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="SettingsSectionHeaderTextBlockStyle" BasedOn="{StaticResource BodyStrongTextBlockStyle}" TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="Auto,*">
        <StackPanel Padding="20,14,36,16"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
            <Button Width="36"
                    Height="36"
                    Padding="0"
                    AutomationProperties.AutomationId="DictionarySettingsBackButton"
                    Click="BackButton_Click">
                <FontIcon Glyph="&#xE72B;" />
            </Button>
            <FontIcon FontSize="24" Glyph="&#xE8F1;" />
            <TextBlock VerticalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="Dictionaries" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="0,0,16,16">
                <StackPanel MaxWidth="1000" HorizontalAlignment="Stretch" Spacing="4">
                    <toolkit:SettingsCard HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Import Yomitan-format dictionaries and use them for reader lookup"
                                          Header="Import"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8A5;}">
                        <Button AutomationProperties.AutomationId="ImportDictionaryButton"
                                AutomationProperties.Name="Import Dictionary"
                                Command="{x:Bind ViewModel.ImportDictionaryCommand}"
                                IsEnabled="{x:Bind ViewModel.IsDictionaryOperationInProgress, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8A5;" FontSize="14" />
                                <TextBlock Text="Import .zip" />
                            </StackPanel>
                        </Button>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Term dictionaries are used for definitions; frequency and pitch data are kept separately"
                                          Header="Dictionary Type"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}">
                        <ComboBox ItemsSource="{x:Bind ViewModel.AvailableDictionaryTypes}"
                                  SelectedItem="{x:Bind ViewModel.SelectedDictionaryType, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                        <Span><Bold>Installed</Bold></Span>
                    </TextBlock>

                    <toolkit:SettingsCard HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Enabled dictionaries are searched in this order"
                                          Header="Dictionary Order"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE700;}"
                                          Visibility="{x:Bind ViewModel.IsDictionaryListEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                        <StackPanel Spacing="8">
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind ViewModel.DictionaryStatusText, Mode=OneWay}" />
                            <ListView x:Name="DictionaryList"
                                      AutomationProperties.AutomationId="InstalledDictionaryList"
                                      AllowDrop="True"
                                      CanDragItems="True"
                                      CanReorderItems="True"
                                      DragItemsCompleted="DictionaryList_DragItemsCompleted"
                                      IsEnabled="{x:Bind ViewModel.IsDictionaryOperationInProgress, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                                      ItemsSource="{x:Bind ViewModel.InstalledDictionaries, Mode=OneWay}"
                                      MaxHeight="520"
                                      ReorderMode="Enabled"
                                      SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="dictModels:InstalledDictionary">
                                        <Grid Padding="0,4" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                            <FontIcon Grid.Column="0" Glyph="&#xE700;" FontSize="12" Opacity="0.65" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="{x:Bind Name}" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Text="{x:Bind Revision}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="2"
                                                          AutomationProperties.Name="Enable Dictionary"
                                                          IsOn="{x:Bind IsEnabled, Mode=OneWay}"
                                                          Tag="{x:Bind Name}"
                                                          Toggled="DictionaryEnabled_Toggled" />
                                            <Button Grid.Column="3"
                                                    Width="32"
                                                    Height="32"
                                                    Padding="0"
                                                    AutomationProperties.Name="Delete Dictionary"
                                                    Tag="{x:Bind Name}"
                                                    ToolTipService.ToolTip="Delete dictionary"
                                                    Click="DeleteDictionary_Click">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Import a Yomitan dictionary ZIP to enable lookup for this category"
                                          Header="No Dictionaries"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}"
                                          Visibility="{x:Bind ViewModel.IsDictionaryListEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
