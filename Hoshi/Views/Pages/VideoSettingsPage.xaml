<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Hoshi.Views.Pages.VideoSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="VideoSectionHeaderStyle" BasedOn="{StaticResource BodyStrongTextBlockStyle}" TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
        <Style x:Key="VideoSettingsValueTextStyle" BasedOn="{StaticResource CaptionTextBlockStyle}" TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="MinWidth" Value="56" />
                <Setter Property="TextAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="Auto,*">
        <StackPanel Padding="20,14,36,16"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
            <Button x:Name="VideoSettingsBackButton"
                    x:Uid="VideoSettingsBackButton"
                    Width="36"
                    Height="36"
                    Padding="0"
                    AutomationProperties.AutomationId="VideoSettingsBackButton"
                    Click="BackButton_Click">
                <FontIcon Glyph="&#xE72B;" />
            </Button>
            <FontIcon FontSize="24" Glyph="&#xE768;" />
            <TextBlock x:Uid="VideoSettingsPageTitle"
                       VerticalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="Video Settings" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="0,0,16,16">
                <StackPanel MaxWidth="1000" HorizontalAlignment="Stretch" Spacing="4">
                    <TextBlock x:Uid="VideoPlaybackSectionHeader"
                               Style="{StaticResource VideoSectionHeaderStyle}"
                               Text="Playback" />

                    <toolkit:SettingsCard x:Uid="VideoAutoPlayNextCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE892;}">
                        <ToggleSwitch x:Uid="VideoAutoPlayNextToggle"
                                      AutomationProperties.AutomationId="VideoAutoPlayNextToggle"
                                      IsOn="{x:Bind ViewModel.AutoPlayNextEpisode, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoRememberPlaybackStateCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE81C;}">
                        <ToggleSwitch x:Uid="VideoRememberPlaybackStateToggle"
                                      AutomationProperties.AutomationId="VideoRememberPlaybackStateToggle"
                                      IsOn="{x:Bind ViewModel.RememberPlaybackState, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSeekIntervalCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE96F;}">
                        <NumberBox Width="160"
                                   AutomationProperties.AutomationId="VideoSeekIntervalNumberBox"
                                   Minimum="1"
                                   Maximum="60"
                                   SmallChange="1"
                                   LargeChange="5"
                                   SpinButtonPlacementMode="Compact"
                                   Value="{x:Bind ViewModel.SeekIntervalSecondsValue, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoMiningHistoryLimitCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}">
                        <NumberBox Width="160"
                                   AutomationProperties.AutomationId="VideoMiningHistoryLimitNumberBox"
                                   Minimum="0"
                                   SmallChange="1"
                                   LargeChange="10"
                                   SpinButtonPlacementMode="Compact"
                                   Value="{x:Bind ViewModel.MiningHistoryLimitValue, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoKeyboardShortcutsCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE765;}">
                        <Button x:Uid="VideoKeyboardShortcutsButton"
                                AutomationProperties.AutomationId="VideoKeyboardShortcutsButton"
                                Click="KeyboardShortcutsButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8A7;" />
                                <TextBlock x:Uid="SettingsOpenText" Text="Open" />
                            </StackPanel>
                        </Button>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="VideoEngineSectionHeader"
                               Style="{StaticResource VideoSectionHeaderStyle}"
                               Text="Engine" />

                    <toolkit:SettingsCard x:Uid="VideoHardwareDecodingCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE7F8;}">
                        <ToggleSwitch x:Uid="VideoHardwareDecodingToggle"
                                      AutomationProperties.AutomationId="VideoHardwareDecodingToggle"
                                      IsOn="{x:Bind ViewModel.HardwareDecodingEnabled, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoDeinterlacingCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE9A6;}">
                        <ToggleSwitch x:Uid="VideoDeinterlacingToggle"
                                      AutomationProperties.AutomationId="VideoDeinterlacingToggle"
                                      IsOn="{x:Bind ViewModel.DeinterlacingEnabled, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoHdrEnhancementCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE706;}">
                        <ToggleSwitch x:Uid="VideoHdrEnhancementToggle"
                                      AutomationProperties.AutomationId="VideoHdrEnhancementToggle"
                                      IsOn="{x:Bind ViewModel.HdrEnhancementEnabled, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="VideoEqualizerSectionHeader"
                               Style="{StaticResource VideoSectionHeaderStyle}"
                               Text="Equalizer" />

                    <toolkit:SettingsCard x:Uid="VideoBrightnessCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE706;}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Width="260"
                                    Minimum="-100"
                                    Maximum="100"
                                    StepFrequency="1"
                                    AutomationProperties.AutomationId="VideoBrightnessSlider"
                                    Value="{x:Bind ViewModel.VideoBrightness, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.VideoBrightnessText, Mode=OneWay}"
                                       Style="{StaticResource VideoSettingsValueTextStyle}" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoContrastCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Width="260"
                                    Minimum="-100"
                                    Maximum="100"
                                    StepFrequency="1"
                                    AutomationProperties.AutomationId="VideoContrastSlider"
                                    Value="{x:Bind ViewModel.VideoContrast, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.VideoContrastText, Mode=OneWay}"
                                       Style="{StaticResource VideoSettingsValueTextStyle}" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSaturationCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Width="260"
                                    Minimum="-100"
                                    Maximum="100"
                                    StepFrequency="1"
                                    AutomationProperties.AutomationId="VideoSaturationSlider"
                                    Value="{x:Bind ViewModel.VideoSaturation, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.VideoSaturationText, Mode=OneWay}"
                                       Style="{StaticResource VideoSettingsValueTextStyle}" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoGammaCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Width="260"
                                    Minimum="-100"
                                    Maximum="100"
                                    StepFrequency="1"
                                    AutomationProperties.AutomationId="VideoGammaSlider"
                                    Value="{x:Bind ViewModel.VideoGamma, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.VideoGammaText, Mode=OneWay}"
                                       Style="{StaticResource VideoSettingsValueTextStyle}" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoHueCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Width="260"
                                    Minimum="-100"
                                    Maximum="100"
                                    StepFrequency="1"
                                    AutomationProperties.AutomationId="VideoHueSlider"
                                    Value="{x:Bind ViewModel.VideoHue, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.VideoHueText, Mode=OneWay}"
                                       Style="{StaticResource VideoSettingsValueTextStyle}" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="VideoSubtitleAppearanceSectionHeader"
                               Style="{StaticResource VideoSectionHeaderStyle}"
                               Text="Subtitle Appearance" />

                    <toolkit:SettingsCard x:Uid="VideoSubtitleFontFamilyCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8D2;}">
                        <TextBox Width="240"
                                 AutomationProperties.AutomationId="VideoSubtitleFontFamilyTextBox"
                                 Text="{x:Bind ViewModel.SubtitleFontFamily, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSubtitleFontSizeCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8D2;}">
                        <NumberBox Width="160"
                                   AutomationProperties.AutomationId="VideoSubtitleFontSizeNumberBox"
                                   Minimum="12"
                                   Maximum="72"
                                   SmallChange="1"
                                   LargeChange="4"
                                   SpinButtonPlacementMode="Compact"
                                   Value="{x:Bind ViewModel.SubtitleFontSizeValue, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSubtitleFontWeightCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8D2;}">
                        <NumberBox Width="160"
                                   AutomationProperties.AutomationId="VideoSubtitleFontWeightNumberBox"
                                   Minimum="100"
                                   Maximum="900"
                                   SmallChange="100"
                                   LargeChange="200"
                                   SpinButtonPlacementMode="Compact"
                                   Value="{x:Bind ViewModel.SubtitleFontWeightValue, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSubtitleShadowRadiusCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE7B3;}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Width="260"
                                    Minimum="0"
                                    Maximum="10"
                                    StepFrequency="0.5"
                                    AutomationProperties.AutomationId="VideoSubtitleShadowRadiusSlider"
                                    Value="{x:Bind ViewModel.SubtitleShadowRadius, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.SubtitleShadowRadiusText, Mode=OneWay}"
                                       Style="{StaticResource VideoSettingsValueTextStyle}" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSubtitleBackgroundOpacityCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Width="260"
                                    Minimum="0"
                                    Maximum="1"
                                    StepFrequency="0.05"
                                    AutomationProperties.AutomationId="VideoSubtitleBackgroundOpacitySlider"
                                    Value="{x:Bind ViewModel.SubtitleBackgroundOpacity, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.SubtitleBackgroundOpacityText, Mode=OneWay}"
                                       Style="{StaticResource VideoSettingsValueTextStyle}" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSubtitleBackgroundDisabledCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE711;}">
                        <ToggleSwitch x:Uid="VideoSubtitleBackgroundDisabledToggle"
                                      AutomationProperties.AutomationId="VideoSubtitleBackgroundDisabledToggle"
                                      IsOn="{x:Bind ViewModel.SubtitleBackgroundDisabled, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSubtitleVerticalPositionCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE74A;}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Width="260"
                                    Minimum="-200"
                                    Maximum="200"
                                    StepFrequency="1"
                                    AutomationProperties.AutomationId="VideoSubtitleVerticalPositionSlider"
                                    Value="{x:Bind ViewModel.SubtitleVerticalPosition, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.SubtitleVerticalPositionText, Mode=OneWay}"
                                       Style="{StaticResource VideoSettingsValueTextStyle}" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="VideoSubtitleColorsSectionHeader"
                               Style="{StaticResource VideoSectionHeaderStyle}"
                               Text="Subtitle Colors" />

                    <toolkit:SettingsCard x:Uid="VideoSubtitleColorCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                        <TextBox Width="160"
                                 AutomationProperties.AutomationId="VideoSubtitleColorTextBox"
                                 Text="{x:Bind ViewModel.SubtitleColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSubtitleLookupHighlightColorCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                        <TextBox Width="160"
                                 AutomationProperties.AutomationId="VideoSubtitleLookupHighlightColorTextBox"
                                 Text="{x:Bind ViewModel.SubtitleLookupHighlightColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSubtitleLookupHighlightTextColorCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                        <TextBox Width="160"
                                 AutomationProperties.AutomationId="VideoSubtitleLookupHighlightTextColorTextBox"
                                 Text="{x:Bind ViewModel.SubtitleLookupHighlightTextColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="VideoSubtitleMaskSectionHeader"
                               Style="{StaticResource VideoSectionHeaderStyle}"
                               Text="Subtitle Mask" />

                    <toolkit:SettingsCard x:Uid="VideoSubtitleMaskCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8A6;}">
                        <ToggleSwitch x:Uid="VideoSubtitleMaskToggle"
                                      AutomationProperties.AutomationId="VideoSubtitleMaskToggle"
                                      IsOn="{x:Bind ViewModel.SubtitleMaskEnabled, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSubtitleMaskModeCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8A6;}">
                        <ComboBox MinWidth="180"
                                  AutomationProperties.AutomationId="VideoSubtitleMaskModeComboBox"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{x:Bind ViewModel.AvailableSubtitleMaskModes}"
                                  SelectedValue="{x:Bind ViewModel.SelectedSubtitleMaskMode, Mode=TwoWay}"
                                  SelectedValuePath="Mode" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSubtitleMaskBlurRadiusCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8A6;}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Width="260"
                                    Minimum="0"
                                    Maximum="20"
                                    StepFrequency="1"
                                    AutomationProperties.AutomationId="VideoSubtitleMaskBlurRadiusSlider"
                                    Value="{x:Bind ViewModel.SubtitleMaskBlurRadius, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.SubtitleMaskBlurRadiusText, Mode=OneWay}"
                                       Style="{StaticResource VideoSettingsValueTextStyle}" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="VideoSubtitleMaskHiddenOpacityCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8A6;}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Slider Width="260"
                                    Minimum="0"
                                    Maximum="1"
                                    StepFrequency="0.05"
                                    AutomationProperties.AutomationId="VideoSubtitleMaskHiddenOpacitySlider"
                                    Value="{x:Bind ViewModel.SubtitleMaskHiddenOpacity, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.SubtitleMaskHiddenOpacityText, Mode=OneWay}"
                                       Style="{StaticResource VideoSettingsValueTextStyle}" />
                        </StackPanel>
                    </toolkit:SettingsCard>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
