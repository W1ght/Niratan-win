<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Hoshi.Views.Pages.NovelReaderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0"
              Padding="16,12"
              ColumnDefinitions="Auto,Auto,Auto,*"
              ColumnSpacing="8">
            <Button HorizontalAlignment="Left"
                    AutomationProperties.AutomationId="NovelReaderBackButton"
                    Command="{x:Bind ViewModel.BackToLibraryCommand}">
                <Button.Content>
                    <FontIcon Glyph="&#xE72B;" />
                </Button.Content>
            </Button>

            <Button Grid.Column="1"
                    HorizontalAlignment="Left"
                    AutomationProperties.AutomationId="NovelReaderChapterButton"
                    AutomationProperties.Name="Chapters"
                    Click="ChapterListButton_Click">
                <Button.Content>
                    <FontIcon Glyph="&#xE8A4;" />
                </Button.Content>
            </Button>

            <Button Grid.Column="2"
                    HorizontalAlignment="Left"
                    AutomationProperties.AutomationId="NovelReaderAppearanceButton"
                    AutomationProperties.Name="Reader Appearance"
                    Click="AppearanceButton_Click">
                <Button.Content>
                    <FontIcon Glyph="&#xE790;" />
                </Button.Content>
            </Button>

            <TextBlock Grid.Column="3"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="{x:Bind ViewModel.ReaderTitle, Mode=OneWay}" />
        </Grid>

        <Grid Grid.Row="1">
            <WebView2 x:Name="NovelWebView"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      DefaultBackgroundColor="White"
                      AutomationProperties.AutomationId="NovelWebView" />
        </Grid>
    </Grid>
</Page>
