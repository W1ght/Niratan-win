<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Hoshi.Views.Pages.NovelLibraryPage"
      x:Name="ThisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:Hoshi.Helpers.UI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:novel="using:Hoshi.Models.Novel"
      xmlns:vmc="using:Hoshi.ViewModels.Components"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate x:Key="NovelBookTemplate" x:DataType="vmc:NovelBookItemViewModel">
            <Button Width="180"
                    Padding="0"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    AutomationProperties.AutomationId="{x:Bind AutomationId, Mode=OneTime}"
                    AutomationProperties.Name="{x:Bind Book.Title, Mode=OneTime}"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="NovelBookButton_Click">
                <Button.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="NovelBookMatchSasayakiMenuItem"
                                        Text="Match Sasayaki"
                                        AutomationProperties.AutomationId="NovelBookMatchSasayakiMenuItem"
                                        Command="{Binding ViewModel.MatchSasayakiCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Delete"
                                        Command="{Binding ViewModel.DeleteNovelCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                    </MenuFlyout>
                </Button.ContextFlyout>
                <StackPanel Spacing="6">
                    <Border Height="250"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8">
                        <Grid>
                            <Image Stretch="UniformToFill"
                                   Source="{x:Bind CoverImage, Mode=OneTime}"
                                   Visibility="{x:Bind HasCover, Mode=OneTime, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <FontIcon FontSize="48"
                                      Glyph="&#xE8B9;"
                                      Opacity="0.3"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="{x:Bind HasCover, Mode=OneTime, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="4">
                        <Grid Margin="0,0,0,4"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <ProgressBar Height="4"
                                         Minimum="0"
                                         Maximum="100"
                                         VerticalAlignment="Center"
                                         Value="{x:Bind OverallProgressPercent, Mode=OneWay}" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind OverallProgressText, Mode=OneWay}" />
                        </Grid>
                        <TextBlock Text="{x:Bind Book.Title, Mode=OneTime}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </StackPanel>
                </StackPanel>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="RemoteNovelBookTemplate" x:DataType="vmc:RemoteNovelBookItemViewModel">
            <Button Width="180"
                    Padding="0"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    AutomationProperties.AutomationId="{x:Bind AutomationId, Mode=OneTime}"
                    AutomationProperties.Name="{x:Bind Book.Title, Mode=OneTime}"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding ViewModel.DownloadRemoteBookCommand, ElementName=ThisPage}"
                    CommandParameter="{x:Bind}">
                <StackPanel Spacing="6">
                    <Border Height="250"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8">
                        <Grid>
                            <FontIcon FontSize="48"
                                      Glyph="&#xEBD3;"
                                      Opacity="0.36"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="4">
                        <Grid Margin="0,0,0,4"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <ProgressBar Height="4"
                                         Minimum="0"
                                         Maximum="100"
                                         VerticalAlignment="Center"
                                         Value="{x:Bind OverallProgressPercent, Mode=OneWay}" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind OverallProgressText, Mode=OneWay}" />
                        </Grid>
                        <ProgressBar Height="3"
                                     Minimum="0"
                                     Maximum="1"
                                     Value="{x:Bind DownloadProgress, Mode=OneWay}"
                                     Visibility="{x:Bind IsDownloading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Text="{x:Bind Book.Title, Mode=OneTime}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </StackPanel>
                </StackPanel>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="StatisticsDistributionTemplate" x:DataType="novel:NovelStatisticsDistributionRow">
            <Grid Padding="0,6"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <StackPanel Spacing="2">
                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{x:Bind CharactersText, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="{x:Bind PercentText, Mode=OneWay}" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid RowDefinitions="Auto, Auto, *"
          AllowDrop="True"
          DragOver="NovelLibrary_DragOver"
          Drop="NovelLibrary_Drop">
        <Grid Grid.Row="0"
              Padding="20,14,36,16"
              ColumnDefinitions="Auto, *, Auto, Auto, Auto, Auto"
              ColumnSpacing="12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <FontIcon FontSize="24" Glyph="&#xE82D;" />
                <TextBlock Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Text="Novels" />
            </StackPanel>

            <ToggleButton Grid.Column="2"
                          x:Name="NovelLibraryStatisticsButton"
                          x:Uid="NovelLibraryStatisticsButton"
                          AutomationProperties.AutomationId="NovelLibraryStatisticsButton"
                          AutomationProperties.Name="Statistics"
                          IsChecked="{x:Bind ViewModel.ShowStatisticsDashboard, Mode=TwoWay}"
                          ToolTipService.ToolTip="Statistics">
                <FontIcon Glyph="&#xE9D2;" />
            </ToggleButton>

            <ComboBox Grid.Column="3"
                      Width="148"
                      VerticalAlignment="Center"
                      x:Uid="NovelLibrarySortComboBox"
                      AutomationProperties.AutomationId="NovelLibrarySortComboBox"
                      AutomationProperties.Name="Sort novels"
                      ItemsSource="{x:Bind ViewModel.SortOptions, Mode=OneWay}"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="Value"
                      SelectedValue="{x:Bind ViewModel.SelectedSortOption, Mode=TwoWay}"
                      ToolTipService.ToolTip="Sort novels" />

            <Button Grid.Column="4"
                    x:Uid="NovelLibraryRefreshGoogleDriveButton"
                    AutomationProperties.AutomationId="NovelLibraryRefreshGoogleDriveButton"
                    Command="{x:Bind ViewModel.RefreshRemoteBooksCommand}"
                    ToolTipService.ToolTip="Refresh Google Drive books">
                <Button.Content>
                    <FontIcon Glyph="&#xE895;" />
                </Button.Content>
            </Button>

            <Button Grid.Column="5"
                    AutomationProperties.AutomationId="ImportNovelButton"
                    Command="{x:Bind ViewModel.ImportNovelCommand}"
                    ToolTipService.ToolTip="Import EPUB">
                <Button.Content>
                    <FontIcon Glyph="&#xE8E5;" />
                </Button.Content>
            </Button>
        </Grid>

        <Border Grid.Row="1"
                Margin="20,0,36,16"
                Padding="16"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                AutomationProperties.AutomationId="NovelLibraryStatisticsDashboard"
                Visibility="{x:Bind ViewModel.ShowStatisticsDashboard, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
            <Grid ColumnDefinitions="*,*,2*"
                  ColumnSpacing="18">
                <StackPanel Spacing="6">
                    <TextBlock Text="Today"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="NovelLibraryTodayStatisticsText"
                               AutomationProperties.AutomationId="NovelLibraryTodayStatisticsText"
                               Text="{x:Bind ViewModel.StatisticsTodayText, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="6">
                    <TextBlock Text="This Week"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="NovelLibraryWeekStatisticsText"
                               AutomationProperties.AutomationId="NovelLibraryWeekStatisticsText"
                               Text="{x:Bind ViewModel.StatisticsWeekText, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Spacing="6">
                    <TextBlock Text="By Book"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ItemsControl x:Name="NovelLibraryByBookStatisticsList"
                                  AutomationProperties.AutomationId="NovelLibraryByBookStatisticsList"
                                  ItemTemplate="{StaticResource StatisticsDistributionTemplate}"
                                  ItemsSource="{x:Bind ViewModel.StatisticsDistributionRows, Mode=OneWay}" />
                </StackPanel>
            </Grid>
        </Border>

        <ProgressRing Grid.Row="2"
                      Width="60"
                      Height="60"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsActive="{x:Bind ViewModel.IsContentLoading, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsContentLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

        <TextBlock Grid.Row="2"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Style="{StaticResource BodyLargeStrongTextBlockStyle}"
                   Text="No novels imported."
                   Visibility="{x:Bind ViewModel.NoNovels, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <ItemsControl Grid.Row="0"
                          Margin="0,0,16,16"
                          Padding="20,0,0,0"
                          AutomationProperties.AutomationId="RemoteNovelBookItemsControl"
                          ItemTemplate="{StaticResource RemoteNovelBookTemplate}"
                          ItemsSource="{x:Bind ViewModel.RemoteBooks, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <GridView Grid.Row="1"
                      AutomationProperties.AutomationId="NovelBookGridView"
                      AllowDrop="True"
                      CanDragItems="True"
                      CanReorderItems="True"
                      DragItemsCompleted="NovelBookGridView_DragItemsCompleted"
                      Padding="0,0,16,0"
                      IsItemClickEnabled="True"
                      ItemClick="GridView_ItemClick"
                      ItemTemplate="{StaticResource NovelBookTemplate}"
                      ItemsSource="{x:Bind ViewModel.NovelBooks, Mode=OneWay}"
                      SelectionMode="None" />
        </Grid>
    </Grid>
</Page>
