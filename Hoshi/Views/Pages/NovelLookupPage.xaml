<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Hoshi.Views.Pages.NovelLookupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:viewModels="using:Hoshi.ViewModels.Pages"
      mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*" Padding="8,0,24,24" RowSpacing="16" Background="Transparent">
        <StackPanel Spacing="8">
            <TextBlock x:Uid="NovelLookupPageTitle"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="Lookup" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox x:Name="LookupQueryBox"
                         x:Uid="NovelLookupQueryBox"
                         AutomationProperties.AutomationId="NovelLookupQueryBox"
                         PlaceholderText="Enter Japanese or English text"
                         Text="{x:Bind ViewModel.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="LookupQueryBox_KeyDown" />
                <Button Grid.Column="1"
                        AutomationProperties.AutomationId="NovelLookupSearchButton"
                        Click="LookupButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE721;" FontSize="14" />
                        <TextBlock x:Uid="NovelLookupSearchButtonText" Text="Search" />
                    </StackPanel>
                </Button>
            </Grid>
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
        </StackPanel>

        <Border x:Name="DictionaryPanelRoot"
                Grid.Row="1"
                MinHeight="420"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
            <Canvas x:Name="DictionaryOverlayCanvas"
                    Background="Transparent" />
        </Border>
    </Grid>
</Page>
