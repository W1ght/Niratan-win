<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="Hoshi.Views.Video.VideoPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Grid x:Name="RootGrid"
          IsTabStop="True"
          RowDefinitions="*,Auto"
          Background="Black"
          AutomationProperties.AutomationId="VideoPlayerRoot">
        <Grid.Resources>
            <Style x:Key="VideoTransportButtonStyle" TargetType="AppBarButton">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="40" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="LabelPosition" Value="Collapsed" />
            </Style>
            <Style x:Key="VideoPrimaryTransportButtonStyle"
                   TargetType="AppBarButton"
                   BasedOn="{StaticResource VideoTransportButtonStyle}">
                <Setter Property="Width" Value="48" />
                <Setter Property="Height" Value="48" />
            </Style>
        </Grid.Resources>

        <Grid x:Name="VideoSurface"
              Grid.Row="0"
              Background="Black"
              AutomationProperties.AutomationId="VideoSurface"
              PointerPressed="VideoSurface_PointerPressed" />

        <Popup x:Name="SubtitleSettingsPopup"
               Grid.RowSpan="2"
               Closed="SubtitleSettingsPopup_Closed"
               IsLightDismissEnabled="True"
               ShouldConstrainToRootBounds="True">
            <Border x:Name="SubtitleSettingsPanel"
                    Padding="14,10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid Width="360"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12">
                    <TextBlock x:Uid="VideoPlayerSubtitleSizeText"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Text="Subtitle size"
                               VerticalAlignment="Center" />
                    <Slider x:Name="SubtitleFontSizeSlider"
                            AutomationProperties.AutomationId="VideoPlayerSubtitleFontSizeSlider"
                            Grid.Column="1"
                            Value="{x:Bind ViewModel.SubtitleFontSize, Mode=OneWay}"
                            ValueChanged="SubtitleFontSizeSlider_ValueChanged" />
                    <ToggleSwitch x:Name="HardwareDecodingToggle"
                                  x:Uid="VideoPlayerHardwareDecodingToggle"
                                  AutomationProperties.AutomationId="VideoPlayerHardwareDecodingToggle"
                                  Grid.Column="2"
                                  MinWidth="0"
                                  OffContent=""
                                  OnContent=""
                                  IsOn="{x:Bind ViewModel.HardwareDecodingEnabled, Mode=OneWay}"
                                  Toggled="HardwareDecodingToggle_Toggled" />
                </Grid>
            </Border>
        </Popup>

        <Border x:Name="BottomChrome"
                Grid.Row="1"
                Padding="16,8,16,12"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="6">
                <Border
                        Height="{x:Bind ViewModel.SubtitlePanelHeight, Mode=OneWay}"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBox x:Name="SubtitleTextBox"
                             AutomationProperties.AutomationId="VideoPlayerSubtitleTextBox"
                             MinHeight="0"
                             AcceptsReturn="True"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="{x:Bind ViewModel.SubtitleFontSize, Mode=OneWay}"
                             HorizontalContentAlignment="Center"
                             IsReadOnly="True"
                             Padding="12,0"
                             Text="{x:Bind ViewModel.CurrentSubtitleText, Mode=OneWay}"
                             TextAlignment="Center"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Center" />
                </Border>

                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12">
                    <TextBlock FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ViewModel.PositionText, Mode=OneWay}"
                               VerticalAlignment="Center" />
                    <Slider x:Name="ProgressSlider"
                            x:Uid="VideoPlayerProgressSlider"
                            AutomationProperties.AutomationId="VideoPlayerProgressSlider"
                            Grid.Column="1"
                            Height="28"
                            Maximum="{x:Bind ViewModel.ProgressMaximum, Mode=OneWay}"
                            Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                            PointerPressed="ProgressSlider_PointerPressed"
                            PointerReleased="ProgressSlider_PointerReleased"
                            PointerCanceled="ProgressSlider_PointerCanceled" />
                    <TextBlock Grid.Column="2"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ViewModel.DurationText, Mode=OneWay}"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Row="2"
                      MinHeight="48"
                      ColumnDefinitions="*,Auto,*"
                      ColumnSpacing="16">
                    <TextBlock FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <AppBarButton x:Name="PreviousSubtitleButton"
                                      x:Uid="VideoPlayerPreviousSubtitleButton"
                                      AutomationProperties.AutomationId="VideoPlayerPreviousSubtitleButton"
                                      Style="{StaticResource VideoTransportButtonStyle}"
                                      Click="PreviousSubtitleButton_Click"
                                      Label="Previous">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE76B;" />
                            </AppBarButton.Icon>
                        </AppBarButton>

                        <AppBarButton x:Name="RewindButton"
                                      x:Uid="VideoPlayerRewindButton"
                                      AutomationProperties.AutomationId="VideoPlayerRewindButton"
                                      Style="{StaticResource VideoTransportButtonStyle}"
                                      Click="RewindButton_Click"
                                      Label="Back">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE892;" />
                            </AppBarButton.Icon>
                        </AppBarButton>

                        <AppBarButton x:Name="PlayPauseButton"
                                      x:Uid="VideoPlayerPlayPauseButton"
                                      AutomationProperties.AutomationId="VideoPlayerPlayPauseButton"
                                      Style="{StaticResource VideoPrimaryTransportButtonStyle}"
                                      Click="PlayPauseButton_Click"
                                      Label="Play or pause">
                            <AppBarButton.Icon>
                                <FontIcon x:Name="PlayPauseIcon" FontSize="20" Glyph="&#xE769;" />
                            </AppBarButton.Icon>
                        </AppBarButton>

                        <AppBarButton x:Name="ForwardButton"
                                      x:Uid="VideoPlayerForwardButton"
                                      AutomationProperties.AutomationId="VideoPlayerForwardButton"
                                      Style="{StaticResource VideoTransportButtonStyle}"
                                      Click="ForwardButton_Click"
                                      Label="Forward">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE893;" />
                            </AppBarButton.Icon>
                        </AppBarButton>

                        <AppBarButton x:Name="NextSubtitleButton"
                                      x:Uid="VideoPlayerNextSubtitleButton"
                                      AutomationProperties.AutomationId="VideoPlayerNextSubtitleButton"
                                      Style="{StaticResource VideoTransportButtonStyle}"
                                      Click="NextSubtitleButton_Click"
                                      Label="Next">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE76C;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Grid Width="132"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="8"
                              VerticalAlignment="Center">
                            <FontIcon FontSize="16"
                                      Glyph="&#xE767;"
                                      VerticalAlignment="Center" />
                            <Slider x:Name="VolumeSlider"
                                    x:Uid="VideoPlayerVolumeSlider"
                                    AutomationProperties.AutomationId="VideoPlayerVolumeSlider"
                                    Grid.Column="1"
                                    Width="96"
                                    Value="{x:Bind ViewModel.Volume, Mode=OneWay}"
                                    ValueChanged="VolumeSlider_ValueChanged" />
                        </Grid>

                        <AppBarButton x:Name="SubtitleStyleButton"
                                      x:Uid="VideoPlayerSubtitleStyleButton"
                                      AutomationProperties.AutomationId="VideoPlayerSubtitleStyleButton"
                                      Style="{StaticResource VideoTransportButtonStyle}"
                                      Click="SubtitleStyleButton_Click"
                                      Label="Subtitles">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE8D2;" />
                            </AppBarButton.Icon>
                        </AppBarButton>

                        <AppBarButton x:Name="FullScreenButton"
                                      x:Uid="VideoPlayerFullScreenButton"
                                      AutomationProperties.AutomationId="VideoPlayerFullScreenButton"
                                      Style="{StaticResource VideoTransportButtonStyle}"
                                      Click="FullScreenButton_Click"
                                      Label="Full screen">
                            <AppBarButton.Icon>
                                <FontIcon x:Name="FullScreenIcon" Glyph="&#xE740;" />
                            </AppBarButton.Icon>
                        </AppBarButton>

                        <AppBarButton x:Name="LookupButton"
                                      x:Uid="VideoPlayerLookupButton"
                                      AutomationProperties.AutomationId="VideoPlayerLookupButton"
                                      Style="{StaticResource VideoTransportButtonStyle}"
                                      Click="LookupButton_Click"
                                      Label="Lookup">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE11A;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Canvas x:Name="PopupOverlayCanvas"
                Grid.RowSpan="2"
                Canvas.ZIndex="100" />
    </Grid>
</Window>
