                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8">
                                                <FontIcon FontSize="13"
                                                          Foreground="#99111111"
                                                          Glyph="&#xE8D2;"
                                                          VerticalAlignment="Center" />
                                                <TextBlock x:Uid="VideoInspectorExternalSubtitlesHeaderText"
                                                           Grid.Column="1"
                                                           Text="External Subtitles"
                                                           Style="{StaticResource VideoInspectorSectionTitleStyle}" />
                                            </Grid>
                                            <Button x:Name="OpenSubtitleButton"
                                                    x:Uid="VideoInspectorOpenSubtitleButton"
                                                    AutomationProperties.AutomationId="VideoInspectorOpenSubtitleButton"
                                                    HorizontalAlignment="Stretch"
                                                    Click="OpenSubtitleButton_Click">
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            Spacing="6">
                                                    <FontIcon Glyph="&#xE710;" />
                                                    <TextBlock x:Uid="VideoInspectorOpenSubtitleButtonText"
                                                               Text="Open Subtitles" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="ClearSubtitleButton"
                                                    x:Uid="VideoInspectorClearSubtitleButton"
                                                    AutomationProperties.AutomationId="VideoInspectorClearSubtitleButton"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    Click="ClearSubtitleButton_Click">
                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="8">
                                                    <FontIcon Glyph="&#xE73E;"
                                                              Foreground="#3F8DFF"
                                                              VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1"
                                                                Spacing="2">
                                                        <TextBlock Text="{x:Bind ViewModel.PrimarySubtitleName, Mode=OneWay}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                        <TextBlock x:Uid="VideoInspectorPrimarySubtitleText"
                                                                   Text="Primary subtitle"
                                                                   Style="{StaticResource VideoInspectorSecondaryTextStyle}" />
                                                    </StackPanel>
                                                    <FontIcon Grid.Column="2"
                                                              Glyph="&#xE711;"
                                                              Foreground="#80111111"
                                                              VerticalAlignment="Center" />
                                                </Grid>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource VideoInspectorCardStyle}">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8">
                                                <FontIcon FontSize="13"
                                                          Foreground="#99111111"
                                                          Glyph="&#xE8D2;"
                                                          VerticalAlignment="Center" />
                                                <TextBlock x:Uid="VideoInspectorSubtitleTrackHeaderText"
                                                           Grid.Column="1"
                                                           Text="Subtitle Track"
                                                           Style="{StaticResource VideoInspectorSectionTitleStyle}" />
                                            </Grid>
                                            <Button x:Name="SubtitleTrackOffButton"
                                                    AutomationProperties.AutomationId="VideoInspectorSubtitleTrackOffButton"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    Click="SubtitleTrackOffButton_Click">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <FontIcon x:Name="SubtitleTrackOffIcon"
                                                              Glyph="&#xE73E;"
                                                              Foreground="#80111111"
                                                              VerticalAlignment="Center" />
                                                    <TextBlock x:Uid="VideoInspectorOffText"
                                                               Grid.Column="1"
                                                               Margin="8,0,0,0"
                                                               Text="Off"
                                                               Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                </Grid>
                                            </Button>
                                            <ListView x:Name="SubtitleTrackListView"
                                                      AutomationProperties.AutomationId="VideoInspectorSubtitleTrackList"
                                                      ItemsSource="{x:Bind ViewModel.SubtitleTracks, Mode=OneWay}"
                                                      SelectionMode="Single"
                                                      SelectionChanged="SubtitleTrackListView_SelectionChanged">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:VideoTrackInfo">
                                                        <Grid ColumnDefinitions="Auto,*"
                                                              ColumnSpacing="8"
                                                              Padding="8,6">
                                                            <FontIcon Glyph="&#xE8D2;"
                                                                      Foreground="#3F8DFF"
                                                                      VerticalAlignment="Center" />
                                                            <StackPanel Grid.Column="1"
                                                                        Spacing="2">
                                                                <TextBlock Text="{x:Bind DisplayName}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                                <TextBlock Text="{x:Bind Description}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Style="{StaticResource VideoInspectorSecondaryTextStyle}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                            <TextBlock x:Name="SubtitleNoTracksText"
                                                       x:Uid="VideoInspectorNoTracksText"
                                                       Text="No tracks"
                                                       Style="{StaticResource VideoInspectorSecondaryTextStyle}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource VideoInspectorCardStyle}">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  ColumnSpacing="8">
                                                <FontIcon FontSize="13"
                                                          Foreground="#99111111"
                                                          Glyph="&#xE823;"
                                                          VerticalAlignment="Center" />
                                                <TextBlock x:Uid="VideoInspectorSubtitleTimingHeaderText"
                                                           Grid.Column="1"
                                                           Text="Subtitle Timing"
                                                           Style="{StaticResource VideoInspectorSectionTitleStyle}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{x:Bind ViewModel.SubtitleDelayText, Mode=OneWay}"
                                                           Style="{StaticResource VideoInspectorValueTextStyle}" />
                                            </Grid>
                                            <TextBlock x:Uid="VideoInspectorSubtitleTimingDescriptionText"
                                                       Text="Positive values delay subtitles; negative values show subtitles earlier."
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource VideoInspectorSecondaryTextStyle}" />
                                            <Slider x:Name="SubtitleDelaySlider"
                                                    AutomationProperties.AutomationId="VideoInspectorSubtitleDelaySlider"
                                                    Minimum="-10000"
                                                    Maximum="10000"
                                                    StepFrequency="50"
                                                    Value="{x:Bind ViewModel.SubtitleDelayMilliseconds, Mode=OneWay}"
                                                    ValueChanged="SubtitleDelaySlider_ValueChanged" />
                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                                  ColumnSpacing="8">
                                                <Button Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        Click="SubtitleDelayBackLargeButton_Click">
                                                    <FontIcon FontSize="12" Glyph="&#xE892;" />
                                                </Button>
                                                <Button Grid.Column="1"
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        Click="SubtitleDelayBackSmallButton_Click">
                                                    <FontIcon FontSize="12" Glyph="&#xE76B;" />
                                                </Button>
                                                <TextBlock Grid.Column="2"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Text="{x:Bind ViewModel.SubtitleDelayText, Mode=OneWay}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="#E6111111" />
                                                <Button Grid.Column="3"
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        Click="SubtitleDelayForwardSmallButton_Click">
                                                    <FontIcon FontSize="12" Glyph="&#xE76C;" />
                                                </Button>
                                                <Button Grid.Column="4"
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        Click="SubtitleDelayForwardLargeButton_Click">
                                                    <FontIcon FontSize="12" Glyph="&#xE893;" />
                                                </Button>
                                            </Grid>
                                            <Grid RowDefinitions="Auto,Auto"
                                                  RowSpacing="6">
                                                <TextBlock x:Uid="VideoInspectorSubtitleOffsetText"
                                                           Text="Offset (ms)"
                                                           Foreground="#3F8DFF"
                                                           FontSize="12"
                                                           FontWeight="SemiBold" />
                                                <NumberBox x:Name="SubtitleDelayNumberBox"
                                                           AutomationProperties.AutomationId="VideoInspectorSubtitleDelayNumberBox"
                                                           Grid.Row="1"
                                                           Minimum="-10000"
                                                           Maximum="10000"
                                                           SmallChange="50"
                                                           SpinButtonPlacementMode="Compact"
                                                           Value="{x:Bind ViewModel.SubtitleDelayMilliseconds, Mode=OneWay}"
                                                           ValueChanged="SubtitleDelayNumberBox_ValueChanged" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource VideoInspectorCardStyle}">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8">
                                                <FontIcon FontSize="13"
                                                          Foreground="#99111111"
                                                          Glyph="&#xE8D3;"
                                                          VerticalAlignment="Center" />
                                                <TextBlock x:Uid="VideoInspectorSubtitleAppearanceHeaderText"
                                                           Grid.Column="1"
                                                           Text="Subtitle Appearance"
                                                           Style="{StaticResource VideoInspectorSectionTitleStyle}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <TextBlock x:Uid="VideoInspectorSubtitleFontText"
                                                           Text="Subtitle Font"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                <ComboBox x:Name="SubtitleFontFamilyComboBox"
                                                          AutomationProperties.AutomationId="VideoInspectorSubtitleFontFamilyComboBox"
                                                          Grid.Column="1"
                                                          HorizontalAlignment="Stretch"
                                                          DisplayMemberPath="Name"
                                                          ItemsSource="{x:Bind ViewModel.AvailableSubtitleFonts}"
                                                          SelectedValuePath="SubtitleFontFamily"
                                                          SelectedValue="{x:Bind ViewModel.SubtitleFontFamily, Mode=TwoWay}"
                                                          SelectionChanged="SubtitleFontFamilyComboBox_SelectionChanged" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <TextBlock x:Uid="VideoPlayerSubtitleSizeText"
                                                           Text="Subtitle size"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind ViewModel.SubtitleFontSizeText, Mode=OneWay}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource VideoInspectorValueTextStyle}" />
                                            </Grid>
                                            <Slider x:Name="SubtitleFontSizeSlider"
                                                    AutomationProperties.AutomationId="VideoPlayerSubtitleFontSizeSlider"
                                                    Minimum="12"
                                                    Maximum="72"
                                                    StepFrequency="1"
                                                    Value="{x:Bind ViewModel.SubtitleFontSize, Mode=OneWay}"
                                                    ValueChanged="SubtitleFontSizeSlider_ValueChanged" />
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <TextBlock x:Uid="VideoInspectorSubtitleWeightText"
                                                           Text="Subtitle Weight"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                <NumberBox x:Name="SubtitleFontWeightNumberBox"
                                                           AutomationProperties.AutomationId="VideoInspectorSubtitleFontWeightNumberBox"
                                                           Grid.Column="1"
                                                           Minimum="100"
                                                           Maximum="900"
                                                           SmallChange="100"
                                                           SpinButtonPlacementMode="Compact"
                                                           Value="{x:Bind ViewModel.SubtitleFontWeight, Mode=OneWay}"
                                                           ValueChanged="SubtitleFontWeightNumberBox_ValueChanged" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <TextBlock x:Uid="VideoInspectorSubtitleShadowText"
                                                           Text="Shadow"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind ViewModel.SubtitleShadowRadiusText, Mode=OneWay}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource VideoInspectorValueTextStyle}" />
                                            </Grid>
                                            <Slider x:Name="SubtitleShadowRadiusSlider"
                                                    AutomationProperties.AutomationId="VideoInspectorSubtitleShadowSlider"
                                                    Minimum="0"
                                                    Maximum="10"
                                                    StepFrequency="0.5"
                                                    Value="{x:Bind ViewModel.SubtitleShadowRadius, Mode=OneWay}"
                                                    ValueChanged="SubtitleShadowRadiusSlider_ValueChanged" />
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <TextBlock x:Uid="VideoInspectorVerticalPositionText"
                                                           Text="Vertical Position"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  ColumnSpacing="10">
                                                <Grid Width="24" Height="18">
                                                    <Border BorderBrush="#99111111"
                                                            BorderThickness="1"
                                                            CornerRadius="2" />
                                                    <Border Height="4"
                                                            Margin="3"
                                                            VerticalAlignment="Top"
                                                            Background="#FF0F6CBD"
                                                            CornerRadius="1" />
                                                </Grid>
                                                <Slider x:Name="SubtitleVerticalPositionSlider"
                                                        Grid.Column="1"
                                                        AutomationProperties.AutomationId="VideoInspectorSubtitleVerticalPositionSlider"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        StepFrequency="0.01"
                                                        Value="{x:Bind ViewModel.SubtitleVerticalPosition, Mode=OneWay}"
                                                        ValueChanged="SubtitleVerticalPositionSlider_ValueChanged" />
                                                <Grid Grid.Column="2" Width="24" Height="18">
                                                    <Border BorderBrush="#99111111"
                                                            BorderThickness="1"
                                                            CornerRadius="2" />
                                                    <Border Height="4"
                                                            Margin="3"
                                                            VerticalAlignment="Bottom"
                                                            Background="#FF0F6CBD"
                                                            CornerRadius="1" />
                                                </Grid>
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <TextBlock x:Uid="VideoInspectorSubtitleColorText"
                                                           Text="Subtitle Color"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                <controls:CompactColorPicker x:Name="SubtitleColorPicker"
                                                                             AutomationProperties.AutomationId="VideoInspectorSubtitleColorPicker"
                                                                             Grid.Column="1"
                                                                             FlyoutPlacement="LeftEdgeAlignedBottom"
                                                                             IsAlphaEnabled="True"
                                                                             ColorChanged="SubtitleColorPicker_ColorChanged" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <TextBlock x:Uid="VideoInspectorLookupHighlightColorText"
                                                           Text="Lookup Highlight Color"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                <controls:CompactColorPicker x:Name="SubtitleLookupHighlightColorPicker"
                                                                             AutomationProperties.AutomationId="VideoInspectorLookupHighlightColorPicker"
                                                                             Grid.Column="1"
                                                                             FlyoutPlacement="LeftEdgeAlignedBottom"
                                                                             IsAlphaEnabled="True"
                                                                             ColorChanged="SubtitleColorPicker_ColorChanged" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <TextBlock x:Uid="VideoInspectorLookupHighlightTextColorText"
                                                           Text="Lookup Highlight Text Color"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                <controls:CompactColorPicker x:Name="SubtitleLookupHighlightTextColorPicker"
                                                                             AutomationProperties.AutomationId="VideoInspectorLookupHighlightTextColorPicker"
                                                                             Grid.Column="1"
                                                                             FlyoutPlacement="LeftEdgeAlignedBottom"
                                                                             IsAlphaEnabled="True"
                                                                             ColorChanged="SubtitleColorPicker_ColorChanged" />
                                            </Grid>
                                            <Button x:Uid="VideoInspectorRestoreDefaultsButton"
                                                    Content="Restore Defaults"
                                                    HorizontalAlignment="Stretch"
                                                    Click="RestoreSubtitleDefaultsButton_Click" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource VideoInspectorCardStyle}">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8">
                                                <FontIcon FontSize="13"
                                                          Foreground="#99111111"
                                                          Glyph="&#xED1A;"
                                                          VerticalAlignment="Center" />
                                                <TextBlock x:Uid="VideoInspectorSubtitleMaskHeaderText"
                                                           Grid.Column="1"
                                                           Text="Subtitle Mask"
                                                           Style="{StaticResource VideoInspectorSectionTitleStyle}" />
                                            </Grid>
                                            <ToggleSwitch x:Name="SubtitleMaskToggle"
                                                          x:Uid="VideoInspectorSubtitleMaskToggle"
                                                          AutomationProperties.AutomationId="VideoInspectorSubtitleMaskToggle"
                                                          MinWidth="0"
                                                          OffContent=""
                                                          OnContent=""
                                                          IsOn="{x:Bind ViewModel.SubtitleMaskEnabled, Mode=OneWay}"
                                                          Toggled="SubtitleMaskToggle_Toggled" />
                                            <Grid ColumnDefinitions="*,*"
                                                  ColumnSpacing="6">
                                                <ToggleButton x:Name="SubtitleMaskBlurModeButton"
                                                              x:Uid="VideoInspectorMaskBlurModeButton"
                                                              AutomationProperties.AutomationId="VideoInspectorMaskBlurModeButton"
                                                              Content="Blur"
                                                              HorizontalAlignment="Stretch"
                                                              IsChecked="True"
                                                              Click="SubtitleMaskModeButton_Click" />
                                                <ToggleButton x:Name="SubtitleMaskTransparentModeButton"
                                                              x:Uid="VideoInspectorMaskTransparentModeButton"
                                                              AutomationProperties.AutomationId="VideoInspectorMaskTransparentModeButton"
                                                              Grid.Column="1"
                                                              Content="Transparent"
                                                              HorizontalAlignment="Stretch"
                                                              Click="SubtitleMaskModeButton_Click" />
                                            </Grid>
                                            <StackPanel x:Name="SubtitleMaskBlurPanel"
                                                        Spacing="8">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="12">
                                                    <TextBlock x:Uid="VideoInspectorBlurRadiusText"
                                                               Text="Blur Radius"
                                                               VerticalAlignment="Center"
                                                               Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{x:Bind ViewModel.SubtitleMaskBlurRadiusText, Mode=OneWay}"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               Style="{StaticResource VideoInspectorValueTextStyle}" />
                                                </Grid>
                                                <Slider x:Name="SubtitleMaskBlurRadiusSlider"
                                                        AutomationProperties.AutomationId="VideoInspectorSubtitleMaskBlurRadiusSlider"
                                                        Minimum="0"
                                                        Maximum="20"
                                                        StepFrequency="1"
                                                        Value="{x:Bind ViewModel.SubtitleMaskBlurRadius, Mode=OneWay}"
                                                        ValueChanged="SubtitleMaskBlurRadiusSlider_ValueChanged" />
                                            </StackPanel>
                                            <StackPanel x:Name="SubtitleMaskHiddenOpacityPanel"
                                                        Spacing="8"
                                                        Visibility="Collapsed">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="12">
                                                    <TextBlock x:Uid="VideoInspectorHiddenOpacityText"
                                                               Text="Hidden Opacity"
                                                               VerticalAlignment="Center"
                                                               Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{x:Bind ViewModel.SubtitleMaskHiddenOpacityText, Mode=OneWay}"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               Style="{StaticResource VideoInspectorValueTextStyle}" />
                                                </Grid>
                                                <Slider x:Name="SubtitleMaskHiddenOpacitySlider"
                                                        AutomationProperties.AutomationId="VideoInspectorSubtitleMaskHiddenOpacitySlider"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        StepFrequency="0.05"
                                                        Value="{x:Bind ViewModel.SubtitleMaskHiddenOpacity, Mode=OneWay}"
                                                        ValueChanged="SubtitleMaskHiddenOpacitySlider_ValueChanged" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource VideoInspectorCardStyle}">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8">
                                                <FontIcon FontSize="13"
                                                          Foreground="#99111111"
                                                          Glyph="&#xE8C1;"
                                                          VerticalAlignment="Center" />
                                                <TextBlock x:Uid="VideoInspectorTranscriptHeaderText"
                                                           Grid.Column="1"
                                                           Text="Transcript"
                                                           Style="{StaticResource VideoInspectorSectionTitleStyle}" />
                                            </Grid>
                                            <Button x:Name="OpenTranscriptButton"
                                                    x:Uid="VideoInspectorOpenTranscriptButton"
                                                    Content="Open Transcript"
                                                    IsEnabled="{x:Bind ViewModel.HasTranscriptRows, Mode=OneWay}"
                                                    HorizontalAlignment="Stretch"
                                                    Click="OpenTranscriptButton_Click" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <video:VideoTranscriptListControl x:Name="InspectorSubtitleListContent"
                                                          Visibility="Collapsed" />
                    </Grid>
                </Grid>
                </Border>
    </Grid>
</Window>
