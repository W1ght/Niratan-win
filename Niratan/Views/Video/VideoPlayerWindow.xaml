<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="Niratan.Views.Video.VideoPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Niratan.Views.Controls"
        xmlns:models="using:Niratan.Models"
        xmlns:video="using:Niratan.Views.Video"
        xmlns:win2d="using:Microsoft.Graphics.Canvas.UI.Xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Grid x:Name="RootGrid"
          IsTabStop="True"
          Background="Black"
          AutomationProperties.AutomationId="VideoPlayerRoot">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.Resources>
            <Style x:Key="VideoTransportButtonStyle" TargetType="AppBarButton">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="40" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="LabelPosition" Value="Collapsed" />
                <Setter Property="Foreground" Value="#E6FFFFFF" />
            </Style>
            <Style x:Key="VideoPrimaryTransportButtonStyle"
                   TargetType="AppBarButton"
                   BasedOn="{StaticResource VideoTransportButtonStyle}" />
            <Style x:Key="VideoInspectorTabButtonStyle" TargetType="ToggleButton">
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="#CC111111" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
            </Style>
            <Style x:Key="VideoInspectorCardStyle" TargetType="Border">
                <Setter Property="Padding" Value="12" />
                <Setter Property="Background" Value="#DDFFFFFF" />
                <Setter Property="BorderBrush" Value="#44FFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="16" />
            </Style>
            <Style x:Key="VideoInspectorSectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#99111111" />
            </Style>
            <Style x:Key="VideoInspectorPrimaryTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="#D9111111" />
            </Style>
            <Style x:Key="VideoInspectorSecondaryTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="#80111111" />
            </Style>
            <Style x:Key="VideoInspectorValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#AA111111" />
            </Style>
        </Grid.Resources>

        <Grid x:Name="VideoSurface"
              Grid.Column="0"
              Background="Black"
              AutomationProperties.AutomationId="VideoSurface"
              PointerPressed="VideoSurface_PointerPressed" />

        <Popup x:Name="BottomChromePopup"
               Grid.Column="0"
               IsLightDismissEnabled="False"
               ShouldConstrainToRootBounds="False">
            <Grid x:Name="BottomChromePopupRoot"
                  Background="Transparent"
                  PointerPressed="BottomChromePopupRoot_PointerPressed"
                  PointerMoved="BottomChromePopupRoot_PointerMoved"
                  PointerExited="BottomChromePopupRoot_PointerExited"
                  PointerWheelChanged="BottomChromePopupRoot_PointerWheelChanged"
                  DoubleTapped="BottomChromePopupRoot_DoubleTapped">
                <Border x:Name="VideoDictionaryPanelChrome"
                        Canvas.ZIndex="100"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Margin="16,16,16,120"
                        BorderThickness="0"
                        Visibility="Collapsed">
                    <Canvas x:Name="PopupOverlayCanvas"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent"
                            SizeChanged="PopupOverlayCanvas_SizeChanged" />
                </Border>

                <Border x:Name="SubtitlePanelBorder"
                        Canvas.ZIndex="20"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Stretch"
                        Margin="16,0,16,0"
                        Height="{x:Bind ViewModel.SubtitlePanelHeight, Mode=OneWay}"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        SizeChanged="SubtitlePanelBorder_SizeChanged"
                        PointerEntered="SubtitlePanelBorder_PointerEntered"
                        PointerExited="SubtitlePanelBorder_PointerExited">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="SubtitlePanelTransform" />
                    </Border.RenderTransform>
                    <Grid Background="Transparent">
                        <WebView2 x:Name="SubtitleWebView"
                                  AutomationProperties.AutomationId="VideoPlayerSubtitleWebView"
                                  Canvas.ZIndex="0"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  IsHitTestVisible="False"
                                  Opacity="0" />
                        <win2d:CanvasControl x:Name="SubtitleCanvas"
                                             AutomationProperties.AutomationId="VideoPlayerVisibleSubtitleText"
                                             Canvas.ZIndex="1"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Stretch"
                                             IsHitTestVisible="True"
                                             Draw="SubtitleCanvas_Draw"
                                             PointerPressed="SubtitleCanvas_PointerPressed"
                                             PointerMoved="SubtitleCanvas_PointerMoved" />
                    </Grid>
                </Border>

                <Border x:Name="BottomChrome"
                        Canvas.ZIndex="30"
                        VerticalAlignment="Bottom"
                        MinHeight="104"
                        Padding="16,6,16,10"
                        Background="#B3121212"
                        BorderBrush="#24FFFFFF"
                        BorderThickness="0,1,0,0">
                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="4">
                        <Grid Grid.Row="0"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">
                            <TextBlock FontSize="12"
                                       Foreground="#C9FFFFFF"
                                       Text="{x:Bind ViewModel.PositionText, Mode=OneWay}"
                                       VerticalAlignment="Center" />
                            <Slider x:Name="ProgressSlider"
                                    x:Uid="VideoPlayerProgressSlider"
                                    AutomationProperties.AutomationId="VideoPlayerProgressSlider"
                                    Grid.Column="1"
                                    Height="28"
                                    Maximum="{x:Bind ViewModel.ProgressMaximum, Mode=OneWay}"
                                    Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}" />
                            <TextBlock Grid.Column="2"
                                       FontSize="12"
                                       Foreground="#C9FFFFFF"
                                       Text="{x:Bind ViewModel.DurationText, Mode=OneWay}"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <Grid Grid.Row="1"
                              MinHeight="48"
                              ColumnDefinitions="*,Auto,*"
                              ColumnSpacing="16">
                            <TextBlock FontSize="12"
                                       Foreground="#99FFFFFF"
                                       Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <AppBarButton x:Name="PreviousSubtitleButton"
                                              x:Uid="VideoPlayerPreviousSubtitleButton"
                                              AutomationProperties.AutomationId="VideoPlayerPreviousSubtitleButton"
                                              Style="{StaticResource VideoTransportButtonStyle}"
                                              Click="PreviousSubtitleButton_Click"
                                              Label="Previous">
                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE76B;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>

                                <AppBarButton x:Name="RewindButton"
                                              x:Uid="VideoPlayerRewindButton"
                                              AutomationProperties.AutomationId="VideoPlayerRewindButton"
                                              Style="{StaticResource VideoTransportButtonStyle}"
                                              Click="RewindButton_Click"
                                              Label="Back">
                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE892;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>

                                <AppBarButton x:Name="PlayPauseButton"
                                              x:Uid="VideoPlayerPlayPauseButton"
                                              AutomationProperties.AutomationId="VideoPlayerPlayPauseButton"
                                              Style="{StaticResource VideoPrimaryTransportButtonStyle}"
                                              Click="PlayPauseButton_Click"
                                              Label="Play or pause">
                                    <AppBarButton.Icon>
                                        <FontIcon x:Name="PlayPauseIcon" FontSize="20" Glyph="&#xE769;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>

                                <AppBarButton x:Name="ForwardButton"
                                              x:Uid="VideoPlayerForwardButton"
                                              AutomationProperties.AutomationId="VideoPlayerForwardButton"
                                              Style="{StaticResource VideoTransportButtonStyle}"
                                              Click="ForwardButton_Click"
                                              Label="Forward">
                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE893;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>

                                <AppBarButton x:Name="NextSubtitleButton"
                                              x:Uid="VideoPlayerNextSubtitleButton"
                                              AutomationProperties.AutomationId="VideoPlayerNextSubtitleButton"
                                              Style="{StaticResource VideoTransportButtonStyle}"
                                              Click="NextSubtitleButton_Click"
                                              Label="Next">
                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE76C;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="10"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Grid Width="132"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8"
                                      VerticalAlignment="Center">
                                    <FontIcon FontSize="16"
                                              Foreground="#E6FFFFFF"
                                              Glyph="&#xE767;"
                                              VerticalAlignment="Center" />
                                    <Slider x:Name="VolumeSlider"
                                            x:Uid="VideoPlayerVolumeSlider"
                                            AutomationProperties.AutomationId="VideoPlayerVolumeSlider"
                                            Grid.Column="1"
                                            Width="96"
                                            Value="{x:Bind ViewModel.Volume, Mode=OneWay}"
                                            ValueChanged="VolumeSlider_ValueChanged" />
                                </Grid>

                                <AppBarButton x:Name="InspectorButton"
                                              x:Uid="VideoPlayerInspectorButton"
                                              AutomationProperties.AutomationId="VideoPlayerInspectorButton"
                                              Style="{StaticResource VideoTransportButtonStyle}"
                                              Click="InspectorButton_Click"
                                              Label="Inspector">
                                    <AppBarButton.Icon>
                                        <FontIcon Glyph="&#xE8A0;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>

                                <AppBarButton x:Name="FullScreenButton"
                                              x:Uid="VideoPlayerFullScreenButton"
                                              AutomationProperties.AutomationId="VideoPlayerFullScreenButton"
                                              Style="{StaticResource VideoTransportButtonStyle}"
                                              Click="FullScreenButton_Click"
                                              Label="Full screen">
                                    <AppBarButton.Icon>
                                        <FontIcon x:Name="FullScreenIcon" Glyph="&#xE740;" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid x:Name="VideoModalOverlayHost"
                      AutomationProperties.AutomationId="VideoModalOverlayHost"
                      Canvas.ZIndex="1000"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />

            </Grid>
        </Popup>

        <Thumb x:Name="InspectorResizeThumb"
               Grid.Column="1"
               Width="24"
               Margin="-12,0,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Stretch"
               AutomationProperties.AutomationId="VideoInspectorResizeThumb"
               Canvas.ZIndex="10"
               DragDelta="InspectorResizeThumb_DragDelta"
               Visibility="{Binding Visibility, ElementName=InspectorPanel}">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Grid Background="Transparent">
                        <Border Width="2"
                                HorizontalAlignment="Center"
                                Background="#33111111"
                                CornerRadius="1" />
                    </Grid>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <Border x:Name="InspectorPanel"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Width="380"
                        MinWidth="320"
                        MaxWidth="720"
                        Visibility="Collapsed"
                        Padding="12,20,16,20"
                        RequestedTheme="Light"
                        Background="#E8F2F2F2"
                        BorderBrush="#66FFFFFF"
                        BorderThickness="1,0,0,0"
                        AutomationProperties.AutomationId="VideoInspectorRightDockPanel">
                    <Grid RowDefinitions="Auto,Auto,Auto,*"
                          RowSpacing="12">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10">
                            <FontIcon FontSize="14"
                                      Foreground="#CC111111"
                                      Glyph="&#xE8A0;"
                                      VerticalAlignment="Center" />
                            <TextBlock x:Uid="VideoInspectorTitleText"
                                       Grid.Column="1"
                                       Text="视频面板"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#E6111111"
                                       VerticalAlignment="Center" />
                            <Button x:Name="InspectorCloseButton"
                                    x:Uid="VideoInspectorCloseButton"
                                    AutomationProperties.AutomationId="VideoInspectorCloseButton"
                                    Grid.Column="2"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    Foreground="#CC111111"
                                    Click="InspectorCloseButton_Click">
                                <FontIcon FontSize="11"
                                          Glyph="&#xE711;" />
                            </Button>
                        </Grid>

                        <Border Grid.Row="1"
                                Padding="3"
                                Background="Transparent"
                                BorderThickness="0">
                            <Grid ColumnDefinitions="*,*,*">
                                <ToggleButton x:Name="InspectorMiningHistoryTabButton"
                                              AutomationProperties.AutomationId="VideoInspectorMiningHistoryTabButton"
                                              Style="{StaticResource VideoInspectorTabButtonStyle}"
                                              Checked="InspectorMiningHistoryTabButton_Checked"
                                              Unchecked="InspectorTabButton_Unchecked">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="5"
                                                HorizontalAlignment="Center">
                                        <FontIcon FontSize="12" Glyph="&#xE8F1;" />
                                        <TextBlock x:Uid="VideoInspectorMiningHistoryTabText" Text="挖卡历史" />
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton x:Name="InspectorSubtitleListTabButton"
                                              AutomationProperties.AutomationId="VideoInspectorSubtitleListTabButton"
                                              Grid.Column="1"
                                              Style="{StaticResource VideoInspectorTabButtonStyle}"
                                              Checked="InspectorSubtitleListTabButton_Checked"
                                              Unchecked="InspectorTabButton_Unchecked">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="5"
                                                HorizontalAlignment="Center">
                                        <FontIcon FontSize="12" Glyph="&#xE8C1;" />
                                        <TextBlock x:Uid="VideoInspectorTranscriptTabText" Text="字幕列表" />
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton x:Name="InspectorChaptersTabButton"
                                              AutomationProperties.AutomationId="VideoInspectorChaptersTabButton"
                                              Grid.Column="2"
                                              Style="{StaticResource VideoInspectorTabButtonStyle}"
                                              Checked="InspectorChaptersTabButton_Checked"
                                              Unchecked="InspectorTabButton_Unchecked">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="5"
                                                HorizontalAlignment="Center">
                                        <FontIcon FontSize="12" Glyph="&#xE8FD;" />
                                        <TextBlock x:Uid="VideoInspectorChaptersTabText" Text="章节" />
                                    </StackPanel>
                                </ToggleButton>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Padding="3"
                                Background="Transparent"
                                BorderThickness="0">
                            <Grid ColumnDefinitions="*,*,*">
                                <ToggleButton x:Name="InspectorVideoTabButton"
                                              AutomationProperties.AutomationId="VideoInspectorVideoTabButton"
                                              Style="{StaticResource VideoInspectorTabButtonStyle}"
                                              Checked="InspectorVideoTabButton_Checked"
                                              Unchecked="InspectorTabButton_Unchecked">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="5"
                                                HorizontalAlignment="Center">
                                        <FontIcon FontSize="12" Glyph="&#xE714;" />
                                        <TextBlock x:Uid="VideoInspectorVideoTabText" Text="Video" />
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton x:Name="InspectorAudioTabButton"
                                              AutomationProperties.AutomationId="VideoInspectorAudioTabButton"
                                              Grid.Column="1"
                                              Style="{StaticResource VideoInspectorTabButtonStyle}"
                                              Checked="InspectorAudioTabButton_Checked"
                                              Unchecked="InspectorTabButton_Unchecked">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="5"
                                                HorizontalAlignment="Center">
                                        <FontIcon FontSize="12" Glyph="&#xE767;" />
                                        <TextBlock x:Uid="VideoInspectorAudioTabText" Text="Audio" />
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton x:Name="InspectorSubtitlesTabButton"
                                              AutomationProperties.AutomationId="VideoInspectorSubtitlesTabButton"
                                              Grid.Column="2"
                                              Style="{StaticResource VideoInspectorTabButtonStyle}"
                                              Checked="InspectorSubtitlesTabButton_Checked"
                                              Unchecked="InspectorTabButton_Unchecked">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="5"
                                                HorizontalAlignment="Center">
                                        <FontIcon FontSize="12" Glyph="&#xE8D2;" />
                                        <TextBlock x:Uid="VideoInspectorSubtitlesTabText" Text="Subtitles" />
                                    </StackPanel>
                                </ToggleButton>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3">
                        <ScrollViewer x:Name="InspectorScrollableContent"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,4,0">
                            <Grid>
                                <StackPanel x:Name="InspectorMiningHistoryContent"
                                            Spacing="12"
                                            Visibility="Collapsed">
                                    <Border Style="{StaticResource VideoInspectorCardStyle}">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8">
                                                <FontIcon FontSize="13"
                                                          Foreground="#99111111"
                                                          Glyph="&#xE8F1;"
                                                          VerticalAlignment="Center" />
                                                <TextBlock x:Uid="VideoInspectorMiningHistoryHeaderText"
                                                           Grid.Column="1"
                                                           Text="挖卡历史"
                                                           Style="{StaticResource VideoInspectorSectionTitleStyle}" />
                                            </Grid>
                                             <TextBlock x:Uid="VideoInspectorMiningHistoryEmptyText"
                                                       x:Name="MiningHistoryEmptyText"
                                                       Text="暂无挖卡历史。保存当前字幕后会显示在这里。"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource VideoInspectorSecondaryTextStyle}" />
                                             <Button x:Name="RecordMiningHistoryButton"
                                                     Content="保存字幕"
                                                     IsEnabled="{x:Bind ViewModel.HasCurrentSubtitle, Mode=OneWay}"
                                                     HorizontalAlignment="Stretch"
                                                     Click="RecordMiningHistoryButton_Click" />
                                             <ListView x:Name="MiningHistoryListView"
                                                       AutomationProperties.AutomationId="VideoInspectorMiningHistoryList"
                                                       ItemsSource="{x:Bind ViewModel.MiningHistoryRows, Mode=OneWay}"
                                                       IsItemClickEnabled="True"
                                                       ItemClick="MiningHistoryListView_ItemClick"
                                                       SelectionMode="None"
                                                       Visibility="Collapsed">
                                                 <ListView.ItemContainerStyle>
                                                     <Style TargetType="ListViewItem">
                                                         <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                         <Setter Property="Padding" Value="0" />
                                                         <Setter Property="Margin" Value="0,2" />
                                                         <Setter Property="MinHeight" Value="0" />
                                                     </Style>
                                                 </ListView.ItemContainerStyle>
                                                 <ListView.ItemTemplate>
                                                     <DataTemplate x:DataType="models:VideoMiningHistoryRow">
                                                         <StackPanel Spacing="4"
                                                                     AutomationProperties.Name="{x:Bind AutomationName, Mode=OneWay}">
                                                             <TextBlock Text="{x:Bind SourceHeader}"
                                                                        Opacity="{x:Bind SourceHeaderOpacity, Mode=OneWay}"
                                                                        TextTrimming="CharacterEllipsis"
                                                                        Style="{StaticResource VideoInspectorSecondaryTextStyle}" />
                                                             <Grid ColumnDefinitions="*,Auto,Auto"
                                                                   ColumnSpacing="6"
                                                                   Padding="8,6">
                                                                 <StackPanel Spacing="2">
                                                                     <TextBlock Text="{x:Bind SubtitleText}"
                                                                                MaxLines="2"
                                                                                TextWrapping="Wrap"
                                                                                Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                                     <TextBlock Text="{x:Bind TimeText}"
                                                                                Style="{StaticResource VideoInspectorSecondaryTextStyle}" />
                                                                 </StackPanel>
                                                                 <Button Grid.Column="1"
                                                                         Content="&#xE8C8;"
                                                                         FontFamily="Segoe MDL2 Assets"
                                                                         Tag="{Binding}"
                                                                         Click="CopyMiningHistoryButton_Click" />
                                                                 <Button Grid.Column="2"
                                                                         Content="&#xE74D;"
                                                                         FontFamily="Segoe MDL2 Assets"
                                                                         Tag="{Binding}"
                                                                         Click="DeleteMiningHistoryButton_Click" />
                                                             </Grid>
                                                         </StackPanel>
                                                     </DataTemplate>
                                                 </ListView.ItemTemplate>
                                             </ListView>
                                             <Button x:Name="ClearMiningHistoryButton"
                                                     Content="清空挖卡历史"
                                                     HorizontalAlignment="Stretch"
                                                     Click="ClearMiningHistoryButton_Click" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="InspectorChaptersContent"
                                            Spacing="12"
                                            Visibility="Collapsed">
                                    <Border Style="{StaticResource VideoInspectorCardStyle}">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8">
                                                <FontIcon FontSize="13"
                                                          Foreground="#99111111"
                                                          Glyph="&#xE8FD;"
                                                          VerticalAlignment="Center" />
                                                <TextBlock x:Uid="VideoInspectorChaptersHeaderText"
                                                           Grid.Column="1"
                                                           Text="章节"
                                                           Style="{StaticResource VideoInspectorSectionTitleStyle}" />
                                            </Grid>
                                            <TextBlock x:Name="ChapterEmptyText"
                                                       x:Uid="VideoInspectorNoChaptersText"
                                                       Text="暂无章节"
                                                       Style="{StaticResource VideoInspectorSecondaryTextStyle}"
                                                       Visibility="Collapsed" />
                                            <ListView x:Name="ChapterListView"
                                                      AutomationProperties.AutomationId="VideoInspectorChapterList"
                                                      ItemsSource="{x:Bind ViewModel.ChapterRows, Mode=OneWay}"
                                                      IsItemClickEnabled="True"
                                                      ItemClick="ChapterListView_ItemClick"
                                                      SelectionMode="None"
                                                      Visibility="Collapsed">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Margin" Value="0,2" />
                                                        <Setter Property="MinHeight" Value="0" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:VideoChapterRow">
                                                        <Grid AutomationProperties.Name="{x:Bind AutomationName, Mode=OneWay}"
                                                              ColumnDefinitions="4,Auto,*"
                                                              ColumnSpacing="8"
                                                              MinHeight="42"
                                                              Padding="8,7">
                                                            <Border Width="3"
                                                                    Background="#3F8DFF"
                                                                    CornerRadius="2"
                                                                    Opacity="{x:Bind CurrentIndicatorOpacity, Mode=OneWay}"
                                                                    VerticalAlignment="Stretch" />
                                                            <FontIcon Grid.Column="1"
                                                                      FontSize="15"
                                                                      Foreground="#3F8DFF"
                                                                      Glyph="&#xE714;"
                                                                      VerticalAlignment="Center" />
                                                            <StackPanel Grid.Column="2"
                                                                        Spacing="2">
                                                                <TextBlock Text="{x:Bind Title}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Style="{StaticResource VideoInspectorPrimaryTextStyle}" />
                                                                <TextBlock Text="{x:Bind StartTimeText}"
                                                                           Style="{StaticResource VideoInspectorSecondaryTextStyle}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="InspectorVideoContent"
                                            Spacing="12"
                                            Visibility="Collapsed">
                                    <Border Visibility="{x:Bind ViewModel.IsRemoteVideo, Mode=OneWay}"
                                            Style="{StaticResource VideoInspectorCardStyle}">
                                        <StackPanel Spacing="8">
                                            <TextBlock x:Uid="YouTubeQualityHeaderText"
                                                       Text="YouTube Quality"
                                                       Style="{StaticResource VideoInspectorSectionTitleStyle}" />
                                            <ComboBox x:Name="YouTubeQualityComboBox"
                                                      AutomationProperties.AutomationId="YouTubeQualityComboBox"
                                                      DisplayMemberPath="DisplayName"
                                                      ItemsSource="{x:Bind ViewModel.RemoteQualityOptions, Mode=OneWay}"
                                                      SelectedValue="{x:Bind ViewModel.SelectedRemoteQualityId, Mode=OneWay}"
                                                      SelectedValuePath="Id"
                                                      SelectionChanged="YouTubeQualityComboBox_SelectionChanged" />
                                            <TextBlock Text="Experimental · maximum 1080p"
                                                       Style="{StaticResource VideoInspectorSecondaryTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource VideoInspectorCardStyle}">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8">
                                                <FontIcon FontSize="13"
                                                          Foreground="#99111111"
                                                          Glyph="&#xE945;"
                                                          VerticalAlignment="Center" />
                                                <TextBlock x:Uid="VideoInspectorPlaybackSpeedHeaderText"
                                                           Grid.Column="1"
                                                           Text="Playback Speed"
                                                           Style="{StaticResource VideoInspectorSectionTitleStyle}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,*,*,*"
                                                  ColumnSpacing="6">
                                                <Button Content="0.25x"
                                                        Tag="0.25"
                                                        Click="PlaybackSpeedPresetButton_Click" />
