<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog x:Class="Niratan.Views.Dialogs.NovelShelfManagementDialog"
               x:Name="RootDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:novel="using:Niratan.Models.Novel"
               mc:Ignorable="d"
               x:Uid="NovelShelfManagementDialog"
               DefaultButton="Close"
               MinWidth="520">
    <Grid RowDefinitions="Auto,Auto,Auto"
          RowSpacing="20">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <TextBox x:Name="ShelfNameBox"
                     x:Uid="NovelShelfNameBox"
                     AutomationProperties.AutomationId="NovelShelfNameBox"
                     TextChanged="ShelfNameBox_TextChanged" />
            <Button Grid.Column="1"
                    x:Name="NovelShelfCreateButton"
                    x:Uid="NovelShelfCreateButton"
                    MinWidth="88"
                    VerticalAlignment="Bottom"
                    AutomationProperties.AutomationId="NovelShelfCreateButton"
                    IsEnabled="False"
                    Click="CreateShelfButton_Click" />
        </Grid>

        <ListView x:Name="NovelShelfList"
                  Grid.Row="1"
                  MinHeight="120"
                  MaxHeight="240"
                  AutomationProperties.AutomationId="NovelShelfList"
                  ItemsSource="{x:Bind ViewModel.Shelves, Mode=OneWay}"
                  SelectionMode="Single"
                  AllowDrop="True"
                  CanDragItems="True"
                  CanReorderItems="True"
                  DragItemsCompleted="ShelfList_DragItemsCompleted"
                  SelectionChanged="ShelfList_SelectionChanged">
            <ListView.Header>
                <TextBlock x:Uid="NovelShelfListHeader"
                           Margin="0,0,0,8"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
            </ListView.Header>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="MinHeight" Value="44" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="novel:NovelShelf">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="10">
                        <SymbolIcon VerticalAlignment="Center"
                                    Symbol="Folder" />
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="{x:Bind Name}"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <FontIcon Grid.Column="2"
                                  VerticalAlignment="Center"
                                  FontSize="14"
                                  Glyph="&#xE7C2;"
                                  Opacity="0.55" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="12">
            <TextBox x:Name="ShelfRenameBox"
                     x:Uid="NovelShelfRenameBox"
                     AutomationProperties.AutomationId="NovelShelfRenameBox"
                     IsEnabled="False"
                     TextChanged="ShelfRenameBox_TextChanged" />
            <Button x:Name="NovelShelfRenameButton"
                    Grid.Column="1"
                    x:Uid="NovelShelfRenameButton"
                    MinWidth="88"
                    VerticalAlignment="Bottom"
                    AutomationProperties.AutomationId="NovelShelfRenameButton"
                    IsEnabled="False"
                    Click="RenameShelfButton_Click" />
            <Button x:Name="NovelShelfDeleteButton"
                    Grid.Column="2"
                    x:Uid="NovelShelfDeleteButton"
                    MinWidth="88"
                    VerticalAlignment="Bottom"
                    AutomationProperties.AutomationId="NovelShelfDeleteButton"
                    IsEnabled="False">
                <Button.Flyout>
                    <Flyout x:Name="NovelShelfDeleteConfirmationFlyout"
                            AutomationProperties.AutomationId="NovelShelfDeleteConfirmationFlyout"
                            Opening="DeleteConfirmationFlyout_Opening">
                        <StackPanel MaxWidth="320"
                                    Spacing="12">
                            <TextBlock x:Name="NovelShelfDeleteConfirmationText"
                                       TextWrapping="Wrap" />
                            <StackPanel HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button x:Uid="NovelShelfCancelDeleteButton"
                                        AutomationProperties.AutomationId="NovelShelfCancelDeleteButton"
                                        Click="CancelDeleteShelfButton_Click" />
                                <Button x:Uid="NovelShelfConfirmDeleteButton"
                                        AutomationProperties.AutomationId="NovelShelfConfirmDeleteButton"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="ConfirmDeleteShelfButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>
    </Grid>
</ContentDialog>
