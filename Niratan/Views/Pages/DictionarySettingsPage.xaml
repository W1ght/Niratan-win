<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Niratan.Views.Pages.DictionarySettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:helpers="using:Niratan.Helpers.UI.Converters"
      xmlns:pageViewModels="using:Niratan.ViewModels.Pages"
      mc:Ignorable="d">

    <Page.Resources>
        <helpers:BooleanNegationConverter x:Key="BoolNegationConverter" />
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="SettingsSectionHeaderTextBlockStyle" BasedOn="{StaticResource BodyStrongTextBlockStyle}" TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="Auto,*">
        <StackPanel Padding="20,14,36,16"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
            <Button x:Name="DictionarySettingsBackButton"
                    Width="36"
                    Height="36"
                    Padding="0"
                    AutomationProperties.AutomationId="DictionarySettingsBackButton"
                    x:Uid="DictionarySettingsBackButton"
                    Click="BackButton_Click">
                <FontIcon Glyph="&#xE72B;" />
            </Button>
            <FontIcon FontSize="24" Glyph="&#xE8F1;" />
            <TextBlock x:Uid="DictionarySettingsTitle"
                       VerticalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="Dictionaries" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="16,0,16,16">
                <StackPanel MaxWidth="1280" HorizontalAlignment="Stretch" Spacing="4">
                    <toolkit:SettingsCard x:Uid="DictionaryRecommendedCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Download the dictionaries recommended by Niratan for the active profile language"
                                          Header="Recommended Dictionaries"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE896;}">
                        <Button AutomationProperties.AutomationId="DownloadRecommendedDictionariesButton"
                                Click="DownloadRecommendedDictionaries_Click"
                                IsEnabled="{x:Bind ViewModel.IsDictionaryOperationInProgress, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE896;" />
                                <TextBlock x:Uid="DictionaryRecommendedDownloadText" Text="Download…" />
                            </StackPanel>
                        </Button>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryImportCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Import Yomitan-format dictionaries and use them for reader lookup"
                                          Header="Import"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8A5;}">
                        <Button AutomationProperties.AutomationId="ImportDictionaryButton"
                                AutomationProperties.Name="Import Dictionary"
                                x:Uid="ImportDictionaryButton"
                                Command="{x:Bind ViewModel.ImportDictionaryCommand}"
                                IsEnabled="{x:Bind ViewModel.IsDictionaryOperationInProgress, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8A5;" FontSize="14" />
                                <TextBlock x:Uid="ImportDictionaryButtonText" Text="Import .zip" />
                            </StackPanel>
                        </Button>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="DictionaryUpdatesSectionHeader"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                               Text="Updates" />

                    <toolkit:SettingsCard x:Uid="DictionaryAutoUpdateCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Update Automatically"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE895;}">
                        <ToggleSwitch AutomationProperties.AutomationId="DictionaryAutoUpdateToggle"
                                      IsOn="{x:Bind ViewModel.UpdateAutomatically, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryUpdateIntervalCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Interval"
                                          Visibility="{x:Bind ViewModel.UpdateAutomatically, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ComboBox MinWidth="180"
                                  AutomationProperties.AutomationId="DictionaryUpdateIntervalComboBox"
                                  SelectedIndex="{x:Bind ViewModel.UpdateIntervalIndex, Mode=TwoWay}">
                            <ComboBoxItem x:Uid="DictionaryUpdateIntervalDaily" Content="Daily" />
                            <ComboBoxItem x:Uid="DictionaryUpdateIntervalWeekly" Content="Weekly" />
                            <ComboBoxItem x:Uid="DictionaryUpdateIntervalMonthly" Content="Monthly" />
                        </ComboBox>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryLastUpdateCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Last Update">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="{x:Bind ViewModel.LastUpdateText, Mode=OneWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryUpdateDictionariesCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Check installed dictionaries that publish an update index"
                                          Header="Update Dictionaries">
                        <Button AutomationProperties.AutomationId="UpdateDictionariesButton"
                                Click="UpdateDictionaries_Click"
                                IsEnabled="{x:Bind ViewModel.IsDictionaryOperationInProgress, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE895;" />
                                <TextBlock x:Uid="DictionaryCheckUpdatesText" Text="Check for updates…" />
                            </StackPanel>
                        </Button>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="DictionarySettingsSectionHeader"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                               Text="Settings" />

                    <toolkit:SettingsCard x:Uid="DictionaryDefaultTabCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Open Lookup instead of the novel library when Niratan starts"
                                          Header="Default to Dictionary Tab"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE721;}">
                        <ToggleSwitch AutomationProperties.AutomationId="DictionaryTabDefaultToggle"
                                      IsOn="{x:Bind ViewModel.DictionaryTabDefault, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryCustomCssCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Edit CSS applied after dictionary-provided styles"
                                          Header="Custom CSS"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE943;}">
                        <Button AutomationProperties.AutomationId="DictionaryCustomCssButton"
                                Click="CustomCss_Click">
                            <TextBlock x:Uid="DictionaryCustomCssEditText" Text="Edit…" />
                        </Button>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="DictionaryLookupSectionHeader"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                               Text="Lookup" />

                    <toolkit:SettingsCard x:Uid="ScanNonJapaneseTextCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Allow lookup for English and other non-Japanese text"
                                          Header="Scan Non-Japanese Text"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8D4;}">
                        <ToggleSwitch AutomationProperties.AutomationId="ScanNonJapaneseTextToggle"
                                      IsOn="{x:Bind ViewModel.ScanNonJapaneseText, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="GlobalLookupEnabledCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Enable the global lookup coordinator for selected text"
                                          Header="Global Lookup"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE721;}">
                        <StackPanel Spacing="6" HorizontalAlignment="Right">
                            <ToggleSwitch AutomationProperties.AutomationId="GlobalLookupEnabledToggle"
                                          IsOn="{x:Bind ViewModel.GlobalLookupEnabled, Mode=TwoWay}" />
                            <TextBlock MaxWidth="360"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Text="{x:Bind ViewModel.GlobalLookupStatusText, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryMaxResultsCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Max Results"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8A9;}">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock MinWidth="32"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{x:Bind ViewModel.MaxResults, Mode=OneWay}" />
                            <Button Width="36"
                                    Height="32"
                                    Padding="0"
                                    AutomationProperties.AutomationId="DictionaryMaxResultsDecreaseButton"
                                    Command="{x:Bind ViewModel.DecreaseMaxResultsCommand}">
                                <FontIcon FontSize="12" Glyph="&#xE738;" />
                            </Button>
                            <Button Width="36"
                                    Height="32"
                                    Padding="0"
                                    AutomationProperties.AutomationId="DictionaryMaxResultsIncreaseButton"
                                    Command="{x:Bind ViewModel.IncreaseMaxResultsCommand}">
                                <FontIcon FontSize="12" Glyph="&#xE710;" />
                            </Button>
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryScanLengthCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Scan Length"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8C1;}">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock MinWidth="32"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{x:Bind ViewModel.ScanLength, Mode=OneWay}" />
                            <Button Width="36"
                                    Height="32"
                                    Padding="0"
                                    AutomationProperties.AutomationId="DictionaryScanLengthDecreaseButton"
                                    Command="{x:Bind ViewModel.DecreaseScanLengthCommand}">
                                <FontIcon FontSize="12" Glyph="&#xE738;" />
                            </Button>
                            <Button Width="36"
                                    Height="32"
                                    Padding="0"
                                    AutomationProperties.AutomationId="DictionaryScanLengthIncreaseButton"
                                    Command="{x:Bind ViewModel.IncreaseScanLengthCommand}">
                                <FontIcon FontSize="12" Glyph="&#xE710;" />
                            </Button>
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="DictionaryCollapseSectionHeader"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                               Text="Collapse Dictionaries" />

                    <toolkit:SettingsCard x:Uid="DictionaryCollapseModeCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Mode">
                        <ComboBox MinWidth="220"
                                  AutomationProperties.AutomationId="DictionaryCollapseModeComboBox"
                                  ItemsSource="{x:Bind ViewModel.AvailableCollapseModes}"
                                  SelectedItem="{x:Bind ViewModel.CollapseMode, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryExpandFirstCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Expand First Dictionary"
                                          Visibility="{x:Bind ViewModel.IsExpandFirstDictionaryVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ToggleSwitch AutomationProperties.AutomationId="DictionaryExpandFirstToggle"
                                      IsOn="{x:Bind ViewModel.ExpandFirstDictionary, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryCollapsedDictionariesCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Collapsed Dictionaries"
                                          Visibility="{x:Bind ViewModel.IsCustomCollapseMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button AutomationProperties.AutomationId="ConfigureCollapsedDictionariesButton"
                                Click="ConfigureCollapsedDictionaries_Click">
                            <TextBlock x:Uid="DictionaryConfigureCollapsedText" Text="Configure…" />
                        </Button>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="DictionaryBehaviorSectionHeader"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                               Text="Behavior" />

                    <toolkit:SettingsCard x:Uid="DictionaryTwoColumnCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Arrange dictionary cards in two columns on wide popup surfaces"
                                          Header="Two-Column Layout">
                        <ToggleSwitch AutomationProperties.AutomationId="DictionaryTwoColumnLayoutToggle"
                                      IsOn="{x:Bind ViewModel.TwoColumnLayout, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryCompactGlossariesCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Compact Glossaries">
                        <ToggleSwitch AutomationProperties.AutomationId="DictionaryCompactGlossariesToggle"
                                      IsOn="{x:Bind ViewModel.CompactGlossaries, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryShowExpressionTagsCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Show Expression Tags">
                        <ToggleSwitch AutomationProperties.AutomationId="DictionaryShowExpressionTagsToggle"
                                      IsOn="{x:Bind ViewModel.ShowExpressionTags, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryHarmonicFrequencyCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Harmonic Frequency">
                        <ToggleSwitch AutomationProperties.AutomationId="DictionaryHarmonicFrequencyToggle"
                                      IsOn="{x:Bind ViewModel.HarmonicFrequency, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryDeduplicatePitchCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Deduplicate Pitch">
                        <ToggleSwitch AutomationProperties.AutomationId="DictionaryDeduplicatePitchToggle"
                                      IsOn="{x:Bind ViewModel.DeduplicatePitchAccents, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryCompactPitchCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Compact Pitch">
                        <ToggleSwitch AutomationProperties.AutomationId="DictionaryCompactPitchToggle"
                                      IsOn="{x:Bind ViewModel.CompactPitchAccents, Mode=TwoWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="DictionaryDesktopHoverDelayCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Delay before Shift-hover lookup in Reader, Popup, and video subtitles"
                                          Header="Desktop Hover Delay">
                        <StackPanel MinWidth="280" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Slider Width="220"
                                    Minimum="0"
                                    Maximum="250"
                                    StepFrequency="5"
                                    Value="{x:Bind ViewModel.DesktopLookupHoverDelayMs, Mode=TwoWay}" />
                            <TextBlock MinWidth="56"
                                       VerticalAlignment="Center"
                                       Text="{x:Bind ViewModel.DesktopLookupHoverDelayMs, Mode=OneWay}" />
                            <TextBlock VerticalAlignment="Center" Text="ms" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="DictionaryTypeDescription"
                               Margin="1,12,0,6"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="Supports Yomitan term, frequency, and pitch dictionaries (.zip)" />

                    <Grid AutomationProperties.AutomationId="DictionaryTypeTabs"
                          ColumnDefinitions="*,*,*"
                          BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="6">
                        <RadioButton Grid.Column="0"
                                     x:Uid="DictionaryTypeTermButton"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Center"
                                     Content="Term"
                                     GroupName="DictionaryType"
                                     IsChecked="{x:Bind ViewModel.IsTermSelected, Mode=OneWay}"
                                     Tag="Term"
                                     Checked="DictionaryType_Checked" />
                        <RadioButton Grid.Column="1"
                                     x:Uid="DictionaryTypeFrequencyButton"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Center"
                                     Content="Frequency"
                                     GroupName="DictionaryType"
                                     IsChecked="{x:Bind ViewModel.IsFrequencySelected, Mode=OneWay}"
                                     Tag="Frequency"
                                     Checked="DictionaryType_Checked" />
                        <RadioButton Grid.Column="2"
                                     x:Uid="DictionaryTypePitchButton"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Center"
                                     Content="Pitch"
                                     GroupName="DictionaryType"
                                     IsChecked="{x:Bind ViewModel.IsPitchSelected, Mode=OneWay}"
                                     Tag="Pitch"
                                     Checked="DictionaryType_Checked" />
                    </Grid>

                    <TextBlock x:Uid="DictionaryInstalledSectionHeader"
                               Style="{StaticResource SettingsSectionHeaderTextBlockStyle}">
                        <Span><Bold>Installed</Bold></Span>
                    </TextBlock>

                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ViewModel.DictionaryStatusText, Mode=OneWay}" />

                    <ListView x:Name="DictionaryList"
                              AutomationProperties.AutomationId="InstalledDictionaryList"
                              AllowDrop="True"
                              CanDragItems="True"
                              CanReorderItems="True"
                              DragItemsCompleted="DictionaryList_DragItemsCompleted"
                              IsEnabled="{x:Bind ViewModel.IsDictionaryOperationInProgress, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                              ItemsSource="{x:Bind ViewModel.InstalledDictionaries, Mode=OneWay}"
                              ReorderMode="Enabled"
                              SelectionMode="None"
                              Visibility="{x:Bind ViewModel.IsDictionaryListEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Margin" Value="0,4" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="pageViewModels:DictionarySettingsItemViewModel">
                                <Border MinHeight="76"
                                        Padding="16,10"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="14">
                                        <FontIcon Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  Glyph="&#xE700;"
                                                  FontSize="18"
                                                  Opacity="0.65" />
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="2">
                                            <TextBlock FontSize="16"
                                                       Text="{x:Bind DisplayTitle}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Text="{x:Bind Revision}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="2"
                                                      VerticalAlignment="Center"
                                                      AutomationProperties.Name="Enable Dictionary"
                                                      IsOn="{x:Bind IsEnabled, Mode=OneWay}"
                                                      Tag="{x:Bind Name}"
                                                      Toggled="DictionaryEnabled_Toggled" />
                                        <Button Grid.Column="3"
                                                Width="36"
                                                Height="36"
                                                Padding="0"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="Delete Dictionary"
                                                Tag="{x:Bind Name}"
                                                ToolTipService.ToolTip="Delete dictionary"
                                                Click="DeleteDictionary_Click">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <toolkit:SettingsCard x:Uid="NoDictionariesCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="Import a Yomitan dictionary ZIP to enable lookup for this category"
                                          Header="No Dictionaries"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}"
                                          Visibility="{x:Bind ViewModel.IsDictionaryListEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <ContentDialog x:Name="RecommendedDictionariesDialog"
                       x:Uid="RecommendedDictionariesDialog"
                       Grid.RowSpan="2"
                       Title="Download Dictionaries"
                       PrimaryButtonText="Download"
                       CloseButtonText="Cancel"
                       PrimaryButtonClick="RecommendedDictionariesDialog_PrimaryButtonClick">
            <Grid MinWidth="460" MaxHeight="520">
                <ListView ItemsSource="{x:Bind ViewModel.RecommendedDictionaries, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="52" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <CheckBox VerticalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Text="{Binding Detail}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </ContentDialog>

        <ContentDialog x:Name="DictionaryUpdatesDialog"
                       x:Uid="DictionaryUpdatesDialog"
                       Grid.RowSpan="2"
                       Title="Update Dictionaries"
                       PrimaryButtonText="Update"
                       CloseButtonText="Cancel"
                       PrimaryButtonClick="DictionaryUpdatesDialog_PrimaryButtonClick">
            <Grid MinWidth="460" MaxHeight="520">
                <ListView ItemsSource="{x:Bind ViewModel.AvailableUpdates, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="52" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <CheckBox VerticalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Text="{Binding Detail}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </ContentDialog>

        <ContentDialog x:Name="CollapsedDictionariesDialog"
                       x:Uid="CollapsedDictionariesDialog"
                       Grid.RowSpan="2"
                       Title="Collapse Dictionaries"
                       PrimaryButtonText="Save"
                       CloseButtonText="Cancel"
                       PrimaryButtonClick="CollapsedDictionariesDialog_PrimaryButtonClick">
            <StackPanel MinWidth="460" MaxHeight="520" Spacing="10">
                <TextBlock x:Uid="CollapsedDictionariesDialogDescription"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Choose which term dictionaries start collapsed in lookup results."
                           TextWrapping="Wrap" />
                <ListView ItemsSource="{x:Bind ViewModel.CollapsedDictionaryItems, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <CheckBox MinHeight="44"
                                      Content="{Binding Name}"
                                      IsChecked="{Binding IsCollapsed, Mode=TwoWay}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ContentDialog>

    </Grid>
</Page>
