<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Niratan.Views.Pages.GameControllerSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:converters="using:Niratan.Helpers.UI.Converters"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:vm="using:Niratan.ViewModels.Pages"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="GameControllerSectionHeaderStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="Margin" Value="1,30,0,6" />
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="Auto,*">
        <StackPanel Padding="20,14,36,16"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
            <Button x:Name="GameControllerSettingsBackButton"
                    x:Uid="GameControllerSettingsBackButton"
                    Width="36"
                    Height="36"
                    Padding="0"
                    AutomationProperties.AutomationId="GameControllerSettingsBackButton"
                    Click="BackButton_Click">
                <FontIcon Glyph="&#xE72B;" />
            </Button>
            <FontIcon FontSize="24" Glyph="&#xE7FC;" />
            <TextBlock x:Uid="GameControllerPageTitle"
                       VerticalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="Game Controller" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="16,0,16,16">
                <StackPanel MaxWidth="1280"
                            HorizontalAlignment="Stretch"
                            Spacing="4">
                    <TextBlock x:Uid="GameControllerControllerSectionHeader"
                               Style="{StaticResource GameControllerSectionHeaderStyle}"
                               Text="Controller" />

                    <toolkit:SettingsCard x:Uid="GameControllerConnectionCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE7FC;}">
                        <TextBlock AutomationProperties.AutomationId="GameControllerConnectionStatus"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="{x:Bind ViewModel.ControllerStatusText, Mode=OneWay}" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="GameControllerRecordingCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xEA3A;}"
                                          Visibility="{x:Bind ViewModel.IsRecording, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind ViewModel.RecordingHintText, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <Button Grid.Column="1"
                                    x:Uid="GameControllerCancelRecordingButton"
                                    AutomationProperties.AutomationId="GameControllerCancelRecordingButton"
                                    Command="{x:Bind ViewModel.CancelRecordingCommand}"
                                    Content="Cancel" />
                        </Grid>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="GameControllerInstructionText"
                               Margin="12,6,12,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Text="Choose an action, then press a button or direction on an Xbox, PlayStation, Switch, or compatible controller."
                               TextWrapping="Wrap" />

                    <ItemsControl ItemsSource="{x:Bind ViewModel.Sections, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:GameControllerSectionViewModel">
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{StaticResource GameControllerSectionHeaderStyle}"
                                               Text="{x:Bind Title}" />
                                    <ItemsControl ItemsSource="{x:Bind Rows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:GameControllerRowViewModel">
                                                <toolkit:SettingsCard HorizontalAlignment="Stretch"
                                                                      HorizontalContentAlignment="Stretch"
                                                                      Header="{x:Bind Title}">
                                                    <Button MinWidth="132"
                                                            HorizontalAlignment="Right"
                                                            AutomationProperties.AutomationId="{x:Bind AutomationId}"
                                                            Command="{x:Bind RecordCommand}"
                                                            Content="{x:Bind DisplayLabel, Mode=OneWay}"
                                                            FontFamily="Consolas" />
                                                </toolkit:SettingsCard>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Uid="GameControllerDefaultsSectionHeader"
                               Style="{StaticResource GameControllerSectionHeaderStyle}"
                               Text="Defaults" />
                    <toolkit:SettingsCard x:Uid="GameControllerResetDefaultsCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE777;}">
                        <Button x:Uid="GameControllerResetDefaultsButton"
                                AutomationProperties.AutomationId="GameControllerResetDefaultsButton"
                                Command="{x:Bind ViewModel.ResetDefaultsCommand}"
                                Content="Reset Defaults" />
                    </toolkit:SettingsCard>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
