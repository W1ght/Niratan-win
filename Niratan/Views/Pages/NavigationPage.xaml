<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Niratan.Views.Pages.NavigationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:Niratan.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      NavigationCacheMode="Required"
      mc:Ignorable="d">

    <Grid>
        <Grid x:Name="AppTitleBar"
              Height="32"
              Padding="0"
              VerticalAlignment="Top"
              AutomationProperties.AutomationId="AppTitleBar" />

        <NavigationView x:Name="NavigationViewControl"
                        BackRequested="NavigationViewControl_BackRequested"
                        IsBackEnabled="{x:Bind ViewModel.IsBackEnabled, Mode=OneWay}"
                        IsSettingsVisible="False"
                        ItemInvoked="NavigationViewControl_ItemInvoked"
                        OpenPaneLength="200"
                        PaneDisplayMode="Auto">
            <NavigationView.Resources>
                <Thickness x:Key="NavigationViewContentMargin">0</Thickness>
                <Thickness x:Key="NavigationViewMinimalContentMargin">0</Thickness>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">1,0,0,0</Thickness>
                <Thickness x:Key="NavigationViewHeaderMargin">36,30,36,0</Thickness>
                <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>
            </NavigationView.Resources>

            <NavigationView.MenuItems>
                <NavigationViewItem AutomationProperties.AutomationId="NovelNavItem"
                                    x:Uid="NovelNavItem"
                                    Content="Novels"
                                    Icon="Library"
                                    IsSelected="True"
                                    Tag="Niratan.Views.Pages.NovelLibraryPage" />
                <NavigationViewItem AutomationProperties.AutomationId="VideoNavItem"
                                    x:Uid="VideoNavItem"
                                    Content="Videos"
                                    Icon="Video"
                                    Tag="Niratan.Views.Pages.VideoLibraryPage" />
                <NavigationViewItem AutomationProperties.AutomationId="NovelLookupNavItem"
                                    x:Uid="NovelLookupNavItem"
                                    Content="Lookup"
                                    Icon="Find"
                                    Tag="Niratan.Views.Pages.NovelLookupPage" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem AutomationProperties.AutomationId="SettingsNavItem"
                                    x:Uid="SettingsNavItem"
                                    Content="Settings"
                                    Icon="Setting"
                                    Tag="Niratan.Views.Pages.SettingsPage" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Padding="0" Navigated="ContentFrame_Navigated">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Page>
