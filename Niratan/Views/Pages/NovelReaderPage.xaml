<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Niratan.Views.Pages.NovelReaderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:Niratan.Views.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:novel="using:Niratan.Models.Novel"
      xmlns:vm="using:Niratan.ViewModels.Components"
      CharacterReceived="NovelReaderPage_CharacterReceived"
      KeyboardAcceleratorPlacementMode="Hidden"
      mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="CompactReaderToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="CompactReaderToolbarIconStyle" TargetType="FontIcon">
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="CompactReaderTitleTextStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MaxLines" Value="1" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="CompactReaderProgressTextStyle"
               BasedOn="{StaticResource CaptionTextBlockStyle}"
               TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="MaxLines" Value="1" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ReaderGoToSegmentButtonStyle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0"
                x:Name="ReaderTopChrome"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid Height="32"
                  Padding="4,0,0,0"
                  ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,144"
                  ColumnSpacing="0">
            <Button HorizontalAlignment="Left"
                    x:Name="NovelReaderBackButton"
                    AutomationProperties.AutomationId="NovelReaderBackButton"
                    Command="{x:Bind ViewModel.BackToLibraryCommand}"
                    Style="{StaticResource CompactReaderToolbarButtonStyle}">
                <Button.Content>
                    <FontIcon Glyph="&#xE72B;"
                              Style="{StaticResource CompactReaderToolbarIconStyle}" />
                </Button.Content>
            </Button>

            <Button Grid.Column="1"
                    x:Name="NovelReaderGoToButton"
                    HorizontalAlignment="Left"
                    AutomationProperties.AutomationId="NovelReaderGoToButton"
                    x:Uid="NovelReaderGoToButton"
                    Click="GoToButton_Click"
                    Style="{StaticResource CompactReaderToolbarButtonStyle}">
                <Button.Content>
                    <FontIcon Glyph="&#xE721;"
                              Style="{StaticResource CompactReaderToolbarIconStyle}" />
                </Button.Content>
            </Button>

            <Button Grid.Column="3"
                    x:Name="NovelReaderStatisticsButton"
                    HorizontalAlignment="Left"
                    AutomationProperties.AutomationId="NovelReaderStatisticsButton"
                    x:Uid="NovelReaderStatisticsButton"
                    Click="StatisticsButton_Click"
                    Style="{StaticResource CompactReaderToolbarButtonStyle}">
                <Button.Content>
                    <FontIcon Glyph="&#xE9D2;"
                              Style="{StaticResource CompactReaderToolbarIconStyle}" />
                </Button.Content>
            </Button>

            <Button Grid.Column="2"
                    HorizontalAlignment="Left"
                    AutomationProperties.AutomationId="NovelReaderAppearanceButton"
                    x:Uid="NovelReaderAppearanceButton"
                    Click="AppearanceButton_Click"
                    Style="{StaticResource CompactReaderToolbarButtonStyle}">
                <Button.Content>
                    <FontIcon Glyph="&#xE790;"
                              Style="{StaticResource CompactReaderToolbarIconStyle}" />
                </Button.Content>
            </Button>

            <Button Grid.Column="4"
                    x:Name="NovelReaderGalleryButton"
                    HorizontalAlignment="Left"
                    AutomationProperties.AutomationId="NovelReaderGalleryButton"
                    x:Uid="NovelReaderGalleryButton"
                    Click="GalleryButton_Click"
                    Style="{StaticResource CompactReaderToolbarButtonStyle}">
                <Button.Content>
                    <FontIcon Glyph="&#xE91B;"
                              Style="{StaticResource CompactReaderToolbarIconStyle}" />
                </Button.Content>
            </Button>

            <Button Grid.Column="5"
                    x:Name="SasayakiButton"
                    HorizontalAlignment="Left"
                    AutomationProperties.AutomationId="NovelReaderSasayakiButton"
                    x:Uid="NovelReaderSasayakiButton"
                    Click="SasayakiButton_Click"
                    Style="{StaticResource CompactReaderToolbarButtonStyle}"
                    Visibility="Collapsed">
                <Button.Content>
                    <FontIcon x:Name="SasayakiButtonIcon"
                              Glyph="&#xE767;"
                              Style="{StaticResource CompactReaderToolbarIconStyle}" />
                </Button.Content>
                <Button.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="SasayakiSkipBackMenuItem"
                                        x:Uid="SasayakiSkipBackMenuItem"
                                        AutomationProperties.AutomationId="NovelReaderSasayakiSkipBackMenuItem"
                                        Click="SasayakiSkipBack_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE7A7;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="SasayakiPreviousCueMenuItem"
                                        x:Uid="SasayakiPreviousCueMenuItem"
                                        AutomationProperties.AutomationId="NovelReaderSasayakiPreviousCueMenuItem"
                                        Click="SasayakiPrevCue_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE892;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="SasayakiPlayPauseMenuItem"
                                        x:Uid="SasayakiPlayPauseMenuItem"
                                        AutomationProperties.AutomationId="NovelReaderSasayakiPlayPauseMenuItem"
                                        Click="SasayakiPlayPause_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon x:Name="SasayakiPlayPauseMenuIcon" Glyph="&#xE768;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="SasayakiNextCueMenuItem"
                                        x:Uid="SasayakiNextCueMenuItem"
                                        AutomationProperties.AutomationId="NovelReaderSasayakiNextCueMenuItem"
                                        Click="SasayakiNextCue_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE893;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="SasayakiSkipForwardMenuItem"
                                        x:Uid="SasayakiSkipForwardMenuItem"
                                        AutomationProperties.AutomationId="NovelReaderSasayakiSkipForwardMenuItem"
                                        Click="SasayakiSkipForward_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE7A6;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="SasayakiReplayCueMenuItem"
                                        x:Uid="SasayakiReplayCueMenuItem"
                                        AutomationProperties.AutomationId="NovelReaderSasayakiReplayCueMenuItem"
                                        Click="SasayakiReplayCue_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE102;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="SasayakiJumpCueMenuItem"
                                        x:Uid="SasayakiJumpCueMenuItem"
                                        AutomationProperties.AutomationId="NovelReaderSasayakiJumpCueMenuItem"
                                        Click="SasayakiJumpCue_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8AD;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="SasayakiLyricsModeMenuItem"
                                        x:Uid="NovelReaderLyricsModeMenuItem"
                                        AutomationProperties.AutomationId="NovelReaderLyricsModeMenuItem"
                                        Click="SasayakiLyricsMode_Click"
                                        Visibility="Collapsed">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE189;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="SasayakiLoadAudioMenuItem"
                                        x:Uid="SasayakiLoadAudioMenuItem"
                                        AutomationProperties.AutomationId="NovelReaderSasayakiLoadAudioMenuItem"
                                        Click="SasayakiLoadButton_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8A5;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.ContextFlyout>
            </Button>

            <Button Grid.Column="6"
                    x:Name="NovelReaderLyricsModeButton"
                    x:Uid="NovelReaderLyricsModeButton"
                    HorizontalAlignment="Left"
                    AutomationProperties.AutomationId="NovelReaderLyricsModeButton"
                    Click="SasayakiLyricsMode_Click"
                    Style="{StaticResource CompactReaderToolbarButtonStyle}"
                    Visibility="Collapsed">
                <Button.Content>
                    <FontIcon Glyph="&#xE189;"
                              Style="{StaticResource CompactReaderToolbarIconStyle}" />
                </Button.Content>
            </Button>

            <Grid Grid.Column="7"
                  Margin="8,0"
                  ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="6">
                <TextBlock x:Name="NovelReaderTitleText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CompactReaderTitleTextStyle}"
                           Text="{x:Bind ViewModel.ReaderTitle, Mode=OneWay}" />
                <TextBlock x:Name="NovelReaderTopProgressText"
                           Grid.Column="1"
                           AutomationProperties.AutomationId="NovelReaderProgressText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{StaticResource CompactReaderProgressTextStyle}"
                           Visibility="Collapsed" />
                <TextBlock x:Name="NovelReaderStatisticsText"
                           Grid.Column="2"
                           AutomationProperties.AutomationId="NovelReaderStatisticsText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{StaticResource CompactReaderProgressTextStyle}"
                           Visibility="Collapsed" />
            </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <WebView2 x:Name="NovelWebView"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      DefaultBackgroundColor="White"
                      AutomationProperties.AutomationId="NovelWebView" />
        </Grid>

        <controls:ReaderLyricsModeControl x:Name="ReaderLyricsMode"
                                          Grid.RowSpan="3"
                                          Canvas.ZIndex="90"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Visibility="Collapsed" />

        <!-- Dictionary popup overlay — lives in the main visual tree so MicaBackdrop shows through -->
        <Canvas x:Name="DictionaryOverlayCanvas"
                Grid.RowSpan="3"
                Canvas.ZIndex="120"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                Visibility="Collapsed"
                AutomationProperties.AutomationId="DictionaryOverlayCanvas" />

        <ContentDialog x:Name="ReaderGoToPanelDialog"
                       x:Uid="ReaderGoToPanelDialog"
                       AutomationProperties.AutomationId="NovelReaderGoToPanelDialog"
                       MaxWidth="640"
                       CloseButtonText="Close"
                       DefaultButton="Close">
            <ContentDialog.Resources>
                <x:Double x:Key="ContentDialogMaxWidth">640</x:Double>
            </ContentDialog.Resources>
            <Grid Width="580"
                  Height="640"
                  RowDefinitions="Auto,Auto,*"
                  RowSpacing="12">
                <Grid Margin="4,0,4,4"
                      ColumnDefinitions="50,*,Auto"
                      ColumnSpacing="16">
                    <Border Width="50"
                            Height="75"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="4">
                        <Grid>
                            <FontIcon HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      FontSize="22"
                                      Glyph="&#xE8B9;"
                                      Opacity="0.35" />
                            <Image x:Name="ReaderGoToCoverImage"
                                   Stretch="UniformToFill" />
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="6">
                        <TextBlock x:Name="ReaderGoToBookTitle"
                                   FontWeight="SemiBold"
                                   MaxLines="2"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="ReaderGoToProgressText"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <Button x:Name="ReaderGoToCharacterButton"
                            Grid.Column="2"
                            x:Uid="ReaderGoToCharacterButton"
                            AutomationProperties.AutomationId="NovelReaderGoToCharacterButton"
                            VerticalAlignment="Center"
                            Click="ReaderGoToCharacterButton_Click">
                        <FontIcon FontSize="13" Glyph="&#xE8AD;" />
                    </Button>
                </Grid>

                <Border Grid.Row="1"
                        HorizontalAlignment="Center"
                        Padding="2"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        CornerRadius="18">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <ToggleButton x:Name="ReaderGoToSearchTabButton"
                                      x:Uid="ReaderGoToSearchTabButton"
                                      AutomationProperties.AutomationId="NovelReaderGoToSearchTabButton"
                                      Click="ReaderGoToSearchTabButton_Click"
                                      IsChecked="True"
                                      Style="{StaticResource ReaderGoToSegmentButtonStyle}" />
                        <ToggleButton x:Name="ReaderGoToChaptersTabButton"
                                      x:Uid="ReaderGoToChaptersTabButton"
                                      AutomationProperties.AutomationId="NovelReaderGoToChaptersTabButton"
                                      Click="ReaderGoToChaptersTabButton_Click"
                                      Style="{StaticResource ReaderGoToSegmentButtonStyle}" />
                        <ToggleButton x:Name="ReaderGoToHighlightsTabButton"
                                      x:Uid="ReaderGoToHighlightsTabButton"
                                      AutomationProperties.AutomationId="NovelReaderGoToHighlightsTabButton"
                                      Click="ReaderGoToHighlightsTabButton_Click"
                                      Style="{StaticResource ReaderGoToSegmentButtonStyle}" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid x:Name="ReaderGoToSearchContent"
                          AutomationProperties.AutomationId="NovelReaderGoToSearchContent"
                          RowDefinitions="Auto,*"
                          RowSpacing="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox x:Name="ReaderSearchQueryBox"
                                     x:Uid="ReaderSearchQueryBox"
                                     AutomationProperties.AutomationId="NovelReaderSearchQueryBox"
                                     CornerRadius="18"
                                     KeyDown="ReaderSearchQueryBox_KeyDown"
                                     PlaceholderText="Search in this book"
                                     TextChanged="ReaderSearchQueryBox_TextChanged" />
                            <Button x:Name="ReaderSearchSubmitButton"
                                    Grid.Column="1"
                                    x:Uid="ReaderSearchSubmitButton"
                                    AutomationProperties.AutomationId="NovelReaderSearchSubmitButton"
                                    Click="ReaderSearchSubmitButton_Click">
                                <FontIcon FontSize="13" Glyph="&#xE721;" />
                            </Button>
                        </Grid>
                        <Grid Grid.Row="1">
                            <ListView x:Name="ReaderSearchResultsList"
                                      AutomationProperties.AutomationId="NovelReaderSearchResultsList"
                                      IsItemClickEnabled="True"
                                      ItemClick="SearchResult_ItemClick"
                                      SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="novel:ReaderSearchResult">
                                        <StackPanel Padding="4,8" Spacing="4">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{x:Bind ChapterLabel}" />
                                            <TextBlock MaxLines="4"
                                                       TextWrapping="Wrap">
                                                <Run Text="{x:Bind SnippetBeforeMatch}" />
                                                <Run FontWeight="SemiBold"
                                                     Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                     Text="{x:Bind SnippetMatch}" />
                                                <Run Text="{x:Bind SnippetAfterMatch}" />
                                            </TextBlock>
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Text="{x:Bind Character}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <StackPanel x:Name="ReaderSearchStatusPanel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False"
                                        Spacing="8">
                                <ProgressRing x:Name="ReaderSearchLoadingRing"
                                              Width="24"
                                              Height="24"
                                              IsActive="False"
                                              Visibility="Collapsed" />
                                <TextBlock x:Name="ReaderSearchPromptText"
                                           x:Uid="ReaderSearchPromptText"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Text="Enter text to search this book" />
                                <TextBlock x:Name="ReaderSearchLoadingText"
                                           x:Uid="ReaderSearchLoadingText"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Text="Searching..."
                                           Visibility="Collapsed" />
                                <TextBlock x:Name="ReaderSearchNoMatchesText"
                                           x:Uid="ReaderSearchNoMatchesText"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Text="No matches"
                                           Visibility="Collapsed" />
                                <TextBlock x:Name="ReaderSearchFailedText"
                                           x:Uid="ReaderSearchFailedText"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Text="Could not search this book"
                                           Visibility="Collapsed" />
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <controls:ReaderChapterListContent x:Name="ReaderChapterListContent"
                                                       AutomationProperties.AutomationId="NovelReaderGoToChaptersContent"
                                                       Visibility="Collapsed" />

                    <Grid x:Name="ReaderGoToHighlightsContent"
                          AutomationProperties.AutomationId="NovelReaderGoToHighlightsContent"
                          Visibility="Collapsed">
                        <ListView x:Name="ReaderHighlightsList"
                                  AutomationProperties.AutomationId="NovelReaderHighlightsList"
                                  IsItemClickEnabled="True"
                                  ItemClick="Highlight_ItemClick"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="novel:ReaderHighlightListItem">
                                    <Grid Padding="4,8"
                                          ColumnDefinitions="4,*"
                                          ColumnSpacing="10">
                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem x:Uid="ReaderHighlightDeleteMenuItem"
                                                                Text="Delete"
                                                                AutomationProperties.AutomationId="ReaderHighlightDeleteMenuItem"
                                                                Tag="{Binding}"
                                                                Click="ReaderHighlightDeleteMenuItem_Click" />
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        <Border CornerRadius="2">
                                            <Border.Background>
                                                <SolidColorBrush Color="{x:Bind SwatchColor}" />
                                            </Border.Background>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{x:Bind ChapterLabel}" />
                                            <TextBlock MaxLines="5"
                                                       Text="{x:Bind Text}"
                                                       TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Text="{x:Bind PositionText}" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Text="{x:Bind CreatedText}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock x:Name="ReaderHighlightsEmptyText"
                                   x:Uid="ReaderHighlightsEmptyText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="No highlights"
                                   Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </Grid>
        </ContentDialog>

        <ContentDialog x:Name="ReaderGalleryPanelDialog"
                       x:Uid="ReaderGalleryPanelDialog"
                       AutomationProperties.AutomationId="NovelReaderGalleryPanelDialog"
                       MaxWidth="10000"
                       MaxHeight="10000"
                       CloseButtonText="Close"
                       DefaultButton="Close">
            <ContentDialog.Resources>
                <x:Double x:Key="ContentDialogMaxWidth">10000</x:Double>
                <x:Double x:Key="ContentDialogMaxHeight">10000</x:Double>
            </ContentDialog.Resources>
            <Grid x:Name="ReaderGalleryPanelContent"
                  MinWidth="320"
                  MinHeight="320"
                  RowDefinitions="Auto,*"
                  RowSpacing="12">
                <ToggleSwitch x:Name="ReaderGalleryBlurUnreadToggle"
                              x:Uid="ReaderGalleryBlurUnreadToggle"
                              AutomationProperties.AutomationId="NovelReaderGalleryBlurUnreadToggle"
                              HorizontalAlignment="Right"
                              Toggled="ReaderGalleryBlurUnreadToggle_Toggled" />
                <GridView x:Name="ReaderGalleryGrid"
                          Grid.Row="1"
                          AutomationProperties.AutomationId="NovelReaderGalleryGrid"
                          IsItemClickEnabled="True"
                          ItemClick="GalleryImage_ItemClick"
                          ItemsSource="{x:Bind ViewModel.GalleryImages, Mode=OneWay}"
                          SelectionMode="None">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           ItemWidth="252"
                                           ItemHeight="320" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ReaderGalleryImageItemViewModel">
                            <Border Margin="6"
                                    Padding="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    AutomationProperties.AutomationId="{x:Bind AutomationId}">
                                <controls:ReaderGalleryImageCard FilePath="{x:Bind FilePath}"
                                                                 Thumbnail="{x:Bind Thumbnail}"
                                                                 IsBlurred="{x:Bind IsBlurred, Mode=OneWay}" />
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
                <StackPanel x:Name="ReaderGalleryEmptyState"
                            Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Spacing="12"
                            Visibility="Collapsed">
                    <FontIcon Glyph="&#xE91B;" FontSize="36" />
                    <TextBlock x:Uid="ReaderGalleryEmptyText"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="No images" />
                </StackPanel>

                <Grid x:Name="ReaderImageViewerOverlay"
                      Grid.RowSpan="2"
                      Canvas.ZIndex="10"
                      Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                      Visibility="Collapsed"
                      KeyDown="ReaderImageViewerOverlay_KeyDown"
                      AutomationProperties.AutomationId="NovelReaderImageViewer">
                    <ScrollViewer x:Name="ReaderImageViewerScrollViewer"
                                  HorizontalScrollBarVisibility="Visible"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollBarVisibility="Visible"
                                  VerticalScrollMode="Enabled"
                                  ZoomMode="Enabled"
                                  MinZoomFactor="1"
                                  MaxZoomFactor="5"
                                  DoubleTapped="ReaderImageViewer_DoubleTapped">
                        <Image x:Name="ReaderImageViewerImage"
                               Width="{Binding ViewportWidth, ElementName=ReaderImageViewerScrollViewer}"
                               Height="{Binding ViewportHeight, ElementName=ReaderImageViewerScrollViewer}"
                               Stretch="Uniform" />
                    </ScrollViewer>
                    <Button x:Name="ReaderImageViewerCloseButton"
                            x:Uid="ReaderImageViewerCloseButton"
                            AutomationProperties.AutomationId="NovelReaderImageViewerCloseButton"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="16"
                            Click="ReaderImageViewerCloseButton_Click">
                        <FontIcon Glyph="&#xE711;" />
                    </Button>
                </Grid>
            </Grid>
        </ContentDialog>

        <ContentDialog x:Name="ReaderStatisticsPanelDialog"
                       x:Uid="ReaderStatisticsPanelDialog"
                       AutomationProperties.AutomationId="NovelReaderStatisticsPanelDialog"
                       MaxWidth="560"
                       CloseButtonText="Close"
                       DefaultButton="Close">
            <ContentDialog.Resources>
                <x:Double x:Key="ContentDialogMaxWidth">560</x:Double>
            </ContentDialog.Resources>
            <controls:ReaderStatisticsPanelContent
                MaxWidth="520"
                HorizontalAlignment="Stretch"
                DataContext="{x:Bind ViewModel, Mode=OneWay}" />
        </ContentDialog>

        <ContentDialog x:Name="ReaderAppearancePanelDialog"
                       x:Uid="ReaderAppearancePanelDialog"
                       AutomationProperties.AutomationId="NovelReaderAppearancePanelDialog"
                       MinWidth="1280"
                       MaxWidth="1600"
                       CloseButtonText="Close"
                       DefaultButton="Close">
            <ContentDialog.Resources>
                <x:Double x:Key="ContentDialogMaxWidth">1600</x:Double>
                <x:Double x:Key="ContentDialogMinWidth">1280</x:Double>
            </ContentDialog.Resources>
            <controls:ReaderAppearanceSettingsContent Width="1280"
                                                      Height="620" />
        </ContentDialog>

        <Grid Grid.Row="2"
              x:Name="ReaderBottomChrome"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
              RowDefinitions="Auto,Auto"
              Visibility="Collapsed">
            <Grid Grid.Row="0"
                  Padding="12,4"
                  ColumnDefinitions="*,Auto,*">
                <Button Grid.Column="0"
                        x:Name="NovelReaderHistoryBackButton"
                        AutomationProperties.AutomationId="NovelReaderHistoryBackButton"
                        HorizontalAlignment="Left"
                        Click="HistoryBackButton_Click"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7A7;" FontSize="14" />
                        <TextBlock x:Name="NovelReaderHistoryBackText" />
                    </StackPanel>
                </Button>

                <TextBlock Grid.Column="1"
                           x:Name="NovelReaderBottomProgressText"
                           AutomationProperties.AutomationId="NovelReaderBottomProgressText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Padding="16,6"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Visibility="Collapsed" />

                <Button Grid.Column="2"
                        x:Name="NovelReaderHistoryForwardButton"
                        AutomationProperties.AutomationId="NovelReaderHistoryForwardButton"
                        HorizontalAlignment="Right"
                        Click="HistoryForwardButton_Click"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock x:Name="NovelReaderHistoryForwardText" />
                        <FontIcon Glyph="&#xE7A6;" FontSize="14" />
                    </StackPanel>
                </Button>
            </Grid>

        </Grid>

        <ContentDialog x:Name="SasayakiPanelDialog"
                       x:Uid="NovelReaderSasayakiPanelDialog"
                       AutomationProperties.AutomationId="NovelReaderSasayakiPanelDialog"
                       MinWidth="1120"
                       MaxWidth="1600"
                       CloseButtonText="Close"
                       DefaultButton="Close">
            <ContentDialog.Resources>
                <x:Double x:Key="ContentDialogMaxWidth">1600</x:Double>
                <x:Double x:Key="ContentDialogMinWidth">1120</x:Double>
            </ContentDialog.Resources>
            <ScrollViewer MaxHeight="640"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Width="1120"
                            MaxWidth="1120"
                            DataContext="{x:Bind SasayakiPanelViewModel}"
                            Spacing="20">
                    <StackPanel x:Name="SasayakiPanelAudioSection"
                                AutomationProperties.AutomationId="NovelReaderSasayakiAudioSection"
                                Spacing="12">
                        <TextBlock x:Uid="NovelReaderSasayakiAudioSectionHeader"
                                   FontWeight="SemiBold"
                                   Text="Audio" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding PositionText, Mode=OneWay}" />
                                    <TextBlock Text="/" />
                                    <TextBlock Text="{Binding DurationText, Mode=OneWay}" />
                                </StackPanel>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           MaxLines="2"
                                           Text="{Binding CurrentCueText, Mode=OneWay}"
                                           TextWrapping="Wrap" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Text="{Binding SasayakiStatusText, Mode=OneWay}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="SasayakiPanelLoadAudioButton"
                                    x:Uid="NovelReaderSasayakiPanelLoadAudioButton"
                                    AutomationProperties.AutomationId="NovelReaderSasayakiPanelLoadAudioButton"
                                    Click="SasayakiLoadButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8A5;" />
                                    <TextBlock x:Uid="NovelReaderSasayakiPanelLoadAudioText"
                                               Text="Load Audio" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                            <Button x:Name="SasayakiPanelSkipBackButton"
                                    x:Uid="NovelReaderSasayakiPanelSkipBackButton"
                                    AutomationProperties.AutomationId="NovelReaderSasayakiPanelSkipBackButton"
                                    Click="SasayakiSkipBack_Click">
                                <FontIcon Glyph="&#xE7A7;" />
                            </Button>
                            <Button x:Name="SasayakiPanelPreviousCueButton"
                                    x:Uid="NovelReaderSasayakiPanelPreviousCueButton"
                                    AutomationProperties.AutomationId="NovelReaderSasayakiPanelPreviousCueButton"
                                    Click="SasayakiPrevCue_Click">
                                <FontIcon Glyph="&#xE892;" />
                            </Button>
                            <Button x:Name="SasayakiPanelPlayPauseButton"
                                    x:Uid="NovelReaderSasayakiPanelPlayPauseButton"
                                    AutomationProperties.AutomationId="NovelReaderSasayakiPanelPlayPauseButton"
                                    Click="SasayakiPlayPause_Click">
                                <FontIcon x:Name="SasayakiPanelPlayPauseIcon" Glyph="&#xE768;" />
                            </Button>
                            <Button x:Name="SasayakiPanelNextCueButton"
                                    x:Uid="NovelReaderSasayakiPanelNextCueButton"
                                    AutomationProperties.AutomationId="NovelReaderSasayakiPanelNextCueButton"
                                    Click="SasayakiNextCue_Click">
                                <FontIcon Glyph="&#xE893;" />
                            </Button>
                            <Button x:Name="SasayakiPanelSkipForwardButton"
                                    x:Uid="NovelReaderSasayakiPanelSkipForwardButton"
                                    AutomationProperties.AutomationId="NovelReaderSasayakiPanelSkipForwardButton"
                                    Click="SasayakiSkipForward_Click">
                                <FontIcon Glyph="&#xE7A6;" />
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="SasayakiPanelPlaybackSection"
                                AutomationProperties.AutomationId="NovelReaderSasayakiPlaybackSection"
                                Spacing="12">
                        <TextBlock x:Uid="NovelReaderSasayakiPlaybackSectionHeader"
                                   FontWeight="SemiBold"
                                   Text="Playback" />
                        <Grid ColumnDefinitions="120,*,56"
                              ColumnSpacing="12"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="10">
                            <TextBlock x:Uid="NovelReaderSasayakiDelayLabel"
                                       VerticalAlignment="Center"
                                       Text="Delay" />
                            <Slider Grid.Column="1"
                                    x:Name="SasayakiDelaySlider"
                                    AutomationProperties.AutomationId="NovelReaderSasayakiDelaySlider"
                                    Minimum="-2"
                                    Maximum="2"
                                    SmallChange="0.05"
                                    StepFrequency="0.05"
                                    ValueChanged="SasayakiDelaySlider_ValueChanged" />
                            <TextBlock Grid.Column="2"
                                       x:Name="SasayakiDelayValueText"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right"
                                       Text="0.00s" />

                            <TextBlock Grid.Row="1"
                                       x:Uid="NovelReaderSasayakiSpeedLabel"
                                       VerticalAlignment="Center"
                                       Text="Speed" />
                            <Slider Grid.Row="1"
                                    Grid.Column="1"
                                    x:Name="SasayakiSpeedSlider"
                                    AutomationProperties.AutomationId="NovelReaderSasayakiSpeedSlider"
                                    Minimum="0.5"
                                    Maximum="1.5"
                                    SmallChange="0.05"
                                    StepFrequency="0.05"
                                    ValueChanged="SasayakiSpeedSlider_ValueChanged" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="2"
                                       x:Name="SasayakiSpeedValueText"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right"
                                       Text="1.00x" />
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="SasayakiPanelSettingsSection"
                                AutomationProperties.AutomationId="NovelReaderSasayakiSettingsSection"
                                Spacing="12">
                        <TextBlock x:Uid="NovelReaderSasayakiSettingsSectionHeader"
                                   FontWeight="SemiBold"
                                   Text="Settings" />
                        <ToggleSwitch x:Name="SasayakiPanelShowToggleSwitch"
                                      x:Uid="NovelReaderSasayakiShowToggleSwitch"
                                      AutomationProperties.AutomationId="NovelReaderSasayakiShowToggleSwitch"
                                      Header="Show Sasayaki"
                                      Toggled="SasayakiPanelShowToggleSwitch_Toggled" />
                        <ToggleSwitch x:Name="SasayakiPanelAutoScrollToggleSwitch"
                                      x:Uid="NovelReaderSasayakiAutoScrollToggleSwitch"
                                      AutomationProperties.AutomationId="NovelReaderSasayakiAutoScrollToggleSwitch"
                                      Header="Auto-Scroll"
                                      Toggled="SasayakiPanelAutoScrollToggleSwitch_Toggled" />
                        <ToggleSwitch x:Name="SasayakiPanelAutoPauseToggleSwitch"
                                      x:Uid="NovelReaderSasayakiAutoPauseToggleSwitch"
                                      AutomationProperties.AutomationId="NovelReaderSasayakiAutoPauseToggleSwitch"
                                      Header="Auto-Pause"
                                      Toggled="SasayakiPanelAutoPauseToggleSwitch_Toggled" />
                    </StackPanel>

                    <StackPanel x:Name="SasayakiPanelThemeSection"
                                AutomationProperties.AutomationId="NovelReaderSasayakiThemeSection"
                                Spacing="12">
                        <TextBlock x:Uid="NovelReaderSasayakiThemeSectionHeader"
                                   FontWeight="SemiBold"
                                   Text="Theme" />
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="16"
                              RowDefinitions="Auto,Auto">
                            <StackPanel Spacing="8">
                                <TextBlock x:Uid="NovelReaderSasayakiLightTextColorLabel"
                                           Text="Light Text" />
                                <controls:CompactColorPicker x:Name="SasayakiPanelLightTextColorPicker"
                                                             AutomationProperties.AutomationId="NovelReaderSasayakiLightTextColorPicker"
                                                             IsAlphaEnabled="True"
                                                             ColorChanged="SasayakiPanelLightTextColorPicker_ColorChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock x:Uid="NovelReaderSasayakiLightBackgroundColorLabel"
                                           Text="Light Background" />
                                <controls:CompactColorPicker x:Name="SasayakiPanelLightBackgroundColorPicker"
                                                             AutomationProperties.AutomationId="NovelReaderSasayakiLightBackgroundColorPicker"
                                                             IsAlphaEnabled="True"
                                                             ColorChanged="SasayakiPanelLightBackgroundColorPicker_ColorChanged" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Spacing="8">
                                <TextBlock x:Uid="NovelReaderSasayakiDarkTextColorLabel"
                                           Text="Dark Text" />
                                <controls:CompactColorPicker x:Name="SasayakiPanelDarkTextColorPicker"
                                                             AutomationProperties.AutomationId="NovelReaderSasayakiDarkTextColorPicker"
                                                             IsAlphaEnabled="True"
                                                             ColorChanged="SasayakiPanelDarkTextColorPicker_ColorChanged" />
                            </StackPanel>
                            <StackPanel Grid.Row="1"
                                        Grid.Column="1"
                                        Spacing="8">
                                <TextBlock x:Uid="NovelReaderSasayakiDarkBackgroundColorLabel"
                                           Text="Dark Background" />
                                <controls:CompactColorPicker x:Name="SasayakiPanelDarkBackgroundColorPicker"
                                                             AutomationProperties.AutomationId="NovelReaderSasayakiDarkBackgroundColorPicker"
                                                             IsAlphaEnabled="True"
                                                             ColorChanged="SasayakiPanelDarkBackgroundColorPicker_ColorChanged" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </ContentDialog>
    </Grid>
</Page>
