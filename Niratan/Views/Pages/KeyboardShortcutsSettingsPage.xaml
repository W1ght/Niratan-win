<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Niratan.Views.Pages.KeyboardShortcutsSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="using:Niratan.ViewModels.Pages"
      mc:Ignorable="d">

    <Grid x:Name="KeyboardShortcutsRoot"
          RowDefinitions="Auto,*"
          IsTabStop="True"
          KeyDown="KeyboardShortcutsRoot_KeyDown">
        <StackPanel Padding="20,14,36,16"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
            <Button x:Name="KeyboardShortcutsBackButton"
                    x:Uid="KeyboardShortcutsBackButton"
                    Width="36"
                    Height="36"
                    Padding="0"
                    AutomationProperties.AutomationId="KeyboardShortcutsBackButton"
                    Click="BackButton_Click">
                <FontIcon Glyph="&#xE72B;" />
            </Button>
            <FontIcon FontSize="24" Glyph="&#xE765;" />
            <StackPanel>
                <TextBlock x:Uid="KeyboardShortcutsPageTitle"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Text="Keyboard Shortcuts" />
                <TextBlock Text="{x:Bind ViewModel.RecordingHintText, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="16,0,16,24">
                <ItemsRepeater MaxWidth="1280"
                               HorizontalAlignment="Stretch"
                               AutomationProperties.AutomationId="KeyboardShortcutSections"
                               ItemsSource="{x:Bind ViewModel.Sections, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="20" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:ShortcutSectionViewModel">
                            <StackPanel Spacing="6">
                                <TextBlock Margin="2,0,0,0"
                                           Text="{x:Bind Title, Mode=OneWay}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ItemsRepeater ItemsSource="{x:Bind Rows, Mode=OneWay}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout />
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ShortcutRowViewModel">
                                                <Grid MinHeight="64"
                                                      ColumnDefinitions="*,Auto,Auto"
                                                      ColumnSpacing="12"
                                                      Padding="16,10">
                                                    <Grid.Resources>
                                                        <Style TargetType="Button">
                                                            <Setter Property="VerticalAlignment" Value="Center" />
                                                        </Style>
                                                    </Grid.Resources>
                                                    <StackPanel VerticalAlignment="Center" Spacing="2">
                                                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                                                   Style="{StaticResource BodyTextBlockStyle}" />
                                                        <TextBlock Text="{x:Bind DefaultShortcutText, Mode=OneWay}"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock Text="{x:Bind ConflictText, Mode=OneWay}"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            MinWidth="108"
                                                            HorizontalAlignment="Right"
                                                            AutomationProperties.AutomationId="ShortcutRecordButton"
                                                            Click="RecordShortcutButton_Click"
                                                            Content="{x:Bind ShortcutButtonLabel, Mode=OneWay}" />
                                                    <Button Grid.Column="2"
                                                            x:Uid="KeyboardShortcutResetButton"
                                                            AutomationProperties.AutomationId="ShortcutResetButton"
                                                            Click="ResetShortcutButton_Click"
                                                            Content="Reset"
                                                            IsEnabled="{x:Bind CanReset, Mode=OneWay}" />
                                                    <Border Grid.ColumnSpan="3"
                                                            Margin="0,0,0,-10"
                                                            VerticalAlignment="Bottom"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            IsHitTestVisible="False" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
