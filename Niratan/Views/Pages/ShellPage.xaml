<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Niratan.Views.Pages.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:Niratan.Helpers.UI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:Niratan.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:models="using:Niratan.Models"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:NotificationSeverityToInfoBarSeverityConverter x:Key="SeverityConverter" />
    </Page.Resources>

    <Grid>
        <Frame x:Name="ShellFrame" SourcePageType="local:NavigationPage" />

        <ItemsControl Width="360"
                      Margin="0,0,0,20"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Bottom"
                      ItemsSource="{x:Bind ViewModel.Notifications, Mode=OneWay}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:NotificationModel">
                    <InfoBar Title="{x:Bind Title}"
                             Margin="0,0,0,10"
                             IsOpen="{x:Bind IsActive, Mode=TwoWay}"
                             Message="{x:Bind Message}"
                             Severity="{x:Bind Severity, Converter={StaticResource SeverityConverter}}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>
