<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Niratan.Views.Pages.AboutSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:converters="using:Niratan.Helpers.UI.Converters"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid RowDefinitions="Auto,*">
        <StackPanel Padding="20,14,36,16"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
            <FontIcon FontSize="24" Glyph="&#xE946;" />
            <TextBlock x:Uid="AboutSettingsPageTitle"
                       VerticalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="About" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="16,0,16,16">
                <StackPanel MaxWidth="1280"
                            HorizontalAlignment="Stretch"
                            Spacing="4">
                    <toolkit:SettingsExpander x:Uid="SettingsAboutExpander"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch"
                                              Header="Niratan"
                                              HeaderIcon="{ui:BitmapIcon Source=ms-appx:///Assets/Square44x44Logo.altform-lightunplated_targetsize-32.png}">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsTextSelectionEnabled="True">
                            <Run x:Uid="SettingsAboutVersionRun" Text="Version" />
                            <Run Text="{x:Bind ViewModel.NiratanVersion, Mode=OneTime}" />
                        </TextBlock>
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                                <StackPanel Margin="-12,0,0,0" Orientation="Vertical">
                                    <HyperlinkButton x:Uid="SettingsProjectRepositoryLink"
                                                     Content="Project Repository"
                                                     NavigateUri="https://github.com/W1ght/Niratan-win" />
                                    <HyperlinkButton x:Uid="SettingsSendFeedbackLink"
                                                     Content="Send Feedback"
                                                     NavigateUri="https://github.com/W1ght/Niratan-win/issues" />
                                </StackPanel>
                            </toolkit:SettingsCard>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>

                    <toolkit:SettingsCard x:Uid="AppUpdateCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Description="{x:Bind ViewModel.UpdateStatusText, Mode=OneWay}"
                                          Header="Updates"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE895;}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ProgressRing Width="20"
                                          Height="20"
                                          IsActive="{x:Bind ViewModel.IsCheckingForUpdates, Mode=OneWay}"
                                          Visibility="{x:Bind ViewModel.IsCheckingForUpdates, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button x:Uid="AppUpdateCheckButton"
                                    AutomationProperties.AutomationId="AppUpdateCheckButton"
                                    Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                    Content="Check for updates" />
                            <Button x:Uid="AppUpdateOpenButton"
                                    AutomationProperties.AutomationId="AppUpdateOpenButton"
                                    Command="{x:Bind ViewModel.OpenUpdateCommand}"
                                    Content="View update"
                                    Visibility="{x:Bind ViewModel.HasAvailableUpdate, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </toolkit:SettingsCard>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
