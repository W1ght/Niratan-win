<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Niratan.Views.Pages.VideoLibraryPage"
      x:Name="ThisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:Niratan.Helpers.UI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:pages="using:Niratan.ViewModels.Pages"
      xmlns:vmc="using:Niratan.ViewModels.Components"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate x:Key="FolderFilterTemplate" x:DataType="pages:VideoLibraryFilterRow">
            <Button Width="220"
                    Margin="0,0,8,6"
                    Padding="10,8"
                    HorizontalContentAlignment="Stretch"
                    Command="{Binding ViewModel.SelectFolderFilterCommand, ElementName=ThisPage}"
                    CommandParameter="{x:Bind}">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <FontIcon Glyph="&#xE8B7;"
                              VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1"
                                Spacing="2">
                        <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind MetadataText, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="CollectionFilterTemplate" x:DataType="pages:VideoLibraryFilterRow">
            <Button Width="220"
                    Margin="0,0,8,6"
                    Padding="10,8"
                    HorizontalContentAlignment="Stretch"
                    Command="{Binding ViewModel.SelectCollectionFilterCommand, ElementName=ThisPage}"
                    CommandParameter="{x:Bind}">
                <Button.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Edit smart collection"
                                        Click="EditSmartCollectionMenuItem_Click" />
                        <MenuFlyoutItem Text="Delete collection"
                                        Command="{Binding ViewModel.DeleteCollectionCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                    </MenuFlyout>
                </Button.ContextFlyout>
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <FontIcon Glyph="&#xE8F1;"
                              VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1"
                                Spacing="2">
                        <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind MetadataText, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="TagFilterTemplate" x:DataType="pages:VideoLibraryFilterRow">
            <Button Width="180"
                    Margin="0,0,8,6"
                    Padding="10,8"
                    HorizontalContentAlignment="Stretch"
                    Command="{Binding ViewModel.SelectTagFilterCommand, ElementName=ThisPage}"
                    CommandParameter="{x:Bind}">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <FontIcon Glyph="&#xE8EC;"
                              VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1"
                                Spacing="2">
                        <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind MetadataText, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="VideoListItemTemplate" x:DataType="vmc:VideoItemViewModel">
            <Grid>
            <Button Padding="0"
                    HorizontalContentAlignment="Stretch"
                    AutomationProperties.AutomationId="{x:Bind AutomationId, Mode=OneTime}"
                    AutomationProperties.Name="{x:Bind Video.Title, Mode=OneTime}"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="VideoButton_Click">
                <Button.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="VideoLibraryPlayMenuItem"
                                        Text="Play"
                                        Command="{Binding ViewModel.OpenVideoCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryPlayFromBeginningMenuItem"
                                        Text="Play from beginning"
                                        Command="{Binding ViewModel.OpenVideoFromBeginningCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem Text="Details"
                                        Command="{Binding ViewModel.SelectVideoDetailsCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Uid="VideoLibraryAddFavoriteMenuItem"
                                        Text="Add to favorites"
                                        Visibility="{x:Bind Video.IsFavorite, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"
                                        Command="{Binding ViewModel.ToggleFavoriteCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryRemoveFavoriteMenuItem"
                                        Text="Remove from favorites"
                                        Visibility="{x:Bind Video.IsFavorite, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Command="{Binding ViewModel.ToggleFavoriteCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryMarkWatchedMenuItem"
                                        Text="Mark watched"
                                        Command="{Binding ViewModel.MarkWatchedCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryClearProgressMenuItem"
                                        Text="Clear progress"
                                        Command="{Binding ViewModel.ClearProgressCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryRevealFileMenuItem"
                                        Text="Reveal file"
                                        Visibility="{x:Bind Video.IsRemote, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"
                                        Command="{Binding ViewModel.RevealFileCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryAddToNewCollectionMenuItem"
                                        Text="Add to new collection"
                                        Command="{Binding ViewModel.AddToNewCollectionCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Uid="VideoLibraryDeleteMenuItem"
                                        Text="Delete"
                                        Command="{Binding ViewModel.DeleteVideoCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                    </MenuFlyout>
                </Button.ContextFlyout>
                <Grid Height="96"
                      ColumnDefinitions="144,*"
                      ColumnSpacing="14"
                      Padding="10,8">
                    <Border Width="144"
                            Height="81"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid>
                            <Image Source="{x:Bind ArtworkImage, Mode=OneTime}"
                                   Stretch="UniformToFill"
                                   Visibility="{x:Bind HasArtwork, Mode=OneTime, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <FontIcon Glyph="&#xE714;"
                                      Opacity="0.35"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="{x:Bind HasArtwork, Mode=OneTime, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />
                        </Grid>
                    </Border>
                    <Grid Grid.Column="1"
                          RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="6">
                        <TextBlock Text="{x:Bind Video.Title, Mode=OneTime}"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="1"
                                   Text="{x:Bind ListMetadataText, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Grid Grid.Row="2"
                              ColumnDefinitions="120,Auto"
                              ColumnSpacing="10">
                            <ProgressBar Height="4"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{x:Bind OverallProgressPercent, Mode=OneWay}" />
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind RemainingText, Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                    </Grid>
                </Grid>
            </Button>
                <CheckBox Margin="6"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          IsChecked="{x:Bind IsSelected, Mode=OneWay}"
                          Command="{Binding ViewModel.ToggleVideoSelectionCommand, ElementName=ThisPage}"
                          CommandParameter="{x:Bind}"
                          AutomationProperties.Name="Select video" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="VideoPosterItemTemplate" x:DataType="vmc:VideoItemViewModel">
            <Grid>
            <Button Width="220"
                    Padding="0"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    AutomationProperties.AutomationId="{x:Bind AutomationId, Mode=OneTime}"
                    AutomationProperties.Name="{x:Bind Video.Title, Mode=OneTime}"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="VideoButton_Click">
                <Button.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="VideoLibraryPlayMenuItem"
                                        Text="Play"
                                        Command="{Binding ViewModel.OpenVideoCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryPlayFromBeginningMenuItem"
                                        Text="Play from beginning"
                                        Command="{Binding ViewModel.OpenVideoFromBeginningCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem Text="Details"
                                        Command="{Binding ViewModel.SelectVideoDetailsCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Uid="VideoLibraryAddFavoriteMenuItem"
                                        Text="Add to favorites"
                                        Visibility="{x:Bind Video.IsFavorite, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"
                                        Command="{Binding ViewModel.ToggleFavoriteCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryRemoveFavoriteMenuItem"
                                        Text="Remove from favorites"
                                        Visibility="{x:Bind Video.IsFavorite, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Command="{Binding ViewModel.ToggleFavoriteCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryMarkWatchedMenuItem"
                                        Text="Mark watched"
                                        Command="{Binding ViewModel.MarkWatchedCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryClearProgressMenuItem"
                                        Text="Clear progress"
                                        Command="{Binding ViewModel.ClearProgressCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryRevealFileMenuItem"
                                        Text="Reveal file"
                                        Visibility="{x:Bind Video.IsRemote, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"
                                        Command="{Binding ViewModel.RevealFileCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="VideoLibraryAddToNewCollectionMenuItem"
                                        Text="Add to new collection"
                                        Command="{Binding ViewModel.AddToNewCollectionCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Uid="VideoLibraryDeleteMenuItem"
                                        Text="Delete"
                                        Command="{Binding ViewModel.DeleteVideoCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}" />
                    </MenuFlyout>
                </Button.ContextFlyout>
                <StackPanel Spacing="8">
                    <Border Height="124"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8">
                        <Grid>
                            <Image Stretch="UniformToFill"
                                   Source="{x:Bind ArtworkImage, Mode=OneTime}"
                                   Visibility="{x:Bind HasArtwork, Mode=OneTime, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <FontIcon FontSize="44"
                                      Glyph="&#xE714;"
                                      Opacity="0.35"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="{x:Bind HasArtwork, Mode=OneTime, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="5">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <ProgressBar Height="4"
                                         Minimum="0"
                                         Maximum="100"
                                         VerticalAlignment="Center"
                                         Value="{x:Bind OverallProgressPercent, Mode=OneWay}" />
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ProgressText, Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <TextBlock x:Name="VideoPosterTitleText"
                                   Text="{x:Bind Video.Title, Mode=OneTime}"
                                   TextWrapping="WrapWholeWords"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="2"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind FolderName, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind WatchStatusText, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Button>
                <CheckBox Margin="6"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          IsChecked="{x:Bind IsSelected, Mode=OneWay}"
                          Command="{Binding ViewModel.ToggleVideoSelectionCommand, ElementName=ThisPage}"
                          CommandParameter="{x:Bind}"
                          AutomationProperties.Name="Select video" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <NavigationView x:Name="VideoLibrarySecondaryNavigationView"
                        x:Uid="VideoLibrarySecondaryNavigationView"
                        AlwaysShowHeader="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        IsSettingsVisible="False"
                        ItemInvoked="VideoLibrarySecondaryNavigationView_ItemInvoked"
                        OpenPaneLength="248"
                        PaneDisplayMode="Left"
                        PaneTitle="Videos">
            <NavigationView.Resources>
                <Thickness x:Key="NavigationViewContentMargin">0</Thickness>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">1,0,0,0</Thickness>
                <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>
            </NavigationView.Resources>

            <NavigationView.MenuItems>
                <NavigationViewItemHeader x:Uid="VideoLibrarySectionHeader"
                                          Content="Library" />
                <NavigationViewItem x:Name="VideoLibraryAllNavItem"
                                    x:Uid="VideoLibraryAllNavItem"
                                    AutomationProperties.AutomationId="VideoLibraryAllNavItem"
                                    Content="All Videos"
                                    Tag="All">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE714;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="VideoLibraryContinueWatchingNavItem"
                                    x:Uid="VideoLibraryContinueWatchingNavItem"
                                    AutomationProperties.AutomationId="VideoLibraryContinueWatchingNavItem"
                                    Content="Continue Watching"
                                    Tag="ContinueWatching">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE768;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="VideoLibraryUnwatchedNavItem"
                                    x:Uid="VideoLibraryUnwatchedNavItem"
                                    AutomationProperties.AutomationId="VideoLibraryUnwatchedNavItem"
                                    Content="Unwatched"
                                    Tag="Unwatched">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="VideoLibraryFinishedNavItem"
                                    x:Uid="VideoLibraryFinishedNavItem"
                                    AutomationProperties.AutomationId="VideoLibraryFinishedNavItem"
                                    Content="Finished"
                                    Tag="Finished">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE930;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="VideoLibraryRecentNavItem"
                                    x:Uid="VideoLibraryRecentNavItem"
                                    AutomationProperties.AutomationId="VideoLibraryRecentNavItem"
                                    Content="Recent"
                                    Tag="Recent">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE823;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="VideoLibraryNeedsReviewNavItem"
                                    x:Uid="VideoLibraryNeedsReviewNavItem"
                                    AutomationProperties.AutomationId="VideoLibraryNeedsReviewNavItem"
                                    Content="Needs Review"
                                    Tag="NeedsReview">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7BA;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="VideoLibraryFavoritesNavItem"
                                    x:Uid="VideoLibraryFavoritesNavItem"
                                    AutomationProperties.AutomationId="VideoLibraryFavoritesNavItem"
                                    Content="Favorites"
                                    Tag="Favorites">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="VideoLibrarySeriesNavItem"
                                    x:Uid="VideoLibrarySeriesNavItem"
                                    AutomationProperties.AutomationId="VideoLibrarySeriesNavItem"
                                    Content="Series"
                                    Tag="Series">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemHeader x:Uid="VideoLibraryOrganizeSectionHeader"
                                          Content="Organize" />
                <NavigationViewItem x:Name="VideoLibraryFoldersNavItem"
                                    x:Uid="VideoLibraryFoldersNavItem"
                                    AutomationProperties.AutomationId="VideoLibraryFoldersNavItem"
                                    Content="Folders"
                                    Tag="Folders">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="VideoLibraryCollectionsNavItem"
                                    x:Uid="VideoLibraryCollectionsNavItem"
                                    AutomationProperties.AutomationId="VideoLibraryCollectionsNavItem"
                                    Content="Collections"
                                    Tag="Collections">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="VideoLibraryTagsNavItem"
                                    x:Uid="VideoLibraryTagsNavItem"
                                    AutomationProperties.AutomationId="VideoLibraryTagsNavItem"
                                    Content="Tags"
                                    Tag="Tags">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8EC;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0"
                      Padding="20,14,28,16"
                      RowDefinitions="Auto,Auto"
                      ColumnDefinitions="*,156,112,Auto"
                      ColumnSpacing="12">
                    <StackPanel Grid.ColumnSpan="4"
                                Margin="0,0,0,12"
                                VerticalAlignment="Center"
                                Spacing="2">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <FontIcon FontSize="24" Glyph="&#xE714;" />
                            <TextBlock Text="{x:Bind ViewModel.CurrentViewTitle, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource TitleTextBlockStyle}" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.CurrentViewSubtitle, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             x:Name="VideoLibrarySearchBox"
                             x:Uid="VideoLibrarySearchBox"
                             AutomationProperties.AutomationId="VideoLibrarySearchBox"
                             PlaceholderText="Search videos"
                             VerticalAlignment="Center"
                             Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox Grid.Row="1"
                              Grid.Column="1"
                              x:Name="VideoLibrarySortComboBox"
                              x:Uid="VideoLibrarySortComboBox"
                              AutomationProperties.AutomationId="VideoLibrarySortComboBox"
                              AutomationProperties.Name="Sort videos"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{x:Bind ViewModel.SortOptions, Mode=OneWay}"
                              SelectedValue="{x:Bind ViewModel.SelectedSortOption, Mode=TwoWay}"
                              SelectedValuePath="Value"
                              VerticalAlignment="Center" />

                    <Grid x:Name="VideoLibraryLayoutSegment"
                          AutomationProperties.AutomationId="VideoLibraryLayoutSegment"
                          Grid.Row="1"
                          Grid.Column="2"
                          Height="36"
                          ColumnDefinitions="*,*">
                        <ToggleButton x:Uid="VideoLibraryLayoutList"
                                      IsChecked="{x:Bind ViewModel.IsListLayout, Mode=OneWay}"
                                      Command="{x:Bind ViewModel.SelectLayoutCommand}"
                                      CommandParameter="List">
                            <FontIcon Glyph="&#xE8FD;" />
                        </ToggleButton>
                        <ToggleButton x:Uid="VideoLibraryLayoutPosters"
                                      Grid.Column="1"
                                      IsChecked="{x:Bind ViewModel.IsPosterLayout, Mode=OneWay}"
                                      Command="{x:Bind ViewModel.SelectLayoutCommand}"
                                      CommandParameter="Posters">
                            <FontIcon Glyph="&#xECA5;" />
                        </ToggleButton>
                    </Grid>

                    <CommandBar Grid.Row="1"
                                Grid.Column="3"
                                DefaultLabelPosition="Collapsed"
                                VerticalAlignment="Center">
                        <AppBarButton Label="Refresh sources"
                                      AutomationProperties.AutomationId="RefreshVideoSourcesButton"
                                      IsEnabled="{x:Bind ViewModel.HasSources, Mode=OneWay}"
                                      Command="{x:Bind ViewModel.RefreshAllSourcesCommand}">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE72C;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton Label="Manage sources"
                                      AutomationProperties.AutomationId="ManageVideoSourcesButton"
                                      IsEnabled="{x:Bind ViewModel.HasSources, Mode=OneWay}"
                                      Click="ManageVideoSourcesButton_Click">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE713;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="ScanVideoFolderButton"
                                      x:Uid="ScanVideoFolderButton"
                                      AutomationProperties.AutomationId="ScanVideoFolderButton"
                                      Command="{x:Bind ViewModel.ScanFolderCommand}"
                                      Label="Scan folder">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE8B7;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="ImportVideoButton"
                                      x:Uid="ImportVideoButton"
                                      AutomationProperties.AutomationId="ImportVideoButton"
                                      Command="{x:Bind ViewModel.ImportVideoCommand}"
                                      Label="Import video">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE8E5;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="AddYouTubeLinkButton"
                                      x:Uid="AddYouTubeLinkButton"
                                      AutomationProperties.AutomationId="AddYouTubeLinkButton"
                                      Click="AddYouTubeLinkButton_Click"
                                      Label="Add link">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE71B;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Name="CreateSmartCollectionButton"
                                      x:Uid="CreateSmartCollectionButton"
                                      AutomationProperties.AutomationId="CreateSmartCollectionButton"
                                      Click="CreateSmartCollectionButton_Click"
                                      Label="Create smart collection">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE710;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar>
                </Grid>

                <ProgressRing Grid.Row="1"
                              Width="60"
                              Height="60"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              IsActive="{x:Bind ViewModel.IsContentLoading, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsContentLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                <TextBlock Grid.Row="1"
                           x:Uid="NoVideosText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Style="{StaticResource BodyLargeStrongTextBlockStyle}"
                           Text="No videos."
                           Visibility="{x:Bind ViewModel.NoVideos, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                <Grid Grid.Row="1"
                      RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0"
                                Margin="20,0,28,4"
                                Spacing="8">
                        <ItemsControl x:Name="VideoLibraryFolderFilters"
                                      AutomationProperties.AutomationId="VideoLibraryFolderFilters"
                                      ItemTemplate="{StaticResource FolderFilterTemplate}"
                                      ItemsSource="{x:Bind ViewModel.FolderFilters, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsFoldersView, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal"
                                                   ItemWidth="228" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl x:Name="VideoLibraryCollectionFilters"
                                      AutomationProperties.AutomationId="VideoLibraryCollectionFilters"
                                      ItemTemplate="{StaticResource CollectionFilterTemplate}"
                                      ItemsSource="{x:Bind ViewModel.CollectionFilters, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsCollectionsView, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal"
                                                   ItemWidth="228" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl x:Name="VideoLibraryTagFilters"
                                      AutomationProperties.AutomationId="VideoLibraryTagFilters"
                                      ItemTemplate="{StaticResource TagFilterTemplate}"
                                      ItemsSource="{x:Bind ViewModel.TagFilters, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsTagsView, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal"
                                                   ItemWidth="188" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="20,0,28,0"
                          ColumnDefinitions="*,340"
                          ColumnSpacing="16">
                        <Grid RowDefinitions="Auto,*">
                            <CommandBar Grid.Row="0"
                                        Margin="0,0,0,8"
                                        Visibility="{x:Bind ViewModel.HasSelection, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                <AppBarButton Label="Mark selected watched"
                                              Command="{x:Bind ViewModel.MarkSelectedWatchedCommand}">
                                    <AppBarButton.Icon><SymbolIcon Symbol="Accept" /></AppBarButton.Icon>
                                </AppBarButton>
                                <AppBarButton Label="Clear selected progress"
                                              Command="{x:Bind ViewModel.ClearSelectedProgressCommand}">
                                    <AppBarButton.Icon><SymbolIcon Symbol="Clear" /></AppBarButton.Icon>
                                </AppBarButton>
                                <AppBarButton Label="Remove selected"
                                              Command="{x:Bind ViewModel.DeleteSelectedVideosCommand}">
                                    <AppBarButton.Icon><SymbolIcon Symbol="Delete" /></AppBarButton.Icon>
                                </AppBarButton>
                                <AppBarButton Label="Remove missing"
                                              Command="{x:Bind ViewModel.RemoveMissingVideosCommand}">
                                    <AppBarButton.Icon><FontIcon Glyph="&#xE74D;" /></AppBarButton.Icon>
                                </AppBarButton>
                            </CommandBar>

                        <ListView Grid.Row="1"
                                  x:Name="VideoLibraryListView"
                                  AutomationProperties.AutomationId="VideoLibraryListView"
                                  ItemTemplate="{StaticResource VideoListItemTemplate}"
                                  ItemsSource="{x:Bind ViewModel.Videos, Mode=OneWay}"
                                  ItemClick="ListView_ItemClick"
                                  IsItemClickEnabled="True"
                                  SelectionMode="None"
                                  Visibility="{x:Bind ViewModel.IsListLayout, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                        <GridView Grid.Row="1"
                                  x:Name="VideoGridView"
                                  AutomationProperties.AutomationId="VideoGridView"
                                  Padding="0,0,16,0"
                                  IsItemClickEnabled="True"
                                  ItemClick="GridView_ItemClick"
                                  ItemTemplate="{StaticResource VideoPosterItemTemplate}"
                                  ItemsSource="{x:Bind ViewModel.Videos, Mode=OneWay}"
                                  SelectionMode="None"
                                  Visibility="{x:Bind ViewModel.IsPosterLayout, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal"
                                                   ItemWidth="220"
                                                   ItemHeight="260" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                        </GridView>
                        </Grid>

                        <Border Grid.Column="1"
                                Padding="16"
                                BorderThickness="1,0,0,0"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Visibility="{x:Bind ViewModel.HasSelectedVideo, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                            <ScrollViewer>
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="Video details" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <Button Grid.Column="1"
                                                Command="{x:Bind ViewModel.CloseVideoDetailsCommand}">
                                            <FontIcon Glyph="&#xE711;" />
                                        </Button>
                                    </Grid>
                                    <TextBox Header="Display title"
                                             Text="{x:Bind ViewModel.SelectedVideoTitleDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Header="Tags"
                                             PlaceholderText="Comma or line separated"
                                             AcceptsReturn="True"
                                             Text="{x:Bind ViewModel.SelectedVideoTagsDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="Save metadata"
                                            HorizontalAlignment="Left"
                                            Command="{x:Bind ViewModel.SaveVideoDetailsCommand}" />

                                    <TextBlock Text="Bound subtitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.SelectedVideoSubtitlePath, Mode=OneWay}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Bind subtitle"
                                                Command="{x:Bind ViewModel.BindSubtitleCommand}" />
                                        <Button Content="Clear"
                                                Command="{x:Bind ViewModel.ClearBoundSubtitleCommand}" />
                                    </StackPanel>

                                    <TextBlock Text="Collections" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.ManualCollectionOptions, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="pages:VideoCollectionMembershipOption">
                                                <CheckBox Content="{x:Bind Collection.Name, Mode=OneWay}"
                                                          IsChecked="{x:Bind IsIncluded, Mode=TwoWay}"
                                                          Command="{Binding ViewModel.SetSelectedCollectionMembershipCommand, ElementName=ThisPage}"
                                                          CommandParameter="{x:Bind}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <TextBox PlaceholderText="New collection"
                                                 Text="{x:Bind ViewModel.ManualCollectionNameDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="1"
                                                Content="Add"
                                                Command="{x:Bind ViewModel.AddSelectedToNewCollectionCommand}" />
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </NavigationView>

        <ContentDialog x:Name="CreateSmartCollectionDialog"
                       Title="{x:Bind ViewModel.SmartCollectionDialogTitle, Mode=OneWay}"
                       FullSizeDesired="False"
                       DefaultButton="None">
            <StackPanel Spacing="16"
                        MinWidth="440">
                <TextBox x:Uid="VideoLibrarySmartCollectionName"
                         Header="Name"
                         PlaceholderText="Smart collection name"
                         Text="{Binding SmartCollectionNameDraft, Mode=TwoWay}" />
                <TextBlock Text="All rules must match" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.SmartRuleDrafts, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="pages:VideoSmartRuleDraft">
                            <Grid ColumnDefinitions="132,112,*,Auto"
                                  ColumnSpacing="8"
                                  Margin="0,0,0,8">
                                <ComboBox DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding ViewModel.AvailableSmartRuleFields, ElementName=ThisPage}"
                                          SelectedValue="{x:Bind Field, Mode=TwoWay}"
                                          SelectedValuePath="Value"
                                          SelectionChanged="SmartRuleEditor_SelectionChanged" />
                                <ComboBox Grid.Column="1"
                                          DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding ViewModel.AvailableSmartRuleMatches, ElementName=ThisPage}"
                                          SelectedValue="{x:Bind Match, Mode=TwoWay}"
                                          SelectedValuePath="Value"
                                          SelectionChanged="SmartRuleEditor_SelectionChanged" />
                                <TextBox Grid.Column="2"
                                         PlaceholderText="Value"
                                         Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="SmartRuleEditor_TextChanged" />
                                <Button Grid.Column="3"
                                        Command="{Binding ViewModel.RemoveSmartRuleCommand, ElementName=ThisPage}"
                                        CommandParameter="{x:Bind}">
                                    <SymbolIcon Symbol="Remove" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="Add rule"
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.AddSmartRuleCommand}" />
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="VideoLibraryPreviewMatches"
                               Text="Preview matches"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ItemsControl ItemsSource="{Binding SmartCollectionPreviewRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vmc:VideoItemViewModel">
                                <TextBlock Text="{Binding Video.Title}"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    <Button x:Uid="VideoLibraryCreateSmartCollectionSecondaryButton"
                            Content="Cancel"
                            Click="CreateSmartCollectionSecondaryButton_Click" />
                    <Button x:Uid="VideoLibraryCreateSmartCollectionPrimaryButton"
                            Content="Create"
                            Command="{x:Bind ViewModel.CreateSmartCollectionCommand}"
                            Click="CreateSmartCollectionPrimaryButton_Click" />
                </StackPanel>
            </StackPanel>
        </ContentDialog>

        <ContentDialog x:Name="ManageVideoSourcesDialog"
                       Title="Manage sources"
                       PrimaryButtonText="Done"
                       DefaultButton="Primary">
            <ListView MinWidth="640"
                      MaxHeight="440"
                      SelectionMode="None"
                      ItemsSource="{x:Bind ViewModel.SourceSummaries, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="pages:VideoLibrarySourceSummary">
                        <Grid Padding="8"
                              ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                              ColumnSpacing="10">
                            <FontIcon Glyph="&#xE8B7;" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="{x:Bind Source.Name, Mode=OneWay}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind Source.FolderPath, Mode=OneWay}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind LastScannedText, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind Source.LastError, Mode=OneWay}"
                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{x:Bind HasError, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Command="{Binding ViewModel.RefreshSourceCommand, ElementName=ThisPage}"
                                    CommandParameter="{x:Bind}"
                                    ToolTipService.ToolTip="Refresh source">
                                <FontIcon Glyph="&#xE72C;" />
                            </Button>
                            <Button Grid.Column="3"
                                    Command="{Binding ViewModel.RevealSourceCommand, ElementName=ThisPage}"
                                    CommandParameter="{x:Bind}"
                                    ToolTipService.ToolTip="Reveal source">
                                <FontIcon Glyph="&#xE8B7;" />
                            </Button>
                            <Button Grid.Column="4"
                                    Command="{Binding ViewModel.RemoveSourceCommand, ElementName=ThisPage}"
                                    CommandParameter="{x:Bind}"
                                    ToolTipService.ToolTip="Remove source">
                                <FontIcon Glyph="&#xE74D;" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ContentDialog>

    </Grid>
</Page>
