<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Niratan.Views.Pages.ProfilesSettingsPage"
      x:Name="ThisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:helpers="using:Niratan.Helpers.UI.Converters"
      xmlns:vm="using:Niratan.ViewModels.Pages"
      mc:Ignorable="d">

    <Page.Resources>
        <helpers:BooleanNegationConverter x:Key="BoolNegationConverter" />
        <Style x:Key="ProfilesSectionHeaderTextBlockStyle" BasedOn="{StaticResource BodyStrongTextBlockStyle}" TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="Auto,*">
        <StackPanel Padding="20,14,36,16"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
            <Button x:Name="ProfilesSettingsBackButton"
                    Width="36"
                    Height="36"
                    Padding="0"
                    AutomationProperties.AutomationId="ProfilesSettingsBackButton"
                    Click="BackButton_Click">
                <FontIcon Glyph="&#xE72B;" />
            </Button>
            <FontIcon FontSize="24" Glyph="&#xE77B;" />
            <TextBlock VerticalAlignment="Center"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="Profiles" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="0,0,16,16">
                <StackPanel MaxWidth="1000" HorizontalAlignment="Stretch" Spacing="4">
                    <toolkit:SettingsCard HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Active Profile"
                                          Description="Used by global lookup and as fallback for content without an override"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE77B;}">
                        <ComboBox MinWidth="260"
                                  AutomationProperties.AutomationId="GlobalActiveProfileComboBox"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                                  SelectedValue="{x:Bind ViewModel.GlobalActiveProfileId, Mode=TwoWay}"
                                  SelectedValuePath="Id" />
                    </toolkit:SettingsCard>

                    <TextBlock Style="{StaticResource ProfilesSectionHeaderTextBlockStyle}"
                               Text="New Profile" />

                    <toolkit:SettingsCard HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Create"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE710;}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Width="240"
                                     AutomationProperties.AutomationId="NewProfileNameTextBox"
                                     PlaceholderText="Name"
                                     Text="{x:Bind ViewModel.NewProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox MinWidth="150"
                                      AutomationProperties.AutomationId="NewProfileLanguageComboBox"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{x:Bind ViewModel.AvailableLanguages}"
                                      SelectedItem="{x:Bind ViewModel.NewProfileLanguage, Mode=TwoWay}" />
                            <Button AutomationProperties.AutomationId="CreateProfileButton"
                                    Command="{x:Bind ViewModel.CreateProfileCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsOperationInProgress, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    <TextBlock Text="Create" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <TextBlock Style="{StaticResource ProfilesSectionHeaderTextBlockStyle}"
                               Text="Book Defaults" />

                    <toolkit:SettingsCard HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Japanese Books"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}">
                        <ComboBox MinWidth="260"
                                  AutomationProperties.AutomationId="JapanesePrimaryProfileComboBox"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{x:Bind ViewModel.JapaneseProfiles, Mode=OneWay}"
                                  SelectedValue="{x:Bind ViewModel.JapanesePrimaryProfileId, Mode=TwoWay}"
                                  SelectedValuePath="Id" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="English Books"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}">
                        <ComboBox MinWidth="260"
                                  AutomationProperties.AutomationId="EnglishPrimaryProfileComboBox"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{x:Bind ViewModel.EnglishProfiles, Mode=OneWay}"
                                  SelectedValue="{x:Bind ViewModel.EnglishPrimaryProfileId, Mode=TwoWay}"
                                  SelectedValuePath="Id" />
                    </toolkit:SettingsCard>

                    <TextBlock Style="{StaticResource ProfilesSectionHeaderTextBlockStyle}"
                               Text="Installed" />

                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />

                    <ListView AutomationProperties.AutomationId="ProfilesListView"
                              ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                              MaxHeight="620"
                              SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Margin" Value="0,4" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProfileOption">
                                <Border MinHeight="76"
                                        Padding="16,10"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                        <FontIcon Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  Glyph="&#xE77B;"
                                                  FontSize="18"
                                                  Opacity="0.65" />
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="2">
                                            <TextBlock FontSize="16"
                                                       Text="{x:Bind Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Text="{x:Bind LanguageDisplayName}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="Use Profile"
                                                Command="{Binding ViewModel.ActivateProfileCommand, ElementName=ThisPage}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE73E;" FontSize="14" />
                                                <TextBlock Text="Use" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
