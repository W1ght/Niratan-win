<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Niratan.Views.Pages.ProfilesSettingsPage"
      x:Name="ThisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:helpers="using:Niratan.Helpers.UI.Converters"
      mc:Ignorable="d">

    <Page.Resources>
        <helpers:BooleanNegationConverter x:Key="BoolNegationConverter" />
        <Style x:Key="ProfilesSectionHeaderTextBlockStyle" BasedOn="{StaticResource BodyStrongTextBlockStyle}" TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="Auto,*">
        <StackPanel Padding="20,14,36,16"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
            <Button x:Name="ProfilesSettingsBackButton"
                    x:Uid="ProfilesSettingsBackButton"
                    Width="36"
                    Height="36"
                    Padding="0"
                    AutomationProperties.AutomationId="ProfilesSettingsBackButton"
                    Click="BackButton_Click">
                <FontIcon Glyph="&#xE72B;" />
            </Button>
            <FontIcon FontSize="24" Glyph="&#xE77B;" />
            <TextBlock VerticalAlignment="Center"
                       x:Uid="ProfilesSettingsPageTitle"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="Profiles" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <Grid Padding="16,0,16,16">
                <StackPanel MaxWidth="1280" HorizontalAlignment="Stretch" Spacing="4">
                    <toolkit:SettingsCard x:Uid="ProfilesActiveProfileCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Active Profile"
                                          Description="Dictionary, Reader appearance and Anki mining settings follow the active profile."
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE77B;}">
                        <ComboBox x:Uid="ProfilesActiveProfileComboBox"
                                  MinWidth="260"
                                  AutomationProperties.AutomationId="GlobalActiveProfileComboBox"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                                  SelectedValue="{x:Bind ViewModel.GlobalActiveProfileId, Mode=TwoWay}"
                                  SelectedValuePath="Id" />
                    </toolkit:SettingsCard>

                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />

                    <TextBlock x:Uid="ProfilesNewProfileSectionHeader"
                               Style="{StaticResource ProfilesSectionHeaderTextBlockStyle}"
                               Text="New Profile" />

                    <toolkit:SettingsCard x:Uid="ProfilesCreateCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Create"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE710;}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox x:Uid="ProfilesNewProfileNameTextBox"
                                     Width="240"
                                     AutomationProperties.AutomationId="NewProfileNameTextBox"
                                     PlaceholderText="Name"
                                     Text="{x:Bind ViewModel.NewProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox x:Uid="ProfilesNewProfileLanguageComboBox"
                                      MinWidth="150"
                                      AutomationProperties.AutomationId="NewProfileLanguageComboBox"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{x:Bind ViewModel.AvailableLanguages}"
                                      SelectedItem="{x:Bind ViewModel.NewProfileLanguage, Mode=TwoWay}" />
                            <Button x:Uid="ProfilesCreateProfileButton"
                                    AutomationProperties.AutomationId="CreateProfileButton"
                                    Command="{x:Bind ViewModel.CreateProfileCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsOperationInProgress, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    <TextBlock x:Uid="ProfilesCreateProfileButtonText" Text="Create" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <TextBlock x:Uid="ProfilesBookDefaultsSectionHeader"
                               Style="{StaticResource ProfilesSectionHeaderTextBlockStyle}"
                               Text="Book Defaults" />

                    <toolkit:SettingsCard x:Uid="ProfilesJapaneseBooksCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="Japanese Books"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}">
                        <ComboBox x:Uid="ProfilesJapanesePrimaryProfileComboBox"
                                  MinWidth="260"
                                  AutomationProperties.AutomationId="JapanesePrimaryProfileComboBox"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{x:Bind ViewModel.JapaneseProfiles, Mode=OneWay}"
                                  SelectedValue="{x:Bind ViewModel.JapanesePrimaryProfileId, Mode=TwoWay}"
                                  SelectedValuePath="Id" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard x:Uid="ProfilesEnglishBooksCard"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          Header="English Books"
                                          HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}">
                        <ComboBox x:Uid="ProfilesEnglishPrimaryProfileComboBox"
                                  MinWidth="260"
                                  AutomationProperties.AutomationId="EnglishPrimaryProfileComboBox"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{x:Bind ViewModel.EnglishProfiles, Mode=OneWay}"
                                  SelectedValue="{x:Bind ViewModel.EnglishPrimaryProfileId, Mode=TwoWay}"
                                  SelectedValuePath="Id" />
                    </toolkit:SettingsCard>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
