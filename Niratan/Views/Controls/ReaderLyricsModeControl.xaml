<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="Niratan.Views.Controls.ReaderLyricsModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:win2d="using:Microsoft.Graphics.Canvas.UI.Xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             IsTabStop="True"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="LyricsTransportButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E0FFFFFF" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style x:Key="LyricsOptionButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#DFFFFFFF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Resources>

    <Grid x:Name="LyricsRoot"
          Background="#FF090A0C"
          PointerPressed="LyricsRoot_PointerPressed"
          AutomationProperties.AutomationId="NovelReaderLyricsMode">
        <Image x:Name="LyricsBackgroundImage"
               Stretch="UniformToFill"
               Opacity="0.22"
               IsHitTestVisible="False" />
        <Rectangle IsHitTestVisible="False">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#29000000" Offset="0" />
                    <GradientStop Color="#BD0D1414" Offset="0.52" />
                    <GradientStop Color="#E0000000" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Button x:Name="LyricsExitButton"
                x:Uid="NovelReaderLyricsExitButton"
                AutomationProperties.AutomationId="NovelReaderLyricsExitButton"
                Canvas.ZIndex="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,36,52,0"
                Width="38"
                Height="38"
                Padding="0"
                Background="Transparent"
                Foreground="#BDFFFFFF"
                BorderThickness="0"
                Click="LyricsExitButton_Click">
            <FontIcon Glyph="&#xE711;" FontSize="18" FontWeight="Bold" />
        </Button>

        <Grid Margin="34,26,34,26"
              ColumnDefinitions="0.44*,0.08*,*">
            <Grid Grid.Column="0"
                  MaxWidth="430"
                  MinWidth="220"
                  RowDefinitions="*,Auto,Auto,Auto"
                  RowSpacing="12">
                <Viewbox MaxHeight="430"
                         MaxWidth="430"
                         MinHeight="96"
                         MinWidth="96"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         Stretch="Uniform">
                    <Border Width="430"
                            Height="430"
                            CornerRadius="10"
                            Background="Transparent">
                        <Grid>
                            <Image x:Name="LyricsCoverImage"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Stretch="Uniform" />
                            <FontIcon x:Name="LyricsCoverFallbackIcon"
                                      Glyph="&#xE82D;"
                                      FontSize="58"
                                      Foreground="#70FFFFFF"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Viewbox>

                <StackPanel Grid.Row="1" Spacing="6">
                    <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#EEFFFFFF"
                               MaxLines="1"
                               TextTrimming="WordEllipsis" />
                    <TextBlock Text="{x:Bind ViewModel.StatisticsSummaryText, Mode=OneWay}"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="#78FFFFFF"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <ProgressBar Grid.Row="2"
                             Height="8"
                             Minimum="0"
                             Maximum="1"
                             Value="{x:Bind ViewModel.PlaybackProgress, Mode=OneWay}"
                             Foreground="#B8FFFFFF"
                             Background="#26FFFFFF" />

                <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="12">
                    <Button x:Uid="NovelReaderLyricsPreviousCueButton"
                            AutomationProperties.AutomationId="NovelReaderLyricsPreviousCueButton"
                            Style="{StaticResource LyricsTransportButtonStyle}"
                            Click="PreviousCueButton_Click">
                        <FontIcon Glyph="&#xE892;" FontSize="30" FontWeight="Bold" />
                    </Button>
                    <Button Grid.Column="1"
                            x:Uid="NovelReaderLyricsPlayPauseButton"
                            AutomationProperties.AutomationId="NovelReaderLyricsPlayPauseButton"
                            Width="64"
                            Height="64"
                            MinWidth="64"
                            MinHeight="64"
                            Padding="0"
                            Background="Transparent"
                            Foreground="#E0FFFFFF"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Click="PlayPauseButton_Click">
                        <FontIcon x:Name="LyricsPlayPauseIcon"
                                  Glyph="&#xE768;"
                                  FontSize="40"
                                  FontWeight="Bold" />
                    </Button>
                    <Button Grid.Column="2"
                            x:Uid="NovelReaderLyricsNextCueButton"
                            AutomationProperties.AutomationId="NovelReaderLyricsNextCueButton"
                            Style="{StaticResource LyricsTransportButtonStyle}"
                            Click="NextCueButton_Click">
                        <FontIcon Glyph="&#xE893;" FontSize="30" FontWeight="Bold" />
                    </Button>
                    <ToggleButton Grid.Column="4"
                                  x:Name="LyricsMaskToggle"
                                  x:Uid="NovelReaderLyricsMaskToggle"
                                  AutomationProperties.AutomationId="NovelReaderLyricsMaskToggle"
                                  Style="{StaticResource LyricsOptionButtonStyle}"
                                  IsChecked="{x:Bind ViewModel.IsMaskEnabled, Mode=TwoWay}">
                        <FontIcon x:Name="LyricsMaskIcon"
                                  Glyph="&#xE890;"
                                  FontSize="19"
                                  FontWeight="Bold" />
                    </ToggleButton>
                    <ToggleButton Grid.Column="5"
                                  x:Name="VerticalLyricsToggle"
                                  x:Uid="NovelReaderVerticalLyricsToggle"
                                  AutomationProperties.AutomationId="NovelReaderVerticalLyricsToggle"
                                  Style="{StaticResource LyricsOptionButtonStyle}"
                                  IsChecked="{x:Bind ViewModel.IsVertical, Mode=TwoWay}">
                        <FontIcon x:Name="VerticalLyricsIcon"
                                  Glyph="&#x25AF;"
                                  FontFamily="Segoe UI Symbol"
                                  FontSize="19"
                                  FontWeight="Bold" />
                    </ToggleButton>
                    <Button Grid.Column="6"
                            x:Name="LyricsStatisticsButton"
                            x:Uid="NovelReaderLyricsStatisticsButton"
                            AutomationProperties.AutomationId="NovelReaderLyricsStatisticsButton"
                            Width="36"
                            Height="36"
                            MinWidth="36"
                            MinHeight="36"
                            Padding="0"
                            Foreground="#DFFFFFFF"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Visibility="Collapsed"
                            Click="StatisticsButton_Click">
                        <FontIcon x:Name="LyricsStatisticsIcon"
                                  Glyph="&#xE9D2;"
                                  FontSize="19"
                                  FontWeight="Bold" />
                    </Button>
                </Grid>
            </Grid>

            <win2d:CanvasControl x:Name="LyricsCanvas"
                                 Grid.Column="2"
                                 MinWidth="260"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 AutomationProperties.AutomationId="NovelReaderLyricsTextCanvas"
                                 Draw="LyricsCanvas_Draw"
                                 PointerEntered="LyricsCanvas_PointerEntered"
                                 PointerExited="LyricsCanvas_PointerExited"
                                 PointerMoved="LyricsCanvas_PointerMoved"
                                 PointerPressed="LyricsCanvas_PointerPressed" />
        </Grid>
    </Grid>
</UserControl>
