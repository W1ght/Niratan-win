<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="Niratan.Views.Controls.CompactColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button x:Name="SwatchButton"
            Width="40"
            Height="40"
            Padding="4"
            HorizontalAlignment="Right"
            Background="Transparent"
            CornerRadius="20">
        <Grid>
            <Ellipse Width="28"
                     Height="28"
                     Fill="{ThemeResource ControlFillColorDefaultBrush}" />
            <Ellipse Width="28" Height="28" Fill="{x:Bind SwatchBrush, Mode=OneWay}" />
            <Ellipse Width="28"
                     Height="28"
                     Stroke="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                     StrokeThickness="1" />
        </Grid>
        <Button.Flyout>
            <Flyout Placement="{x:Bind FlyoutPlacement, Mode=OneWay}">
                <ColorPicker x:Name="Picker"
                             IsMoreButtonVisible="False"
                             ColorChanged="Picker_ColorChanged" />
            </Flyout>
        </Button.Flyout>
    </Button>
</UserControl>
