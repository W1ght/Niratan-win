{
  "env": {
    "HOSHI_NOVEL_READER_ARTIFACT_DIR": "${projectDir}/docs/superpowers/artifacts/novel-reader"
  },
  "permissions": {
    "allow": [
      "Bash(dotnet restore)",
      "Bash(dotnet build)",
      "Bash(dotnet test)",
      "Bash(dotnet clean)",
      "Bash(dotnet run)",
      "Bash(ls)",
      "Bash(dir)",
      "Bash(mkdir *)",
      "Bash(cd *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(which dotnet)",
      "Bash(dotnet --version)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(git remote *)",
      "Bash(git worktree *)",
      "Bash(gh *)",
      "Bash(tasklist *)",
      "Bash(where *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(powershell *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(shutdown *)",
      "Bash(del /f /s *)"
    ]
  },

  "mcpServers": {
    "github": {
      "command": "${env:APPDATA}\\fnm\\node-versions\\v24.16.0\\installation\\npx.cmd",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "sqlite": {
      "command": "${env:APPDATA}\\fnm\\node-versions\\v24.16.0\\installation\\npx.cmd",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "--db-path", "${env:APPDATA}\\Hoshi\\Data\\hoshi.db"]
    },
    "dotnet": {
      "command": "${env:APPDATA}\\fnm\\node-versions\\v24.16.0\\installation\\npx.cmd",
      "args": ["-y", "@paretools/dotnet"]
    },
    "nuget": {
      "command": "${env:APPDATA}\\fnm\\node-versions\\v24.16.0\\installation\\npx.cmd",
      "args": ["-y", "package-registry-mcp"]
    }
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"$ext=[System.IO.Path]::GetExtension('${file}'); if ($ext -in '.cs','.xaml','.csproj') { dotnet build -p:Platform=x64 --no-restore 2>&1 | Select-Object -Last 5 }\""
          }
        ]
      }
    ]
  }
}
